:root {
  color-scheme: dark;
  --bg: #020614;
  --panel: rgba(7, 17, 43, .58);
  --panel-strong: rgba(12, 25, 62, .78);
  --line: rgba(89, 167, 255, .36);
  --cyan: #56f7ff;
  --blue: #2488ff;
  --violet: #9c54ff;
  --pink: #ff63db;
  --gold: #ffd36c;
  --green: #46ffba;
  --text: #f7fbff;
  --muted: #9fb2d9;
  --progress: 64%;
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  min-height: 100%;
  background:
    radial-gradient(circle at 50% 18%, rgba(68, 113, 255, .22), transparent 32rem),
    radial-gradient(circle at 20% 72%, rgba(143, 62, 255, .18), transparent 25rem),
    linear-gradient(180deg, #03040b 0%, #040819 48%, #02040c 100%);
  color: var(--text);
  font-family: Inter, Segoe UI, Arial, sans-serif;
  overflow-x: hidden;
}

button {
  font: inherit;
  color: inherit;
}

.ambient {
  position: fixed;
  inset: auto;
  width: 44rem;
  height: 44rem;
  border-radius: 50%;
  filter: blur(48px);
  opacity: .18;
  pointer-events: none;
}

.ambient-a {
  top: -16rem;
  left: calc(50% - 38rem);
  background: #1677ff;
}

.ambient-b {
  right: calc(50% - 36rem);
  bottom: 0;
  background: #a855ff;
}

.phone-shell {
  position: relative;
  width: min(100vw, 520px);
  min-height: 100svh;
  margin: 0 auto;
  padding: 22px 18px max(22px, env(safe-area-inset-bottom));
  isolation: isolate;
  overflow: hidden;
  border: 1px solid rgba(87, 132, 255, .28);
  background:
    linear-gradient(180deg, rgba(9, 14, 32, .68), rgba(3, 8, 22, .92)),
    radial-gradient(circle at 50% 36%, rgba(31, 126, 255, .12), transparent 22rem);
  box-shadow:
    inset 0 0 32px rgba(68, 128, 255, .12),
    0 0 60px rgba(0, 0, 0, .55);
}

.phone-shell::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -2;
  background-image:
    linear-gradient(rgba(86, 247, 255, .06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(86, 247, 255, .05) 1px, transparent 1px);
  background-size: 42px 42px;
  mask-image: radial-gradient(circle at 50% 40%, #000 0 58%, transparent 83%);
}

.screen-glow {
  position: absolute;
  inset: 0;
  z-index: -1;
  background:
    radial-gradient(circle at 50% 60%, rgba(14, 204, 255, .22), transparent 25rem),
    linear-gradient(90deg, transparent, rgba(94, 219, 255, .08), transparent);
  opacity: .78;
  animation: slow-pulse 5.4s ease-in-out both;
}

.topbar,
.mode-pill,
.workflow-dock,
.command-card,
.live-data,
.bottom-nav,
.glass-panel {
  backdrop-filter: blur(18px) saturate(145%);
  -webkit-backdrop-filter: blur(18px) saturate(145%);
}

.topbar {
  position: relative;
  z-index: 20;
  display: grid;
  grid-template-columns: 48px 1fr 58px;
  align-items: center;
  gap: 12px;
}

.brand {
  text-align: center;
  letter-spacing: .08em;
  text-shadow: 0 0 18px rgba(86, 247, 255, .58);
}

.brand strong {
  display: block;
  font-size: clamp(1.38rem, 6vw, 2.15rem);
  line-height: 1.05;
  font-weight: 800;
}

.brand small {
  display: block;
  color: #b6c6ff;
  font-size: .84rem;
  margin-top: 4px;
}

.icon-btn {
  width: 48px;
  height: 48px;
  border: 1px solid rgba(98, 164, 255, .34);
  border-radius: 16px;
  background: rgba(7, 15, 38, .55);
  box-shadow: inset 0 0 20px rgba(55, 132, 255, .15), 0 0 18px rgba(0, 195, 255, .11);
  display: grid;
  place-items: center;
  cursor: pointer;
}

.icon-btn span {
  display: block;
  width: 22px;
  height: 2px;
  margin: 2px 0;
  background: linear-gradient(90deg, #bfefff, #4ee8ff);
  box-shadow: 0 0 10px #50e7ff;
}

.badge-btn {
  font-weight: 800;
  color: #e8efff;
}

.badge-btn::before {
  content: "";
  width: 11px;
  height: 19px;
  display: inline-block;
  margin-right: 7px;
  border-radius: 9px 9px 3px 3px;
  background: linear-gradient(180deg, var(--cyan), var(--violet));
  clip-path: polygon(56% 0, 100% 0, 68% 41%, 100% 41%, 36% 100%, 49% 55%, 10% 55%);
  filter: drop-shadow(0 0 9px var(--cyan));
}

.mode-pill {
  position: relative;
  z-index: 16;
  width: max-content;
  max-width: 92%;
  margin: 16px auto 8px;
  padding: 10px 20px;
  border: 1px solid rgba(67, 242, 255, .46);
  border-radius: 999px;
  background: linear-gradient(90deg, rgba(2, 19, 45, .76), rgba(10, 28, 68, .68));
  color: #8dffff;
  font-weight: 800;
  letter-spacing: .06em;
  text-align: center;
  box-shadow: 0 0 30px rgba(41, 222, 255, .18), inset 0 0 18px rgba(58, 255, 234, .09);
}

.pill-dot {
  display: inline-block;
  width: 9px;
  height: 9px;
  margin-right: 9px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 14px var(--green);
  vertical-align: 1px;
}

.thinking-dots {
  display: inline-flex;
  gap: 6px;
  margin-left: 12px;
}

.thinking-dots i {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--cyan);
  animation: dot 1.15s ease-in-out both;
}

.thinking-dots i:nth-child(2) {
  animation-delay: .16s;
}

.thinking-dots i:nth-child(3) {
  animation-delay: .32s;
}

.hero {
  position: relative;
  min-height: 850px;
  margin: 6px -8px 18px;
  overflow: hidden;
  border-radius: 30px;
}

.hero-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 50% 41%;
  opacity: .92;
  filter: saturate(1.12) contrast(1.08) brightness(.9);
  transform: scale(1.025);
  transition: opacity .45s ease, transform .9s ease, filter .45s ease;
}


.hero-motion {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 50% 43%;
  opacity: .58;
  filter: saturate(1.32) contrast(1.12) brightness(.86);
  transform: scale(1.035);
  mix-blend-mode: screen;
  pointer-events: none;
  transition: opacity .38s ease, filter .38s ease, transform .8s ease;
  -webkit-mask-image: radial-gradient(ellipse at 50% 49%, #000 0 51%, rgba(0,0,0,.75) 61%, transparent 81%);
  mask-image: radial-gradient(ellipse at 50% 49%, #000 0 51%, rgba(0,0,0,.75) 61%, transparent 81%);
}

.motion-sheen {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at 50% 72%, rgba(255, 211, 108, .26), transparent 14rem),
    radial-gradient(circle at 50% 35%, rgba(86, 247, 255, .2), transparent 18rem),
    linear-gradient(115deg, transparent 0 34%, rgba(86, 247, 255, .13) 46%, transparent 58% 100%);
  mix-blend-mode: screen;
  opacity: .68;
  animation: motion-sweep 3.8s ease-in-out both;
}

.phone-shell[data-mode="running"] .hero-motion,
.phone-shell[data-mode="analyzing"] .hero-motion {
  opacity: .74;
  filter: saturate(1.45) contrast(1.16) brightness(.96);
}

.phone-shell[data-mode="answer"] .hero-motion,
.phone-shell[data-mode="listening"] .hero-motion {
  opacity: .68;
}

.phone-shell[data-mode="clarify"] .hero-motion {
  opacity: .42;
  filter: saturate(1.15) contrast(1.05) brightness(.74);
}

.phone-shell[data-motion="still"] .hero-motion {
  opacity: 0;
}

.phone-shell[data-mode="listening"] .hero-image {
  object-position: 50% 50%;
  filter: saturate(1.18) contrast(1.1) brightness(.98);
}

.phone-shell[data-mode="map"] .hero-image {
  object-fit: cover;
  object-position: 50% 52%;
}

.hero-vignette {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(0, 3, 10, .22), transparent 24%, rgba(0, 5, 19, .72) 92%),
    radial-gradient(circle at 50% 53%, transparent 0 32%, rgba(2, 5, 15, .5) 76%);
  pointer-events: none;
}

.scanline {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(180deg, transparent, rgba(114, 246, 255, .12), transparent);
  height: 27%;
  transform: translateY(-120%);
  animation: scan 4.7s linear both;
  mix-blend-mode: screen;
}

.energy-column {
  position: absolute;
  left: 50%;
  bottom: 8%;
  width: 3px;
  height: 52%;
  border-radius: 999px;
  background: linear-gradient(180deg, transparent, rgba(92, 246, 255, .85), transparent);
  transform: translateX(-50%);
  box-shadow: 0 0 34px 12px rgba(40, 199, 255, .28);
  opacity: .9;
  animation: beam 2.8s ease-in-out both;
}

.orbit {
  position: absolute;
  left: 50%;
  top: 45%;
  border-radius: 50%;
  border: 1px solid rgba(100, 215, 255, .28);
  box-shadow: 0 0 22px rgba(60, 211, 255, .16), inset 0 0 22px rgba(123, 77, 255, .12);
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.orbit-one {
  width: 330px;
  height: 330px;
  animation: rotate 18s linear both;
}

.orbit-two {
  width: 420px;
  height: 420px;
  border-color: rgba(159, 88, 255, .24);
  animation: rotate 26s linear reverse both;
}

.orbit-three {
  width: 250px;
  height: 250px;
  border-color: rgba(255, 203, 103, .2);
  animation: rotate 12s linear both;
}

.node-cloud {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.node {
  position: absolute;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #74fbff;
  box-shadow: 0 0 12px #5df1ff, 0 0 28px rgba(143, 84, 255, .8);
  animation: float-node 4.6s ease-in-out both;
}

.glass-panel {
  position: absolute;
  z-index: 8;
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 13px;
  background: var(--panel);
  box-shadow: inset 0 0 22px rgba(43, 136, 255, .11), 0 0 22px rgba(21, 178, 255, .12);
}

.panel-title {
  margin-bottom: 11px;
  color: #f6f9ff;
  font-size: .75rem;
  font-weight: 800;
  letter-spacing: .04em;
}

.panel-core {
  left: 14px;
  top: 66px;
  width: 155px;
}

.core-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.core-orb {
  width: 38px;
  height: 38px;
  flex: 0 0 auto;
  border-radius: 50%;
  background:
    radial-gradient(circle at 55% 45%, var(--cyan) 0 5px, transparent 6px),
    conic-gradient(from 30deg, var(--blue), var(--violet), var(--cyan), var(--blue));
  box-shadow: 0 0 18px rgba(82, 242, 255, .48);
  animation: rotate 5s linear both;
}

.core-row small,
.mini-metrics small,
.workflow-stats label,
.throughput small,
.live-data small,
.steps small {
  display: block;
  color: var(--muted);
  font-size: .64rem;
}

.core-row b {
  display: block;
  color: var(--green);
  font-size: .82rem;
}

.mini-metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 13px;
}

.mini-metrics b,
.workflow-stats b,
.throughput b,
.live-data b {
  display: block;
  color: #85ffff;
  font-size: 1rem;
  margin-top: 3px;
}

.sparkline {
  width: 100%;
  height: 30px;
  margin-top: 8px;
}

.sparkline polyline {
  fill: none;
  stroke: var(--cyan);
  stroke-width: 2;
  filter: drop-shadow(0 0 4px var(--cyan));
}

.panel-workflow {
  right: 14px;
  top: 72px;
  width: 142px;
}

.micro-flow {
  position: relative;
  height: 88px;
}

.micro-flow::before,
.micro-flow::after {
  content: "";
  position: absolute;
  border: 1px solid rgba(82, 215, 255, .38);
  border-radius: 9px;
}

.micro-flow::before {
  left: 18px;
  top: 18px;
  width: 68px;
  height: 50px;
  border-right: 0;
}

.micro-flow::after {
  right: 13px;
  top: 10px;
  width: 42px;
  height: 64px;
  border-left: 0;
}

.micro-flow span {
  position: absolute;
  width: 22px;
  height: 22px;
  border: 1px solid rgba(103, 225, 255, .65);
  border-radius: 6px;
  background: rgba(7, 22, 55, .78);
  box-shadow: 0 0 10px rgba(67, 232, 255, .36);
}

.micro-flow span:nth-child(1) { left: 4px; top: 34px; border-color: var(--gold); }
.micro-flow span:nth-child(2) { left: 48px; top: 2px; }
.micro-flow span:nth-child(3) { right: 4px; top: 22px; }
.micro-flow span:nth-child(4) { left: 50px; bottom: 0; }
.micro-flow span:nth-child(5) { right: 3px; bottom: 8px; border-color: var(--violet); }

.workflow-stats {
  display: grid;
  gap: 7px;
}

.workflow-stats label {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.workflow-stats b {
  display: inline;
  font-size: .78rem;
}

.panel-capabilities {
  left: 14px;
  top: 286px;
  width: 168px;
}

.panel-capabilities .cap,
.panel-builder button {
  width: 100%;
  height: 34px;
  margin: 4px 0;
  border: 1px solid rgba(82, 151, 255, .24);
  border-radius: 9px;
  background: rgba(5, 17, 47, .48);
  color: #eaf2ff;
  text-align: left;
  padding: 0 11px;
  cursor: pointer;
  text-transform: uppercase;
  font-size: .66rem;
  letter-spacing: .03em;
}

.panel-capabilities .active,
.panel-capabilities .cap:hover,
.panel-builder button:hover {
  border-color: rgba(87, 244, 255, .58);
  box-shadow: inset 0 0 16px rgba(86, 247, 255, .11);
}

.panel-builder {
  right: 12px;
  top: 294px;
  width: 160px;
}

.panel-builder .hot {
  border-color: rgba(212, 92, 255, .52);
}

.panel-builder .gold {
  border-color: rgba(255, 199, 91, .45);
}

.panel-library {
  left: 14px;
  bottom: 40px;
  width: 168px;
}

.library-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.library-grid button {
  height: 42px;
  border: 1px solid rgba(93, 174, 255, .34);
  border-radius: 9px;
  background: rgba(5, 16, 42, .6);
  color: #bdf5ff;
  cursor: pointer;
  font-size: .68rem;
}

.panel-stream {
  right: 12px;
  bottom: 40px;
  width: 170px;
}

.binary-stream {
  display: grid;
  gap: 5px;
  min-height: 94px;
  font-family: Consolas, monospace;
  color: rgba(124, 222, 255, .8);
  font-size: .6rem;
}

.binary-stream div {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: clip;
  text-shadow: 0 0 7px rgba(86, 247, 255, .38);
}

.binary-stream em {
  color: var(--gold);
  font-style: normal;
}

.throughput {
  display: flex;
  justify-content: space-between;
  align-items: end;
  margin-top: 8px;
}

.command-card,
.workflow-dock,
.live-data,
.bottom-nav {
  position: relative;
  z-index: 18;
  border: 1px solid rgba(95, 170, 255, .38);
  background: var(--panel-strong);
  box-shadow: inset 0 0 26px rgba(42, 130, 255, .13), 0 0 28px rgba(26, 156, 255, .13);
}

.command-card {
  margin: 8px 0 16px;
  padding: 18px;
  border-radius: 24px;
}

.command-main {
  display: grid;
  grid-template-columns: 48px 1fr 62px;
  gap: 14px;
  align-items: center;
}

.command-icon {
  width: 45px;
  height: 45px;
  border-radius: 16px;
  background:
    radial-gradient(circle, #e9fdff 0 12%, transparent 14%),
    conic-gradient(from 45deg, var(--cyan), transparent 20%, var(--violet), transparent 60%, var(--cyan));
  filter: drop-shadow(0 0 16px rgba(86, 247, 255, .65));
  animation: rotate 7s linear both;
}

.command-card h1 {
  margin: 0;
  font-size: clamp(1.32rem, 5vw, 1.74rem);
  line-height: 1.1;
  font-weight: 760;
}

.command-card p {
  margin: 7px 0 0;
  color: #c0c9e7;
  line-height: 1.36;
  font-size: .9rem;
}

.voice-button {
  width: 58px;
  height: 58px;
  border-radius: 50%;
  border: 1px solid rgba(139, 86, 255, .58);
  background:
    radial-gradient(circle, rgba(14, 24, 64, .95) 0 44%, transparent 45%),
    conic-gradient(var(--cyan), var(--violet), var(--pink), var(--cyan));
  box-shadow: 0 0 22px rgba(124, 92, 255, .42);
  display: grid;
  place-items: center;
  cursor: pointer;
}

.voice-button span {
  width: 26px;
  height: 30px;
  background:
    linear-gradient(90deg, transparent 0 10%, var(--cyan) 10% 20%, transparent 20% 31%, var(--cyan) 31% 41%, transparent 41% 58%, var(--cyan) 58% 68%, transparent 68% 80%, var(--cyan) 80% 90%, transparent 90%);
  filter: drop-shadow(0 0 8px var(--cyan));
  animation: bars 1.1s ease-in-out both;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 17px;
}

.quick-actions button,
.choice-grid button {
  min-height: 44px;
  border: 1px solid rgba(99, 164, 255, .28);
  border-radius: 14px;
  background: rgba(4, 17, 45, .55);
  color: #eef5ff;
  box-shadow: inset 0 0 18px rgba(53, 149, 255, .09);
  cursor: pointer;
}

.quick-actions button:hover,
.choice-grid button:hover {
  border-color: rgba(86, 247, 255, .62);
}

.request-composer {
  margin-top: 16px;
  padding: 14px;
  border: 1px solid rgba(86, 247, 255, .32);
  border-radius: 18px;
  background: rgba(2, 12, 33, .62);
  box-shadow: inset 0 0 22px rgba(51, 159, 255, .12), 0 0 20px rgba(21, 178, 255, .08);
  direction: rtl;
}

.composer-head {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
  color: #eff9ff;
  font-weight: 800;
}

.request-composer textarea {
  width: 100%;
  min-height: 92px;
  resize: vertical;
  border: 1px solid rgba(99, 164, 255, .34);
  border-radius: 14px;
  background: rgba(1, 8, 24, .72);
  color: #f8fbff;
  padding: 12px;
  outline: none;
  line-height: 1.45;
  font-size: 1rem;
  box-shadow: inset 0 0 18px rgba(0, 0, 0, .18);
}

.request-composer textarea:focus {
  border-color: rgba(86, 247, 255, .74);
  box-shadow: 0 0 18px rgba(86, 247, 255, .18), inset 0 0 18px rgba(0, 0, 0, .18);
}

.request-composer textarea::placeholder {
  color: rgba(203, 213, 243, .62);
}

.composer-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  margin-top: 10px;
}

.send-request {
  min-height: 44px;
  border: 1px solid rgba(70, 255, 186, .55);
  border-radius: 14px;
  background: linear-gradient(135deg, rgba(0, 166, 255, .24), rgba(70, 255, 186, .18));
  color: #f4fffb;
  cursor: pointer;
  font-weight: 800;
  box-shadow: 0 0 20px rgba(70, 255, 186, .14);
}

.send-request:disabled {
  opacity: .55;
  cursor: wait;
}

.composer-status {
  min-height: 20px;
  margin: 10px 0 0;
  color: #b8c4e8;
  font-size: .84rem;
}

.composer-status.ok {
  color: var(--green);
}

.composer-status.error {
  color: var(--gold);
}

.answer-panel,
.clarify-panel {
  display: none;
  margin-top: 16px;
  border: 1px solid rgba(88, 244, 255, .32);
  border-radius: 17px;
  padding: 16px;
  background: rgba(4, 15, 40, .52);
}

.answer-panel {
  grid-template-columns: 48px 1fr;
  gap: 14px;
  align-items: center;
}

.answer-check {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid rgba(61, 255, 220, .55);
  box-shadow: 0 0 22px rgba(61, 255, 220, .36);
  position: relative;
}

.answer-check::before {
  content: "";
  position: absolute;
  width: 18px;
  height: 10px;
  border-left: 4px solid var(--green);
  border-bottom: 4px solid var(--green);
  transform: rotate(-45deg);
  left: 12px;
  top: 13px;
}

.answer-panel h2,
.clarify-panel h2 {
  margin: 0;
  text-transform: uppercase;
  font-size: 1rem;
  letter-spacing: .04em;
}

.clarify-panel {
  border-color: rgba(255, 201, 91, .56);
}

.question-mark {
  display: grid;
  place-items: center;
  width: 52px;
  height: 52px;
  margin-bottom: 9px;
  border: 1px solid var(--gold);
  border-radius: 16px;
  color: var(--gold);
  font-weight: 900;
  font-size: 1.9rem;
  box-shadow: 0 0 20px rgba(255, 190, 84, .26);
}

.choice-grid {
  display: grid;
  gap: 9px;
  margin-top: 14px;
}

.choice-grid .selected {
  border-color: rgba(212, 94, 255, .8);
  box-shadow: inset 0 0 20px rgba(188, 82, 255, .15);
}

.workflow-dock {
  padding: 14px;
  border-radius: 22px;
}

.dock-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-bottom: 12px;
}

.dock-title strong {
  font-size: .78rem;
  letter-spacing: .05em;
}

.dock-title span {
  color: #cbd5f3;
  font-size: .76rem;
}

.steps {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8px;
}

.steps button {
  position: relative;
  min-width: 0;
  min-height: 74px;
  border: 1px solid rgba(91, 166, 255, .33);
  border-radius: 13px;
  background: rgba(5, 18, 48, .62);
  display: grid;
  place-items: center;
  align-content: center;
  gap: 5px;
  cursor: pointer;
  overflow: hidden;
}

.steps button::after {
  content: "";
  position: absolute;
  right: -13px;
  top: 50%;
  width: 23px;
  height: 2px;
  background: linear-gradient(90deg, var(--cyan), transparent);
  box-shadow: 0 0 9px var(--cyan);
}

.steps button:last-child::after {
  display: none;
}

.steps i {
  width: 24px;
  height: 24px;
  border-radius: 8px;
  border: 1px solid rgba(112, 226, 255, .64);
  box-shadow: inset 0 0 14px rgba(86, 247, 255, .12), 0 0 12px rgba(86, 247, 255, .28);
}

.steps b {
  font-size: .58rem;
  letter-spacing: .02em;
}

.steps .done {
  border-color: rgba(78, 255, 190, .58);
}

.steps .active {
  border-color: rgba(255, 211, 108, .78);
  box-shadow: inset 0 0 18px rgba(255, 211, 108, .13), 0 0 18px rgba(255, 211, 108, .18);
}

.progress-track {
  height: 5px;
  margin: 14px 1px 11px;
  border-radius: 999px;
  background: rgba(74, 110, 170, .28);
  overflow: hidden;
}

.progress-track span {
  display: block;
  width: var(--progress);
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, var(--cyan), var(--blue), var(--violet), var(--gold));
  box-shadow: 0 0 18px rgba(87, 237, 255, .66);
  transition: width .5s ease;
}

.runtime-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #d8e5ff;
  font-size: .86rem;
}

.runtime-line b {
  color: #fff;
}

.live-data {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  margin: 14px 0;
  padding: 12px 10px;
  border-radius: 18px;
}

.live-data div {
  text-align: center;
  border-right: 1px solid rgba(100, 172, 255, .18);
}

.live-data div:last-child {
  border-right: 0;
}

.live-data b {
  font-size: 1.03rem;
}

.bottom-nav {
  position: sticky;
  bottom: max(8px, env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8px;
  padding: 10px 14px;
  border-radius: 28px;
  background: rgba(6, 15, 39, .82);
}

.bottom-nav button {
  height: 48px;
  border: 0;
  border-radius: 18px;
  background: transparent;
  cursor: pointer;
  position: relative;
}

.bottom-nav button::before {
  content: "";
  position: absolute;
  inset: 13px;
  border: 2px solid rgba(192, 210, 255, .72);
  border-radius: 9px;
  opacity: .78;
}

.bottom-nav button:nth-child(1)::before { border-radius: 50% 50% 10px 10px; }
.bottom-nav button:nth-child(2)::before { transform: rotate(45deg); }
.bottom-nav button:nth-child(4)::before { clip-path: polygon(0 70%, 25% 50%, 45% 62%, 73% 20%, 100% 30%, 100% 100%, 0 100%); }
.bottom-nav button:nth-child(5)::before { border-radius: 50%; }

.bottom-nav .primary {
  margin-top: -28px;
  height: 78px;
  border-radius: 50%;
  background:
    radial-gradient(circle, rgba(8, 23, 60, 1) 0 48%, transparent 49%),
    conic-gradient(var(--cyan), var(--violet), var(--blue), var(--cyan));
  box-shadow: 0 0 28px rgba(90, 224, 255, .58), inset 0 0 28px rgba(139, 91, 255, .3);
}

.bottom-nav .primary::before {
  inset: 21px;
  border-color: #bdfdff;
  box-shadow: 0 0 18px rgba(86, 247, 255, .58);
}

.phone-shell[data-mode="answer"] .answer-panel {
  display: grid;
}

.phone-shell[data-mode="clarify"] .clarify-panel {
  display: block;
}

.phone-shell[data-mode="answer"] .quick-actions,
.phone-shell[data-mode="clarify"] .quick-actions {
  display: none;
}

.phone-shell[data-mode="listening"] .command-card {
  text-align: center;
}

.phone-shell[data-mode="listening"] .command-main {
  grid-template-columns: 1fr;
}

.phone-shell[data-mode="listening"] .voice-button {
  margin: 0 auto;
  width: 92px;
  height: 92px;
}

.phone-shell[data-mode="listening"] .command-icon {
  display: none;
}

.screen-glow,
.thinking-dots i,
.motion-sheen,
.scanline,
.energy-column,
.orbit-one,
.orbit-two,
.orbit-three,
.node,
.core-orb,
.command-icon,
.voice-button span {
  animation-play-state: paused;
}

.thinking-dots,
.motion-sheen,
.scanline {
  opacity: 0;
}

.phone-shell:not(.is-animating) .hero-motion {
  opacity: 0;
}

.phone-shell.is-animating .screen-glow,
.phone-shell.is-animating .thinking-dots i,
.phone-shell.is-animating .motion-sheen,
.phone-shell.is-animating .scanline,
.phone-shell.is-animating .energy-column,
.phone-shell.is-animating .orbit-one,
.phone-shell.is-animating .orbit-two,
.phone-shell.is-animating .orbit-three,
.phone-shell.is-animating .node,
.phone-shell.is-animating .core-orb,
.phone-shell.is-animating .command-icon,
.phone-shell.is-animating .voice-button span {
  animation-play-state: running;
  animation-iteration-count: 1;
}

.phone-shell.is-animating .thinking-dots {
  opacity: 1;
}

.phone-shell.is-animating .motion-sheen {
  opacity: .68;
  animation-name: motion-sweep;
  animation-duration: 1.6s;
}

.phone-shell.is-animating .scanline {
  opacity: 1;
  animation-duration: 1.45s;
}

.phone-shell.is-animating .energy-column {
  animation-duration: 1.2s;
}

.phone-shell.is-animating .orbit-one,
.phone-shell.is-animating .orbit-two,
.phone-shell.is-animating .orbit-three {
  animation-duration: 2.2s;
}

.phone-shell.is-animating .node {
  animation-duration: 1.35s;
}

.phone-shell.is-animating .steps .active {
  animation: step-flash .72s ease-out 1;
}

.phone-shell.is-animating .command-card {
  animation: card-kick .52s ease-out 1;
}

@media (max-width: 430px) {
  .phone-shell {
    padding-inline: 12px;
  }

  .hero {
    min-height: 820px;
    margin-inline: -6px;
  }

  .panel-core,
  .panel-workflow,
  .panel-capabilities,
  .panel-builder,
  .panel-library,
  .panel-stream {
    transform: scale(.82);
    transform-origin: top left;
  }

  .panel-workflow,
  .panel-builder,
  .panel-stream {
    transform-origin: top right;
  }

  .panel-library {
    transform-origin: bottom left;
  }

  .panel-stream {
    transform-origin: bottom right;
  }

  .steps {
    gap: 5px;
  }

  .steps button {
    min-height: 66px;
  }

  .steps b {
    font-size: .5rem;
  }
}

@media (min-width: 860px) {
  .phone-shell {
    width: min(96vw, 1060px);
    border-radius: 34px;
  }

  .hero {
    min-height: 850px;
  }

  .command-card,
  .workflow-dock,
  .live-data,
  .bottom-nav {
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .panel-core { left: 34px; width: 190px; }
  .panel-workflow { right: 34px; width: 190px; }
  .panel-capabilities { left: 42px; width: 200px; }
  .panel-builder { right: 42px; width: 205px; }
  .panel-library { left: 44px; width: 230px; }
  .panel-stream { right: 44px; width: 230px; }
}

@keyframes rotate {
  to { rotate: 360deg; }
}

@keyframes slow-pulse {
  0%, 100% { opacity: .58; }
  50% { opacity: .9; }
}

@keyframes dot {
  0%, 100% { opacity: .25; transform: translateY(0); }
  50% { opacity: 1; transform: translateY(-2px); }
}

@keyframes scan {
  to { transform: translateY(470%); }
}

@keyframes motion-sweep {
  from { transform: translateX(-34%); opacity: 0; }
  40% { opacity: .74; }
  to { transform: translateX(34%); opacity: 0; }
}

@keyframes beam {
  0%, 100% { opacity: .54; transform: translateX(-50%) scaleY(.84); }
  50% { opacity: 1; transform: translateX(-50%) scaleY(1.05); }
}

@keyframes float-node {
  0%, 100% { transform: translate3d(0, 0, 0) scale(.85); opacity: .55; }
  50% { transform: translate3d(0, -10px, 0) scale(1.18); opacity: 1; }
}

@keyframes bars {
  0%, 100% { transform: scaleY(.72); opacity: .7; }
  50% { transform: scaleY(1.18); opacity: 1; }
}

@keyframes step-flash {
  0% { transform: translateY(0); box-shadow: inset 0 0 18px rgba(255, 211, 108, .13), 0 0 0 rgba(255, 211, 108, 0); }
  42% { transform: translateY(-3px); box-shadow: inset 0 0 20px rgba(255, 211, 108, .18), 0 0 26px rgba(255, 211, 108, .35); }
  100% { transform: translateY(0); box-shadow: inset 0 0 18px rgba(255, 211, 108, .13), 0 0 18px rgba(255, 211, 108, .18); }
}

@keyframes card-kick {
  0% { transform: translateY(0); border-color: rgba(95, 170, 255, .38); }
  45% { transform: translateY(-4px); border-color: rgba(86, 247, 255, .74); }
  100% { transform: translateY(0); border-color: rgba(95, 170, 255, .38); }
}


.phone-shell[data-voice="listening"] .voice-button,
.phone-shell[data-voice="speaking"] .voice-button {
  border-color: rgba(86, 247, 255, .9);
  box-shadow: 0 0 32px rgba(86, 247, 255, .48), inset 0 0 22px rgba(156, 84, 255, .22);
}

.phone-shell[data-voice="listening"] .voice-button::after,
.phone-shell[data-voice="speaking"] .voice-button::after {
  content: "";
  position: absolute;
  inset: -10px;
  border: 1px solid rgba(86, 247, 255, .55);
  border-radius: 50%;
  animation: voice-ring 1.15s ease-out infinite;
}

.phone-shell[data-voice="listening"] .request-composer,
.phone-shell[data-voice="speaking"] .request-composer {
  border-color: rgba(86, 247, 255, .62);
  box-shadow: inset 0 0 24px rgba(51, 159, 255, .18), 0 0 26px rgba(21, 178, 255, .2);
}

.phone-shell[data-voice="listening"] .composer-status {
  color: var(--cyan);
}

.phone-shell[data-voice="speaking"] .composer-status {
  color: var(--green);
}

@keyframes voice-ring {
  0% {
    opacity: .85;
    transform: scale(.82);
  }
  100% {
    opacity: 0;
    transform: scale(1.38);
  }
}
