(function () {
  var shell = document.getElementById('appShell');
  var heroImage = document.getElementById('heroImage');
  var heroMotion = document.getElementById('heroMotion');
  var modeLabel = document.getElementById('modeLabel');
  var commandTitle = document.getElementById('commandTitle');
  var commandText = document.getElementById('commandText');
  var runtimeStatus = document.getElementById('runtimeStatus');
  var runtimeValue = document.getElementById('runtimeValue');
  var progressBar = document.getElementById('progressBar');
  var binaryStream = document.getElementById('binaryStream');
  var nodeCloud = document.getElementById('nodeCloud');
  var steps = Array.prototype.slice.call(document.querySelectorAll('#steps button'));
  var requestComposer = document.getElementById('requestComposer');
  var requestInput = document.getElementById('requestInput');
  var composerStatus = document.getElementById('composerStatus');

  var assets = {
    running: '/app/assets/photo_2026-05-31_15-31-46.jpg',
    listening: '/app/assets/photo_2026-05-31_15-32-29.jpg',
    answer: '/app/assets/photo_2026-05-31_15-32-33.jpg',
    home: '/app/assets/photo_2026-05-31_15-32-37.jpg',
    analyzing: '/app/assets/photo_2026-05-31_15-32-45.jpg',
    clarify: '/app/assets/photo_2026-05-31_15-32-51.jpg',
    map: '/app/assets/photo_2026-05-31_15-32-58.jpg'
  };

  var motionAssets = {
    home: '/app/assets/orcastrator_flow.mp4',
    running: '/app/assets/orcastrator_burst.mp4',
    listening: '/app/assets/orcastrator_burst.mp4',
    answer: '/app/assets/orcastrator_flow.mp4',
    analyzing: '/app/assets/orcastrator_burst.mp4',
    clarify: '/app/assets/orcastrator_flow.mp4',
    map: '/app/assets/orcastrator_flow.mp4'
  };

  var modes = {
    home: {
      label: 'READY TO HELP',
      title: 'How can I help today?',
      text: 'I can build, optimize and manage AI agents for you.',
      runtime: 'Ready for command',
      progress: 63,
      step: 0
    },
    running: {
      label: 'RUNNING WORKFLOW',
      title: 'Executing workflow',
      text: 'Trigger, retrieve, reason, execute and respond are running in sequence.',
      runtime: 'Executing step',
      progress: 76,
      step: 3
    },
    listening: {
      label: 'LISTENING',
      title: 'Listening...',
      text: 'I am here, go ahead.',
      runtime: 'Voice stream active',
      progress: 42,
      step: 0
    },
    answer: {
      label: 'ANSWER READY',
      title: 'Answer ready',
      text: 'The agent finished building the response and is ready to send.',
      runtime: 'Response composed',
      progress: 100,
      step: 4
    },
    analyzing: {
      label: 'ANALYZING',
      title: 'Analyzing...',
      text: 'Evaluating possibilities and building optimal agent architecture.',
      runtime: 'Deep analysis',
      progress: 83,
      step: 2
    },
    clarify: {
      label: 'NEEDS CLARIFICATION',
      title: 'Need more info',
      text: 'A precise answer needs one more decision before continuing.',
      runtime: 'Waiting for input',
      progress: 34,
      step: 2
    },
    map: {
      label: 'WORKFLOW MAP',
      title: 'Workflow map',
      text: 'Live agents, memory and execution paths are visible in one command surface.',
      runtime: 'Mapping system',
      progress: 68,
      step: 1
    }
  };

  var currentMode = 'home';
  var tick = 0;
  var botState = null;
  var chatId = getChatId();

  function getChatId() {
    var params = new URLSearchParams(window.location.search);
    var fromQuery = params.get('chat_id') || params.get('user_id');
    if (fromQuery) return fromQuery;

    var tg = window.Telegram && window.Telegram.WebApp;
    if (tg && tg.initDataUnsafe && tg.initDataUnsafe.user && tg.initDataUnsafe.user.id) {
      return String(tg.initDataUnsafe.user.id);
    }
    return '';
  }

  function setupTelegram() {
    var tg = window.Telegram && window.Telegram.WebApp;
    if (!tg) return;
    try {
      tg.ready();
      tg.expand();
      tg.setHeaderColor('#050818');
      tg.setBackgroundColor('#020614');
    } catch (error) {
      // Telegram may be unavailable in a local browser.
    }
  }

  function createNodes() {
    var points = [
      [26, 23], [40, 18], [58, 16], [72, 24], [83, 35],
      [20, 45], [33, 57], [66, 55], [78, 67], [48, 72],
      [25, 79], [62, 82], [73, 15], [16, 34], [86, 52]
    ];
    nodeCloud.innerHTML = points.map(function (point, index) {
      return '<span class="node" style="left:' + point[0] + '%;top:' + point[1] + '%;animation-delay:' + (index * 0.17) + 's"></span>';
    }).join('');
  }

  function syncMotion(mode) {
    if (!heroMotion) return;
    var src = motionAssets[mode] || motionAssets.home;
    if (heroMotion.dataset.src !== src) {
      heroMotion.dataset.src = src;
      heroMotion.src = src;
      heroMotion.load();
    }
    if (document.hidden) return;
    shell.dataset.motion = 'video';
    var playAttempt = heroMotion.play();
    if (playAttempt && typeof playAttempt.catch === 'function') {
      playAttempt.catch(function () {
        shell.dataset.motion = 'still';
      });
    }
  }

  function resumeMotion() {
    if (document.hidden) return;
    syncMotion(currentMode);
  }

  function setMode(mode) {
    if (!modes[mode]) mode = 'home';
    currentMode = mode;
    var config = modes[mode];
    shell.dataset.mode = mode;
    modeLabel.textContent = config.label;
    commandTitle.textContent = config.title;
    commandText.textContent = config.text;
    runtimeStatus.textContent = config.runtime;
    runtimeValue.textContent = config.progress + '%';
    shell.style.setProperty('--progress', config.progress + '%');
    heroImage.style.opacity = '0.2';
    window.setTimeout(function () {
      heroImage.src = assets[mode] || assets.home;
      heroImage.style.opacity = '';
    }, 140);
    updateSteps(config.step);
    updateCaps(mode);
    syncMotion(mode);
  }

  function updateCaps(mode) {
    Array.prototype.forEach.call(document.querySelectorAll('.cap'), function (button) {
      button.classList.toggle('active', button.dataset.mode === mode);
    });
  }

  function updateSteps(activeIndex) {
    steps.forEach(function (button, index) {
      button.classList.toggle('done', index < activeIndex);
      button.classList.toggle('active', index === activeIndex);
    });
  }

  function renderBinary() {
    var rows = [];
    for (var i = 0; i < 8; i += 1) {
      var seed = tick + i * 7;
      var a = (seed % 2) ? '10101' : '01001';
      var b = ((seed + 3) % 2) ? '0110' : '1001';
      var c = ((seed + 5) % 2) ? '110' : '000';
      var pulse = '.'.repeat(3 + ((seed + i) % 8));
      rows.push('<div>' + a + ' ' + b + ' ' + c + '<em>' + pulse + '</em></div>');
    }
    binaryStream.innerHTML = rows.join('');
  }

  function numberValue(value, fallback) {
    var parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : fallback;
  }

  function updateLiveData(data) {
    if (!data || !data.ok) return;
    botState = data;
    var stats = data.stats || {};
    var profile = data.profile || {};
    var activeAgents = data.top_agents || [];
    var recent = data.recent || [];
    var load = numberValue(stats.load, 76);
    var nodes = numberValue(stats.nodes, 48);
    var connections = numberValue(stats.connections, 231);
    var success = numberValue(stats.success_rate, 98.7);
    var confidence = numberValue(stats.confidence, 93);
    var processes = numberValue(stats.processes, 24);
    var throughput = stats.throughput || '1.2k/s';

    document.getElementById('processCount').textContent = String(processes);
    document.getElementById('loadValue').textContent = load + '%';
    document.getElementById('nodeCount').textContent = String(nodes);
    document.getElementById('connectionCount').textContent = String(connections);
    document.getElementById('successRate').textContent = success + '%';
    document.getElementById('throughput').textContent = throughput;
    document.getElementById('metricNodes').textContent = String(nodes);
    document.getElementById('metricConnections').textContent = String(connections);
    document.getElementById('metricConsistency').textContent = success + '%';
    document.getElementById('metricConfidence').textContent = confidence + '%';

    var displayName = profile.display_name || profile.telegram_first_name || 'Operator';
    var bestAgent = activeAgents[0] && activeAgents[0].name ? activeAgents[0].name : 'Customer Concierge';
    var lastTask = recent[0] && recent[0].task ? recent[0].task : 'No recent task yet';
    document.getElementById('answerTitle').textContent = 'Answer Summary';
    document.getElementById('answerBody').textContent = displayName + ', ' + bestAgent + ' is the current lead agent. Last task: ' + lastTask;
  }

  async function fetchState() {
    if (!chatId) {
      document.getElementById('answerBody').textContent = 'Open from Telegram or add ?chat_id=YOUR_ID to see personal memory.';
      return;
    }
    try {
      var response = await fetch('/app/api/state?chat_id=' + encodeURIComponent(chatId), { cache: 'no-store' });
      var data = await response.json();
      updateLiveData(data);
    } catch (error) {
      document.getElementById('answerBody').textContent = 'Local state is unavailable. The interface stays ready.';
    }
  }

  function animateRuntime() {
    tick += 1;
    renderBinary();
    var config = modes[currentMode] || modes.home;
    var wave = Math.round(Math.sin(tick / 2.2) * 4);
    var value = Math.max(8, Math.min(100, config.progress + wave));
    runtimeValue.textContent = value + '%';
    shell.style.setProperty('--progress', value + '%');
  }

  function setComposerStatus(message, kind) {
    if (!composerStatus) return;
    composerStatus.textContent = message;
    composerStatus.classList.remove('ok', 'error');
    if (kind) composerStatus.classList.add(kind);
  }

  async function submitRequest(event) {
    if (event) event.preventDefault();
    if (!requestInput) return;
    var text = requestInput.value.trim();
    if (!text) {
      setComposerStatus('כתוב בקשה לפני שליחה.', 'error');
      requestInput.focus();
      return;
    }
    if (!chatId) {
      setComposerStatus('פתח את הממשק דרך טלגרם או הוסף chat_id לכתובת.', 'error');
      return;
    }
    var button = requestComposer && requestComposer.querySelector('.send-request');
    if (button) button.disabled = true;
    setComposerStatus('שולח את הבקשה אל הבוט...', '');
    try {
      var response = await fetch('/app/api/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, text: text })
      });
      var data = await response.json();
      if (!response.ok || !data.ok) {
        throw new Error(data.error || 'request_failed');
      }
      requestInput.value = '';
      setMode('running');
      setComposerStatus('נשלח. התשובה תחזור אליך בטלגרם.', 'ok');
    } catch (error) {
      setComposerStatus('לא הצלחתי לשלוח מכאן. אפשר לשלוח את אותה בקשה ישירות בצאט.', 'error');
    } finally {
      if (button) button.disabled = false;
    }
  }

  function bindEvents() {
    Array.prototype.forEach.call(document.querySelectorAll('[data-mode]'), function (button) {
      button.addEventListener('click', function () {
        setMode(button.dataset.mode);
      });
    });

    Array.prototype.forEach.call(document.querySelectorAll('[data-step]'), function (button) {
      button.addEventListener('click', function () {
        var index = Number(button.dataset.step || 0);
        updateSteps(index);
        setMode(['home', 'map', 'analyzing', 'running', 'answer'][index] || 'home');
      });
    });

    if (requestComposer) requestComposer.addEventListener('submit', submitRequest);

    var cycleButton = document.querySelector('[data-action="cycle"]');
    if (cycleButton) {
      cycleButton.addEventListener('click', function () {
        var keys = Object.keys(modes);
        var next = keys[(keys.indexOf(currentMode) + 1) % keys.length];
        setMode(next);
      });
    }
  }

  document.addEventListener('visibilitychange', resumeMotion);
  setupTelegram();
  createNodes();
  bindEvents();
  setMode('home');
  renderBinary();
  fetchState();
  window.setInterval(animateRuntime, 900);
  window.setInterval(fetchState, 15000);
})();
