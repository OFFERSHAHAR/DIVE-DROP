  function updateSteps(activeIndex) {
    steps.forEach(function (button, index) {
      button.classList.toggle('done', index < activeIndex);
      button.classList.toggle('active', index === activeIndex);
    });
  }

  function renderBinary() {
    var rows = [];
    for (var i = 0; i < 8; i += 1) {
      var seed = tick + i * 7;
      var a = (seed % 2) ? '10101' : '01001';
      var b = ((seed + 3) % 2) ? '0110' : '1001';
      var c = ((seed + 5) % 2) ? '110' : '000';
      var pulse = '.'.repeat(3 + ((seed + i) % 8));
      rows.push('<div>' + a + ' ' + b + ' ' + c + '<em>' + pulse + '</em></div>');
    }
    binaryStream.innerHTML = rows.join('');
  }

  function numberValue(value, fallback) {
    var parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : fallback;
  }

  function normalizeText(value) {
    return String(value || '').replace(/\s+/g, ' ').trim();
  }

  function getSpeechRecognitionCtor() {
    return window.SpeechRecognition || window.webkitSpeechRecognition || null;
  }

  function setVoiceState(state) {
    if (state) {
      shell.dataset.voice = state;
    } else {
      delete shell.dataset.voice;
    }
  }

  function cleanSpeechText(value) {
    return String(value || '')
      .replace(/<[^>]+>/g, ' ')
      .replace(/```[\s\S]*?```/g, ' קוד נוצר ומופיע בחלונית התשובה. ')
      .replace(/[{}<>#*_~|]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim()
      .slice(0, 900);
  }

  function speakText(value) {
    var text = cleanSpeechText(value);
    if (!text || !('speechSynthesis' in window)) return;
    try {
      window.speechSynthesis.cancel();
      var utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = 'he-IL';
      utterance.rate = 0.98;
      utterance.pitch = 1.02;
      utterance.onstart = function () {
        setVoiceState('speaking');
        setComposerStatus('מקריא את התשובה...', 'ok');
      };
      utterance.onend = function () {
        setVoiceState('');
      };
      utterance.onerror = function () {
        setVoiceState('');
      };
      window.speechSynthesis.speak(utterance);
    } catch (error) {
      setVoiceState('');
    }
  }

  function answerItemTime(item) {
    var parsed = Date.parse((item && (item.timestamp || item.delivered_at)) || '');
    return Number.isFinite(parsed) ? parsed : 0;
  }

  function isAnswerItem(item) {
    if (!item || item.event === 'progress') return false;
    if (item.agent === 'pending_created_agent') return false;
    return normalizeText(item.result).length > 0;
  }

  function latestAnswerItem(data) {
    var inbox = data && Array.isArray(data.inbox) ? data.inbox : [];
    var answers = inbox.filter(isAnswerItem);
    var wantedTask = normalizeText(pendingRequestText);
    if (wantedTask) {
      var current = answers.find(function (item) {
        var task = normalizeText(item.task);
        var itemTime = answerItemTime(item);
        return task === wantedTask || task.indexOf(wantedTask) !== -1 || (itemTime && requestStartedAt && itemTime >= requestStartedAt - 2000);
      });
      if (current) return current;
    }
    return answers[0] || null;
  }

  function clearPendingRequest() {
    pendingRequestText = '';
    requestStartedAt = 0;
    if (fastPollTimer) {
      window.clearInterval(fastPollTimer);
      fastPollTimer = null;
    }
  }

  function startFastPolling() {
    if (fastPollTimer) window.clearInterval(fastPollTimer);
    var stopAt = Date.now() + 90000;
    fetchState();
    fastPollTimer = window.setInterval(function () {
      fetchState();
      if (Date.now() > stopAt) {
        window.clearInterval(fastPollTimer);
        fastPollTimer = null;
      }
    }, 2500);
  }

  function maybeSpeakLatestAnswer(data, item) {
    if (!voiceAnswerPending || !item) return;
    var itemTask = normalizeText(item.task);
    var wantedTask = normalizeText(voiceLastRequestText);
    if (wantedTask && itemTask && itemTask !== wantedTask) return;

    var itemTime = Date.parse(item.timestamp || item.delivered_at || '');
    if (voiceStartedAt && Number.isFinite(itemTime) && itemTime < voiceStartedAt - 2000) return;

    var answerId = String(item.id || item.timestamp || item.delivered_at || item.result || '');
    if (!answerId || answerId === lastSpokenAnswerId) return;
    lastSpokenAnswerId = answerId;
    voiceAnswerPending = false;
    setMode('answer', { animate: true });
    speakText(item.result);
  }

  function stopVoiceInput() {
    if (recognition && isListening) {
      try {
        recognition.stop();
      } catch (error) {
        // The recognition engine may already be stopped.
      }
    }
    isListening = false;
    setVoiceState('');
  }

  function startVoiceInput() {
    if (!confirmedDisplayName(botState && botState.profile)) {
      setLoginVisible(true);
      setComposerStatus('הזן שם כדי לפתוח אינטראקציה קולית.', 'error');
      return;
    }

    var Recognition = getSpeechRecognitionCtor();
    if (!Recognition) {
      setComposerStatus('המכשיר לא מאפשר זיהוי קול כאן. אפשר להשתמש בהכתבה של המקלדת.', 'error');
      setMode('listening', { animate: true });
      return;
    }

    if (isListening) {
      stopVoiceInput();
      setComposerStatus('האזנה נעצרה.', '');
      return;
    }

    recognition = new Recognition();
    recognition.lang = 'he-IL';
    recognition.interimResults = true;
    recognition.continuous = false;
    recognition.maxAlternatives = 1;

    var finalTranscript = '';

    recognition.onstart = function () {
      isListening = true;
      setVoiceState('listening');
      setMode('listening', { animate: true });
      setComposerStatus('מקשיב עכשיו...', 'ok');
    };

    recognition.onresult = function (event) {
      var interim = '';
      for (var i = event.resultIndex; i < event.results.length; i += 1) {
        var transcript = event.results[i][0] && event.results[i][0].transcript ? event.results[i][0].transcript : '';
        if (event.results[i].isFinal) {
          finalTranscript += transcript + ' ';
        } else {
          interim += transcript;
        }
      }
      var text = normalizeText(finalTranscript || interim);
      if (text && requestInput) requestInput.value = text;
      if (text) setComposerStatus('קלטתי: ' + text, 'ok');
    };

    recognition.onerror = function (event) {
      isListening = false;
      setVoiceState('');
      var code = event && event.error ? event.error : 'voice_error';
      var message = code === 'not-allowed'
        ? 'צריך לאשר הרשאת מיקרופון כדי לדבר עם הממשק.'
        : 'לא הצלחתי לקלוט קול ברור. נסה שוב.';
      setComposerStatus(message, 'error');
    };

    recognition.onend = function () {
      isListening = false;
      setVoiceState('');
      var text = normalizeText(finalTranscript || (requestInput && requestInput.value));
      if (!text) {
        setComposerStatus('לא קלטתי בקשה. לחץ שוב ודבר אחרי שהמסך עובר להאזנה.', 'error');
        return;
      }
      if (requestInput) requestInput.value = text;
      setComposerStatus('שולח את הבקשה הקולית...', 'ok');
      submitRequest(null, { fromVoice: true });
    };

    try {
      recognition.start();
    } catch (error) {
      isListening = false;
      setVoiceState('');
      setComposerStatus('האזנה כבר פעילה או שהדפדפן חסם את המיקרופון.', 'error');
    }
  }

  function updateLiveData(data) {
    if (!data || !data.ok) return;
    botState = data;
    var stats = data.stats || {};
    var profile = data.profile || {};
    var activeAgents = data.top_agents || [];
    var recent = data.recent || [];
    var load = numberValue(stats.load, 76);
    var nodes = numberValue(stats.nodes, 48);
    var connections = numberValue(stats.connections, 231);
    var success = numberValue(stats.success_rate, 98.7);
    var confidence = numberValue(stats.confidence, 93);
    var processes = numberValue(stats.processes, 24);
    var throughput = stats.throughput || '1.2k/s';

    document.getElementById('processCount').textContent = String(processes);
    document.getElementById('loadValue').textContent = load + '%';
    document.getElementById('nodeCount').textContent = String(nodes);
    document.getElementById('connectionCount').textContent = String(connections);
    document.getElementById('successRate').textContent = success + '%';
    document.getElementById('throughput').textContent = throughput;
    document.getElementById('metricNodes').textContent = String(nodes);
    document.getElementById('metricConnections').textContent = String(connections);
    document.getElementById('metricConsistency').textContent = success + '%';
    document.getElementById('metricConfidence').textContent = confidence + '%';

    var displayName = syncLoginFromProfile(profile) || 'Operator';
    var bestAgent = activeAgents[0] && activeAgents[0].name ? activeAgents[0].name : 'Customer Concierge';
    var lastTask = recent[0] && recent[0].task ? recent[0].task : 'No recent task yet';
    var latestAnswer = latestAnswerItem(data);
    var wantedTask = normalizeText(pendingRequestText);
    var latestTask = latestAnswer ? normalizeText(latestAnswer.task) : '';
    var latestMatchesPending = latestAnswer && wantedTask && (
      latestTask === wantedTask ||
      latestTask.indexOf(wantedTask) !== -1 ||
      (answerItemTime(latestAnswer) && requestStartedAt && answerItemTime(latestAnswer) >= requestStartedAt - 2000)
    );
    var waitingForCurrent = wantedTask && !latestMatchesPending;
    if (waitingForCurrent) {
      document.getElementById('answerTitle').textContent = 'מעבד את הבקשה';
      document.getElementById('answerBody').textContent = 'הבקשה רצה עכשיו מאחורי הקלעים. התשובה תופיע כאן בממשק מיד כשהזרימה תסיים.';
      setMode('running', { animate: true });
      return;
    }
    if (wantedTask && latestAnswer && latestMatchesPending) {
      clearPendingRequest();
      setMode('answer', { animate: true });
    }
    document.getElementById('answerTitle').textContent = latestAnswer ? 'תשובה אחרונה' : 'Answer Summary';
    document.getElementById('answerBody').textContent = latestAnswer && latestAnswer.result
      ? latestAnswer.result
      : displayName + ', ' + bestAgent + ' is the current lead agent. Last task: ' + lastTask;
    maybeSpeakLatestAnswer(data, latestAnswer);
  }

  async function fetchState() {
    if (!chatId) {
      document.getElementById('answerBody').textContent = 'Open from Telegram or add ?chat_id=YOUR_ID to see personal memory.';
      return;
    }
    try {
      var response = await fetch('/app/api/state?chat_id=' + encodeURIComponent(chatId), { cache: 'no-store' });
      var data = await response.json();
      updateLiveData(data);
    } catch (error) {
      document.getElementById('answerBody').textContent = 'Local state is unavailable. The interface stays ready.';
    }
  }

  function shouldAnimateMode(mode) {
    return mode === 'running' || mode === 'listening' || mode === 'answer' || mode === 'analyzing';
  }

  function selectedIntentData() {
    return selectedIntent && intentPrompts[selectedIntent] ? intentPrompts[selectedIntent] : null;
  }

  function setSelectedIntent(intent) {
    selectedIntent = selectedIntent === intent ? '' : intent;
    quickActionButtons.forEach(function (button) {
      var active = button.dataset.intent === selectedIntent;
      button.classList.toggle('is-active', active);
      button.setAttribute('aria-pressed', active ? 'true' : 'false');
    });
    var data = selectedIntentData();
    if (data) {
      setComposerStatus('כוונת פעולה נבחרה: ' + data.label + '. כתוב בקשה ושלח.', 'ok');
    } else {
      setComposerStatus('מצב רגיל. כתוב בקשה ושלח.', '');
    }
  }

  function setComposerStatus(message, kind) {
    if (!composerStatus) return;
    composerStatus.textContent = message;
    composerStatus.classList.remove('ok', 'error');
    if (kind) composerStatus.classList.add(kind);
  }

  async function submitRequest(event, options) {
    if (event) event.preventDefault();
    var fromVoice = Boolean(options && options.fromVoice);
    if (!requestInput) return;
    var text = requestInput.value.trim();
    if (!confirmedDisplayName(botState && botState.profile)) {
      setLoginVisible(true);
      setComposerStatus('הזן שם כדי לפתוח את הזרימה האישית.', 'error');
      return;
    }
    if (!text) {
      setComposerStatus('כתוב בקשה לפני שליחה.', 'error');
      requestInput.focus();
      return;
    }
    if (!chatId) {
      setComposerStatus('פתח את הממשק דרך טלגרם או הוסף chat_id לכתובת.', 'error');
      return;
    }
    var button = requestComposer && requestComposer.querySelector('.send-request');
    pendingRequestText = text;
    requestStartedAt = Date.now();
    if (fromVoice) {
      voiceAnswerPending = true;
      voiceLastRequestText = text;
      voiceStartedAt = requestStartedAt;
    }
    if (button) button.disabled = true;
    setComposerStatus('שולח את הבקשה אל הבוט...', '');
    try {
      var response = await fetch('/app/api/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          chat_id: chatId,
          text: text,
          intent: selectedIntent,
          intent_prompt: selectedIntentData() ? selectedIntentData().prompt : '',
          intent_label: selectedIntentData() ? selectedIntentData().label : ''
        })
      });
      var data = await response.json();
      if (!response.ok || !data.ok) {
        throw new Error(data.error || 'request_failed');
      }
      requestInput.value = '';
      setMode('running', { animate: true });
      setComposerStatus('נשלח. התשובה תופיע כאן בממשק כשהזרימה תסיים.', 'ok');
      startFastPolling();
    } catch (error) {
      if (fromVoice) {
        voiceAnswerPending = false;
      }
      clearPendingRequest();
      setComposerStatus('לא הצלחתי לשלוח מהממשק. אפשר לנסות שוב בעוד רגע.', 'error');
    } finally {
      if (button) button.disabled = false;
    }
  }

  function bindEvents() {
    Array.prototype.forEach.call(document.querySelectorAll('[data-mode]'), function (button) {
      button.addEventListener('click', function () {
        var nextMode = button.dataset.mode;
        if (button.dataset.intent) setSelectedIntent(button.dataset.intent);
        setMode(nextMode, { animate: shouldAnimateMode(nextMode) });
      });
    });

    Array.prototype.forEach.call(document.querySelectorAll('[data-step]'), function (button) {
      button.addEventListener('click', function () {
        var index = Number(button.dataset.step || 0);
        updateSteps(index);
        var nextMode = ['home', 'map', 'analyzing', 'running', 'answer'][index] || 'home';
        setMode(nextMode, { animate: index >= 2 });
      });
    });

    if (requestComposer) requestComposer.addEventListener('submit', submitRequest);
    if (voiceButton) {
      voiceButton.addEventListener('click', function (event) {
        event.preventDefault();
        startVoiceInput();
      });
    }
    if (loginForm) loginForm.addEventListener('submit', submitLogin);

    var cycleButton = document.querySelector('[data-action="cycle"]');
    if (cycleButton) {
      cycleButton.addEventListener('click', function () {
        var keys = Object.keys(modes);
        var next = keys[(keys.indexOf(currentMode) + 1) % keys.length];
        setMode(next, { animate: false });
      });
    }
  }

  document.addEventListener('visibilitychange', resumeMotion);
  setupTelegram();
  setLoginVisible(!getLocalDisplayName());
  createNodes();
  bindEvents();
  setMode('home');
  renderBinary();
  fetchState();
  window.setInterval(fetchState, 15000);
})();
