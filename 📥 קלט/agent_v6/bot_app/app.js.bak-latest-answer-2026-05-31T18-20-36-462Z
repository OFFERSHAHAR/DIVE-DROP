  function storageKey() {
    return 'orcastrator.displayName.' + (chatId || 'local');
  }

  function cleanDisplayName(value) {
    return String(value || '')
      .replace(/[^\u0590-\u05FFa-zA-Z\s'-]/g, ' ')
      .replace(/\s+/g, ' ')
      .trim()
      .slice(0, 40);
  }

  function getTelegramDisplayName() {
    var tg = window.Telegram && window.Telegram.WebApp;
    var user = tg && tg.initDataUnsafe && tg.initDataUnsafe.user;
    if (!user) return '';
    return cleanDisplayName([user.first_name, user.last_name].filter(Boolean).join(' '));
  }

  function getLocalDisplayName() {
    try {
      return cleanDisplayName(window.localStorage.getItem(storageKey()) || '');
    } catch (error) {
      return '';
    }
  }

  function saveLocalDisplayName(name) {
    try {
      window.localStorage.setItem(storageKey(), cleanDisplayName(name));
    } catch (error) {
      // Private webviews may block local storage.
    }
  }

  function setLoginVisible(visible) {
    if (!loginScreen) return;
    loginScreen.hidden = !visible;
    loginScreen.classList.remove('is-leaving');
    shell.classList.toggle('needs-login', visible);
    document.body.classList.toggle('login-active', visible);
    if (visible && loginName) {
      var fallbackName = getLocalDisplayName() || getTelegramDisplayName();
      if (fallbackName && !loginName.value.trim()) loginName.value = fallbackName;
      window.setTimeout(function () { loginName.focus(); }, 80);
    }
  }

  function preferredDisplayName(profile) {
    profile = profile || {};
    return cleanDisplayName(profile.display_name || getLocalDisplayName() || profile.telegram_first_name || getTelegramDisplayName());
  }

  function confirmedDisplayName(profile) {
    profile = profile || {};
    return cleanDisplayName(profile.display_name || getLocalDisplayName());
  }

  function syncLoginFromProfile(profile) {
    var confirmed = confirmedDisplayName(profile);
    if (confirmed) {
      saveLocalDisplayName(confirmed);
      setLoginVisible(false);
      return confirmed;
    }
    setLoginVisible(true);
    return preferredDisplayName(profile);
  }

  async function submitLogin(event) {
    if (event) event.preventDefault();
    var name = cleanDisplayName(loginName && loginName.value);
    if (!name || name.length < 2) {
      if (loginStatus) loginStatus.textContent = 'כתוב שם ברור כדי להתחיל.';
      if (loginName) loginName.focus();
      return;
    }

    saveLocalDisplayName(name);
    if (loginStatus) loginStatus.textContent = 'שומר את השם ומכין את הזרימה...';

    if (chatId) {
      try {
        var response = await fetch('/profile/' + encodeURIComponent(chatId), {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ display_name: name, awaiting_name: false })
        });
        if (!response.ok) throw new Error('profile_save_failed');
      } catch (error) {
        if (loginStatus) loginStatus.textContent = 'השם נשמר מקומית. כשנפתח דרך טלגרם הוא יישמר גם בפרופיל.';
      }
    }

    if (loginStatus) loginStatus.textContent = 'השם נשמר. פותח את הממשק...';
    if (loginScreen) loginScreen.classList.add('is-leaving');
    window.setTimeout(function () {
      setLoginVisible(false);
      setMode('analyzing', { animate: true });
      fetchState();
      window.setTimeout(function () {
        setMode('home', { animate: false });
        if (requestInput) requestInput.focus();
      }, 2200);
    }, 950);
  }

  function createNodes() {
    var points = [
      [26, 23], [40, 18], [58, 16], [72, 24], [83, 35],
      [20, 45], [33, 57], [66, 55], [78, 67], [48, 72],
      [25, 79], [62, 82], [73, 15], [16, 34], [86, 52]
    ];
    nodeCloud.innerHTML = points.map(function (point, index) {
      return '<span class="node" style="left:' + point[0] + '%;top:' + point[1] + '%;animation-delay:' + (index * 0.17) + 's"></span>';
    }).join('');
  }

  function clearActionTimers() {
    actionTimers.forEach(function (timer) {
      window.clearTimeout(timer);
    });
    actionTimers = [];
  }

  function stopMotion() {
    if (!heroMotion) return;
    try {
      heroMotion.pause();
      heroMotion.currentTime = 0;
    } catch (error) {
      // Some mobile webviews do not allow seeking before metadata is ready.
    }
    shell.dataset.motion = 'still';
  }

  function syncMotion(mode, playOnce) {
    if (!heroMotion) return;
    var src = motionAssets[mode] || motionAssets.home;
    if (heroMotion.dataset.src !== src) {
      heroMotion.dataset.src = src;
      heroMotion.src = src;
      heroMotion.load();
    }
    heroMotion.loop = false;
    if (!playOnce || document.hidden) {
      stopMotion();
      return;
    }
    shell.dataset.motion = 'video';
    try {
      heroMotion.currentTime = 0;
    } catch (error) {
      // Metadata might not be available yet.
    }
    var playAttempt = heroMotion.play();
    if (playAttempt && typeof playAttempt.catch === 'function') {
      playAttempt.catch(function () {
        shell.dataset.motion = 'still';
      });
    }
  }

  function resumeMotion() {
    if (document.hidden) stopMotion();
  }

  function runActionSequence(mode) {
    clearActionTimers();
    if (animationTimer) window.clearTimeout(animationTimer);
    shell.classList.remove('is-animating');
    void shell.offsetWidth;
    shell.classList.add('is-animating');
    shell.dataset.actionState = mode;
    syncMotion(mode, true);

    var sequence = {
      running: [
        { delay: 0, step: 0, progress: 22, runtime: 'קולט בקשה' },
        { delay: 450, step: 1, progress: 42, runtime: 'קורא זיכרון אישי' },
        { delay: 900, step: 2, progress: 64, runtime: 'בוחר מסלול' },
        { delay: 1350, step: 3, progress: 84, runtime: 'מבצע פעולה' },
        { delay: 1850, step: 4, progress: 96, runtime: 'מכין תוצר' }
      ],
      listening: [
        { delay: 0, step: 0, progress: 24, runtime: 'פותח מיקרופון' },
