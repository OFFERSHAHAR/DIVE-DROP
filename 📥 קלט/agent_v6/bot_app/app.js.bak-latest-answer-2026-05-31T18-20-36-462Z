    updateSteps(config.step);
    updateCaps(mode);
    syncMotion(mode, false);
    if (options && options.animate) {
      runActionSequence(mode);
    }
  }

  function updateCaps(mode) {
    Array.prototype.forEach.call(document.querySelectorAll('.cap'), function (button) {
      button.classList.toggle('active', button.dataset.mode === mode);
