<!doctype html>
<html lang="he">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <title>The Orcastrator</title>
  <link rel="stylesheet" href="/app/styles.css?v=hero-framing-20260531-1845">
  <script src="https://telegram.org/js/telegram-web-app.js"></script>
</head>
<body>
  <div class="ambient ambient-a"></div>
  <div class="ambient ambient-b"></div>

  <main class="phone-shell" id="appShell" data-mode="home">
    <div class="screen-glow"></div>

    <section class="login-screen" id="loginScreen" aria-label="כניסה לממשק" hidden>
      <img class="login-art" src="/app/assets/orcastrator_login.jpg" alt="">
      <div class="login-shade"></div>
      <form class="login-form" id="loginForm" autocomplete="on">
        <div class="login-kicker">Telegram Mini App</div>
        <h1>שלום, איך לקרוא לך?</h1>
        <p>השם נשמר בזיכרון האישי שלך בלבד ומשמש להצגת השיחה והמשימות שלך.</p>
        <label class="login-name-field">
          <span>שם משתמש</span>
          <input id="loginName" name="name" type="text" maxlength="40" autocomplete="name" inputmode="text" placeholder="השם שלך">
        </label>
        <button class="login-submit" id="loginSubmit" type="submit">
          <span>המשך לזרימה</span>
          <b>→</b>
        </button>
        <div class="login-status" id="loginStatus">מאובטח, אישי, ומחובר לזיכרון הפרטי שלך.</div>
      </form>
    </section>

    <header class="topbar">
      <button class="icon-btn" type="button" data-action="cycle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
      <div class="brand">
        <strong>THE ORCASTRATOR</strong>
        <small>AI ASSISTANT</small>
      </div>
      <button class="icon-btn badge-btn" type="button" data-action="mode" data-mode="running" aria-label="Run">
        <b>425</b>
      </button>
    </header>

    <section class="mode-pill" id="modePill">
      <span class="pill-dot"></span>
      <span id="modeLabel">READY TO HELP</span>
      <span class="thinking-dots"><i></i><i></i><i></i></span>
    </section>

    <section class="hero">
      <img id="heroImage" class="hero-image" src="/app/assets/orcastrator_workspace.jpg" alt="Orcastrator interface">
      <video id="heroMotion" class="hero-motion" muted playsinline preload="metadata" poster="/app/assets/orcastrator_flow_poster.jpg">
        <source src="/app/assets/orcastrator_flow.mp4" type="video/mp4">
      </video>
      <div class="motion-sheen"></div>
      <div class="hero-vignette"></div>
      <div class="scanline"></div>
      <div class="energy-column"></div>
      <div class="orbit orbit-one"></div>
      <div class="orbit orbit-two"></div>
      <div class="orbit orbit-three"></div>
      <div class="node-cloud" id="nodeCloud"></div>

      <aside class="glass-panel panel-core">
        <div class="panel-title">AGENT CORE</div>
        <div class="core-row">
          <span class="core-orb"></span>
          <div><small>Status</small><b id="coreStatus">ACTIVE</b></div>
        </div>
        <div class="mini-metrics">
          <span><small>Processes</small><b id="processCount">24</b></span>
          <span><small>Load</small><b id="loadValue">76%</b></span>
        </div>
        <svg class="sparkline" viewBox="0 0 120 32" role="img" aria-label="Core signal">
          <polyline points="0,21 14,16 26,22 38,12 50,18 62,10 74,15 86,19 98,12 112,18 120,14"></polyline>
        </svg>
      </aside>

      <aside class="glass-panel panel-workflow">
        <div class="panel-title">WORKFLOW</div>
        <div class="micro-flow">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="workflow-stats">
          <label>Nodes <b id="nodeCount">48</b></label>
          <label>Connected <b id="connectionCount">231</b></label>
          <label>Success <b id="successRate">98.7%</b></label>
        </div>
      </aside>

      <aside class="glass-panel panel-capabilities">
        <div class="panel-title">CAPABILITIES</div>
        <button class="cap active" type="button" data-mode="analyzing">Reasoning</button>
        <button class="cap" type="button" data-mode="clarify">Planning</button>
        <button class="cap" type="button" data-mode="answer">Memory</button>
        <button class="cap" type="button" data-mode="running">Tools</button>
        <button class="cap" type="button" data-mode="home">Adaptation</button>
      </aside>

      <aside class="glass-panel panel-builder">
        <div class="panel-title">AGENT BUILDER</div>
        <button type="button" data-mode="running">Trigger</button>
        <button type="button" data-mode="analyzing">Retrieve</button>
        <button class="hot" type="button" data-mode="clarify">Reason</button>
        <button class="gold" type="button" data-mode="answer">Execute</button>
        <button class="gold" type="button" data-mode="listening">Respond</button>
      </aside>

      <aside class="glass-panel panel-library">
        <div class="panel-title">AGENT LIBRARY</div>
        <div class="library-grid">
          <button type="button" data-mode="home">Bot</button>
          <button type="button" data-mode="analyzing">Data</button>
          <button type="button" data-mode="answer">Doc</button>
          <button type="button" data-mode="clarify">Mind</button>
          <button type="button" data-mode="running">Code</button>
          <button type="button" data-mode="listening">DB</button>
          <button type="button" data-mode="map">Map</button>
          <button type="button" data-mode="answer">Magic</button>
          <button type="button" data-mode="running">Plus</button>
        </div>
      </aside>

      <aside class="glass-panel panel-stream">
        <div class="panel-title">DATA STREAM</div>
        <div class="binary-stream" id="binaryStream"></div>
        <div class="throughput"><small>Throughput</small><b id="throughput">1.2k/s</b></div>
      </aside>
    </section>

    <section class="command-card" id="commandCard">
      <div class="command-main">
        <div class="command-icon" id="commandIcon"></div>
        <div>
          <h1 id="commandTitle">How can I help today?</h1>
          <p id="commandText">I can build, optimize and manage AI agents for you.</p>
        </div>
        <button class="voice-button" type="button" data-action="mode" data-mode="listening" aria-label="Voice">
          <span></span>
        </button>
      </div>
      <div class="quick-actions">
        <button type="button" data-mode="running" data-intent="create_agent" aria-pressed="false">Create Agent</button>
        <button type="button" data-mode="analyzing" data-intent="improve_workflow" aria-pressed="false">Improve Workflow</button>
        <button type="button" data-mode="map" data-intent="analyze_data" aria-pressed="false">Analyze Data</button>
        <button type="button" data-mode="answer" data-intent="get_insights" aria-pressed="false">Get Insights</button>
      </div>
      <form class="request-composer" id="requestComposer">
        <div class="composer-head">
          <span>בקשה חדשה</span>
        </div>
        <textarea id="requestInput" rows="3" maxlength="1200" placeholder="כתוב כאן מה אתה רוצה שהבוט יבצע..."></textarea>
        <div class="composer-actions">
          <button class="send-request" type="submit">שלח לבוט</button>
        </div>
        <p class="composer-status" id="composerStatus">התשובה תופיע כאן בממשק.</p>
      </form>
      <div class="answer-panel" id="answerPanel">
        <div class="answer-check"></div>
        <div>
          <h2 id="answerTitle">Answer Summary</h2>
          <p id="answerBody">Your agent is ready. Open the flow or run a live check.</p>
        </div>
      </div>
      <div class="clarify-panel" id="clarifyPanel">
        <div class="question-mark">?</div>
        <div>
          <h2>Need More Info</h2>
          <p>What should this agent prioritize when responding to users?</p>
        </div>
        <div class="choice-grid">
          <button type="button" class="selected">Speed & Efficiency</button>
          <button type="button">Accuracy & Detail</button>
          <button type="button">Empathy & Tone</button>
        </div>
      </div>
    </section>

    <section class="workflow-dock">
      <div class="dock-title">
        <strong id="dockTitle">WORKFLOW BUILDER</strong>
        <span id="dockClock">2.4s Avg. Step Time</span>
      </div>
      <div class="steps" id="steps">
        <button type="button" data-step="0"><i></i><b>TRIGGER</b><small>Webhook</small></button>
        <button type="button" data-step="1"><i></i><b>RETRIEVE</b><small>Knowledge</small></button>
        <button type="button" data-step="2"><i></i><b>REASON</b><small>AI Reasoning</small></button>
        <button type="button" data-step="3"><i></i><b>EXECUTE</b><small>Run Actions</small></button>
        <button type="button" data-step="4"><i></i><b>RESPOND</b><small>Send Reply</small></button>
      </div>
      <div class="progress-track">
        <span id="progressBar"></span>
      </div>
      <div class="runtime-line">
        <span id="runtimeStatus">Executing step</span>
        <b id="runtimeValue">76%</b>
      </div>
    </section>

    <section class="live-data">
      <div><small>NODES</small><b id="metricNodes">48</b></div>
      <div><small>CONNECTIONS</small><b id="metricConnections">231</b></div>
      <div><small>CONSISTENCY</small><b id="metricConsistency">98%</b></div>
      <div><small>CONFIDENCE</small><b id="metricConfidence">93%</b></div>
    </section>

    <nav class="bottom-nav">
      <button type="button" data-mode="home" aria-label="Profile"></button>
      <button type="button" data-mode="map" aria-label="Agents"></button>
      <button class="primary" type="button" data-mode="running" aria-label="Orcastrator"></button>
      <button type="button" data-mode="analyzing" aria-label="Analytics"></button>
      <button type="button" data-mode="clarify" aria-label="Settings"></button>
    </nav>
  </main>

  <script src="/app/app.js?v=hero-framing-20260531-1845"></script>
</body>
</html>
