def split_match_words(value):
    text = str(value or "").lower()
    parts = re.split(r"[,|;\s]+", text)
    return [part.strip() for part in parts if len(part.strip()) >= 2]


def html_safe(value):
    return str(value or "").replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")


def model_override_for(agent, task, default_model=DEFAULT_AGENT_MODEL):
    agent = clean_storage_value(agent, 120)
    task_text = str(task or "").lower()
    rules = [rule for rule in load_model_overrides() if rule.get("active", True)]
    best = None
    best_score = -1
    for rule in rules:
        rule_agent = str(rule.get("agent", ""))
        if rule_agent not in ("*", agent):
            continue
        words = split_match_words(rule.get("match", ""))
        hits = [word for word in words if word.lower() in task_text]
        if words and not hits:
            continue
        score = (100 if rule_agent == agent else 20) + (len(hits) * 5) + (1 if not words else 0)
        if score > best_score:
            best = dict(rule, matched_words=hits)
            best_score = score
    if best:
        return {
            "ok": True,
            "model": best.get("model"),
            "default_model": default_model,
            "override_applied": True,
            "agent": agent,
            "task_preview": clean_preview(task, 220),
            "rule": best,
            "why": "נמצא override פעיל לסוכן ולמילות המשימה."
        }
    return {
        "ok": True,
        "model": default_model,
        "default_model": default_model,
        "override_applied": False,
        "agent": agent,
        "task_preview": clean_preview(task, 220),
        "rule": None,
        "why": "לא נמצא override מתאים, לכן נבחר מודל ברירת המחדל."
    }


