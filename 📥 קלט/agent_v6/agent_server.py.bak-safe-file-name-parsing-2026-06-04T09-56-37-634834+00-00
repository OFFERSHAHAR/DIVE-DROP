def build_safe_write_plan(chat_id, user_name, task):
    if not valid_chat_id(chat_id):
        raise ValueError("Invalid chat_id")
    if not file_write_owner_allowed(chat_id):
        raise ValueError("File writing is owner-only.")
    root = file_write_root()
    task_text = str(task or "")
    requested_path = extract_requested_write_path(task_text)
    code = extract_code_block(task_text)

    if requested_path:
        target_path = ensure_under_file_write_root(requested_path)
        if os.path.splitext(target_path)[1]:
            folder_path = os.path.dirname(target_path)
            file_name = os.path.basename(target_path)
        else:
            folder_path = target_path
            file_name = "login.html" if re.search(r"html|login|כניסה|התחברות", task_text, re.I) else "output.txt"
    else:
        folder_name = extract_quoted_after(task_text, ["בשם", "תיקיה בשם", "תיקייה בשם", "folder named"]) or "orcastrator_task"
        folder_name = safe_file_component(folder_name, "orcastrator_task")
        folder_path = ensure_under_file_write_root(os.path.join(root, folder_name))
        if re.search(r"login|html|כניסה|התחברות", task_text, re.I):
            file_name = "login.html"
        else:
            file_name = "output.txt"
    file_name = safe_write_filename(file_name)
    target_path = ensure_under_file_write_root(os.path.join(folder_path, file_name))
    ext = os.path.splitext(file_name)[1].lower()
    if not code:
        code = default_html_content() if ext == ".html" else clean_storage_value(task_text, 3000, keep_newlines=True)
    raw = code.encode("utf-8")
    if len(raw) > MAX_WRITE_BYTES:
        raise ValueError("Generated content is too large for safe write.")
    if os.path.exists(target_path):
        raise ValueError("Target file already exists. Choose a new file name to avoid overwriting.")
    pending_id = uuid.uuid4().hex[:12]
    plan = {
        "id": pending_id,
        "chat_id": str(chat_id),
        "user_name": clean_storage_value(user_name, 80),
        "task": clean_storage_value(task_text, 1200, keep_newlines=True),
        "root": root,
        "folder_path": folder_path,
        "target_path": target_path,
        "file_name": file_name,
        "bytes": len(raw),
        "content": code,
        "created_at": utc_now(),
        "expires_at": int(time.time()) + 900,
    }
    pending = file_write_pending_all()
    pending[str(chat_id)] = plan
    save_file_write_pending(pending)
    return plan


