def decode_uploaded_text(raw):
    for encoding in ("utf-8-sig", "utf-8", "cp1255", "latin-1"):
        try:
            return raw.decode(encoding)
        except UnicodeDecodeError:
            continue
    return raw.decode("utf-8", errors="replace")

def clean_file_context_text(value):
