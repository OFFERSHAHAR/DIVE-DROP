def clean_preview(value, max_len=220):
    value = str(value or "").replace("\\r", " ").replace("\\n", " ").strip()
    value = re.sub(r"[\\u4E00-\\u9FFF\\u3400-\\u4DBF\\u3000-\\u303F\\uFF00-\\uFFEF\\u00C0-\\u024F]", "", value)
    value = re.sub(r"\\s+", " ", value)
    return value[:max_len]

def clean_storage_value(value, max_len=4000, keep_newlines=False):
    value = str(value or "")
    value = FOREIGN_SCRIPT_RE.sub("", value)
    value = re.sub(r"\[out\]", "", value, flags=re.IGNORECASE)
    value = BAD_WORD_RE.sub("", value)
    if keep_newlines:
        value = value.replace("\r\n", "\n").replace("\r", "\n")
        value = re.sub(r"[ \t]+", " ", value)
        value = re.sub(r"\n{4,}", "\n\n\n", value)
    else:
        value = re.sub(r"\s+", " ", value)
    return value.strip()[:max_len]

def clean_memory_entry(entry):
    if not isinstance(entry, dict):
        return entry
    cleaned = dict(entry)
    cleaned["user_name"] = clean_storage_value(cleaned.get("user_name", ""), 80)
    cleaned["task"] = clean_storage_value(cleaned.get("task", ""), 1000)
    cleaned["agent"] = clean_storage_value(cleaned.get("agent", "unknown"), 120) or "unknown"
    cleaned["result"] = clean_storage_value(cleaned.get("result", ""), 4000, keep_newlines=True)
    cleaned["decision_reason"] = clean_storage_value(cleaned.get("decision_reason", ""), 1000)
    return cleaned

def agent_usage_rows(chat_id, limit=50):
    memory = load_json(user_memory_file(chat_id), [])
    rows = []
    for entry in reversed(memory):
        task = clean_preview(entry.get("task", ""), 260)
        agent = clean_preview(entry.get("agent", "unknown"), 80) or "unknown"
        if not task:
            continue
        rows.append({
            "chat_id": str(chat_id),
            "user_name": clean_preview(entry.get("user_name", ""), 80),
            "task": task,
            "agent": agent,
            "score": entry.get("score", None),
            "timestamp": entry.get("timestamp", ""),
            "decision_reason": clean_preview(entry.get("decision_reason", ""), 260),
            "result_preview": clean_preview(entry.get("result", ""), 260)
        })
        if len(rows) >= limit:
            break
    return rows

def all_agent_usage_rows(limit_per_user=50):
    ensure_dir()
    rows = []
    for filename in os.listdir(DATA_DIR):
        if not filename.startswith("memory_") or filename == "memory_global.json":
            continue
        chat_id = filename.replace("memory_", "").replace(".json", "")
        if not valid_chat_id(chat_id):
            continue
        profile = get_profile_data(chat_id)
        for row in agent_usage_rows(chat_id, limit_per_user):
            row["display_name"] = profile.get("display_name", "")
            rows.append(row)
    return sorted(rows, key=lambda row: row.get("timestamp", ""), reverse=True)

def enrich_agent(existing, data):
    score = data.get("score", None)
    if score is not None:
        try:
            score = float(score)
        except (TypeError, ValueError):
            score = None

    if score is not None:
        old_count = int(existing.get("score_count", 0) or 0)
        old_avg = float(existing.get("score_avg", existing.get("score", 0)) or 0)
        new_count = old_count + 1
        existing["score_avg"] = round(((old_avg * old_count) + score) / new_count, 2)
        existing["score_count"] = new_count
        existing["best_score"] = max(float(existing.get("best_score", score) or score), score)
        existing["last_score"] = score

    for key, value in data.items():
        if key not in {"score", "score_avg", "score_count", "best_score", "created_at"}:
            existing[key] = value

    existing["uses"] = int(existing.get("uses", 0) or 0) + (1 if score is not None else 0)
    existing["updated_at"] = utc_now()
    if score is not None:
        existing["last_used"] = existing["updated_at"]
    existing.setdefault("status", "active")
    return existing

