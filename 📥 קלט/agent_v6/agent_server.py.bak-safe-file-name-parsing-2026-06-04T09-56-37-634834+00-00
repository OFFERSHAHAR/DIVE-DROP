def safe_upload_filename(filename):
    base = os.path.basename(str(filename or "uploaded.txt")).strip()
    base = re.sub(r"[^A-Za-z0-9._ -]+", "_", base).strip(" .")
    if not base:
        base = "uploaded.txt"
    name, ext = os.path.splitext(base)
    ext = ext.lower()
