        str(entry.get("timestamp", "")),
        str(entry.get("agent", "")),
        str(entry.get("task", ""))[:120],
        str(entry.get("event", "answer"))
    ])
    return hashlib.sha1(raw.encode("utf-8", errors="ignore")).hexdigest()[:16]

