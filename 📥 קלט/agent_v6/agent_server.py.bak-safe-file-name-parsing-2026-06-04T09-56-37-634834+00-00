LOCAL_PATH_MAX_BYTES = 512 * 1024
LOCAL_DIR_MAX_ENTRIES = 80
LOCAL_PATH_BLOCKED_EXACT = {
    os.path.normcase(os.path.abspath(path))
    for path in ("C:\\", r"C:\Users", r"C:\Users\GamingPC")
}
LOCAL_PATH_BLOCKED_ROOTS = tuple(
    os.path.normcase(os.path.abspath(path))
    for path in (
        r"C:\Windows",
        r"C:\Program Files",
        r"C:\Program Files (x86)",
        r"C:\Users\GamingPC\AppData",
        r"C:\Users\GamingPC\.ssh",
    )
)
WINDOWS_PATH_START_RE = re.compile(r"(?i)(?:[a-z]:\\|\\\\[^\\/\s]+\\[^\\/\s]+\\)")


def local_path_owner_allowed(chat_id):
    return str(chat_id or "").strip() == str(ADMIN_CHAT_ID)


def clean_path_candidate(value):
    candidate = str(value or "").replace("\r", " ").replace("\n", " ").strip()
    candidate = candidate.strip("`\"'<>")
    return candidate.rstrip(" .,;:!?)]}\"'")


def resolve_existing_local_path(candidate):
    current = clean_path_candidate(candidate)
    if not current:
        return ""

    variants = []
    for sep in ('"', "'", "`"):
        if sep in current:
            variants.append(current.split(sep, 1)[0])
    variants.append(current)

    seen = set()
    for variant in variants:
        probe = clean_path_candidate(variant)
        for _ in range(80):
            if not probe or probe in seen:
                break
            seen.add(probe)
            norm = os.path.abspath(os.path.normpath(probe))
            if os.path.exists(norm):
                return norm
            if " " not in probe and "\t" not in probe:
                break
            probe = probe.rsplit(None, 1)[0].rstrip()
    return ""


def extract_local_path(text):
    raw = str(text or "")
    candidates = []

    quoted_re = re.compile(r"([\"'`])((?:[A-Za-z]:\\|\\\\)[\s\S]{1,900}?)\1")
    candidates.extend(match.group(2) for match in quoted_re.finditer(raw))

    for line in raw.replace("\r", "\n").split("\n"):
        for match in WINDOWS_PATH_START_RE.finditer(line):
            tail = line[match.start():].strip()
            tail = tail.split("```", 1)[0].strip()
            if tail:
                candidates.append(tail)

    for candidate in candidates:
        path = resolve_existing_local_path(candidate)
        if path:
            return path
    return ""


def local_path_allowed(path):
    absolute = os.path.normcase(os.path.abspath(path))
    if absolute in LOCAL_PATH_BLOCKED_EXACT:
        return False, "Path is too broad. Provide a specific file or a specific project folder."
    for blocked in LOCAL_PATH_BLOCKED_ROOTS:
        if absolute == blocked or absolute.startswith(blocked + os.sep):
            return False, "This system path is blocked for safety."
    return True, ""


def build_local_file_context(path):
    _, ext = os.path.splitext(path)
    if ext.lower() not in ALLOWED_UPLOAD_EXTENSIONS:
        raise ValueError("Unsupported file type for read-only local path.")
    with open(path, "rb") as f:
        raw = f.read(LOCAL_PATH_MAX_BYTES + 1)
    truncated = len(raw) > LOCAL_PATH_MAX_BYTES
    if truncated:
        raw = raw[:LOCAL_PATH_MAX_BYTES]
    content = clean_file_context_text(decode_uploaded_text(raw))
    stat = os.stat(path)
    header = [
        "READ_ONLY_LOCAL_PATH_CONTEXT",
        "MODE: file",
        "PATH: " + path,
        "SIZE_BYTES: " + str(stat.st_size),
        "TRUNCATED: " + ("true" if truncated else "false"),
        "INSTRUCTION: Use this as read-only evidence. Do not claim you changed files.",
        "----- BEGIN LOCAL FILE -----",
    ]
    return "\n".join(header) + "\n" + content + "\n----- END LOCAL FILE -----"


def build_local_dir_context(path):
    rows = []
    with os.scandir(path) as iterator:
        for entry in iterator:
            try:
                stat = entry.stat()
                kind = "dir" if entry.is_dir() else "file"
                size = "" if entry.is_dir() else str(stat.st_size)
                modified = datetime.fromtimestamp(stat.st_mtime).isoformat(timespec="seconds")
                rows.append((0 if kind == "dir" else 1, entry.name.lower(), f"- [{kind}] {entry.name} | {size} bytes | {modified}"))
            except OSError:
                rows.append((2, entry.name.lower(), f"- [unknown] {entry.name} | unreadable"))
    rows.sort()
    visible = [row[2] for row in rows[:LOCAL_DIR_MAX_ENTRIES]]
    if len(rows) > LOCAL_DIR_MAX_ENTRIES:
        visible.append(f"... {len(rows) - LOCAL_DIR_MAX_ENTRIES} more entries not shown")
    header = [
        "READ_ONLY_LOCAL_PATH_CONTEXT",
        "MODE: directory",
        "PATH: " + path,
        "ENTRY_COUNT: " + str(len(rows)),
        "LISTING_DEPTH: 1",
        "INSTRUCTION: This is a directory listing only. Do not claim nested file contents were read.",
        "----- BEGIN LOCAL DIRECTORY -----",
    ]
    return "\n".join(header) + "\n" + "\n".join(visible) + "\n----- END LOCAL DIRECTORY -----"


def read_only_local_path_context(chat_id, text):
    if not local_path_owner_allowed(chat_id):
        return {"ok": False, "has_path": False, "error": "Local path reading is owner-only."}
    path = extract_local_path(text)
    if not path:
        return {"ok": False, "has_path": False, "error": "No exact local path found."}
    allowed, reason = local_path_allowed(path)
    if not allowed:
        return {"ok": False, "has_path": True, "path": path, "error": reason}
    if os.path.isfile(path):
        context = build_local_file_context(path)
        mode = "file"
    elif os.path.isdir(path):
        context = build_local_dir_context(path)
        mode = "directory"
    else:
        return {"ok": False, "has_path": True, "path": path, "error": "Path is neither a file nor a directory."}
    return {
        "ok": True,
        "has_path": True,
        "path": path,
        "mode": mode,
        "context": context,
    }

