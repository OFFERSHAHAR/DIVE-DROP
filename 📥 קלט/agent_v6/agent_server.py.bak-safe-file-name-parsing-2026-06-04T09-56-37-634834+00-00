def confirm_safe_write(chat_id):
    if not valid_chat_id(chat_id):
        raise ValueError("Invalid chat_id")
    if not file_write_owner_allowed(chat_id):
        raise ValueError("File writing is owner-only.")
    pending = file_write_pending_all()
    plan = pending.get(str(chat_id))
    if not plan:
        return {"ok": False, "message_html": "אין פעולת כתיבה שממתינה לאישור."}
    if int(plan.get("expires_at", 0) or 0) < int(time.time()):
        pending.pop(str(chat_id), None)
        save_file_write_pending(pending)
        return {"ok": False, "message_html": "פעולת הכתיבה פגה. שלח את הבקשה מחדש."}
    target_path = ensure_under_file_write_root(plan.get("target_path", ""))
    folder_path = ensure_under_file_write_root(plan.get("folder_path", ""))
    if os.path.exists(target_path):
        pending.pop(str(chat_id), None)
        save_file_write_pending(pending)
        return {"ok": False, "message_html": "הקובץ כבר קיים ולכן לא כתבתי עליו. בחר שם חדש."}
    content = str(plan.get("content", ""))
    raw = content.encode("utf-8")
    if len(raw) > MAX_WRITE_BYTES:
        return {"ok": False, "message_html": "התוכן גדול מדי ולכן לא נכתב."}
    os.makedirs(folder_path, exist_ok=True)
    with open(target_path, "x", encoding="utf-8", newline="\n") as f:
        f.write(content)
    pending.pop(str(chat_id), None)
    save_file_write_pending(pending)
    entry = {
        "chat_id": str(chat_id),
        "user_name": plan.get("user_name", ""),
        "task": plan.get("task", ""),
        "agent": "safe_file_writer",
        "result": "נוצר קובץ בפועל:\n" + target_path,
        "decision_reason": "כתיבה בוצעה רק לאחר אישור משתמש ובתוך ORCASTRATOR_OUTPUT.",
        "timestamp": utc_now(),
    }
    memory = load_json(user_memory_file(chat_id), [])
    if isinstance(memory, list):
        memory.append(entry)
        save_json(user_memory_file(chat_id), memory[-200:])
    try:
        if mini_session_active(chat_id):
            append_mini_inbox(chat_id, entry, "answer")
    except Exception:
        pass
    file_write_log({"chat_id": str(chat_id), "target_path": target_path, "bytes": len(raw), "task": plan.get("task", "")})
    return {
        "ok": True,
        "target_path": target_path,
        "folder_path": folder_path,
        "message_html": "בוצע. נוצר קובץ בפועל:\n<code>" + html_safe(target_path) + "</code>"
    }


