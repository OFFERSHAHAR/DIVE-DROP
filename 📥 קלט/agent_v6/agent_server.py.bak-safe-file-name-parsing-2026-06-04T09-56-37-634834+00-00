def safe_file_component(value, fallback):
    value = clean_storage_value(value, 120, keep_newlines=False)
    value = value.strip().strip("\"'`<>")
    value = re.sub(r"[\\/:*?\"<>|]+", "_", value)
    value = re.sub(r"\s+", " ", value).strip(" .")
    return value or fallback


def safe_write_filename(value, fallback="output.txt"):
    name = safe_file_component(value, fallback)
    base, ext = os.path.splitext(name)
    if not ext:
        ext = os.path.splitext(fallback)[1] or ".txt"
        name = (base or "output") + ext
    ext = ext.lower()
    if ext not in ALLOWED_WRITE_EXTENSIONS:
        raise ValueError("File extension is not allowed for safe write.")
    return safe_file_component(os.path.splitext(name)[0], "output") + ext


def ensure_under_file_write_root(path):
    root = file_write_root()
    absolute = os.path.abspath(os.path.normpath(path))
    root_norm = os.path.normcase(root)
    absolute_norm = os.path.normcase(absolute)
    if absolute_norm != root_norm and not absolute_norm.startswith(root_norm + os.sep):
        raise ValueError("Write path blocked. Use only the safe ORCASTRATOR_OUTPUT folder.")
    return absolute


def extract_quoted_after(text, words):
    raw = str(text or "")
    for word in words:
        pattern = re.compile(re.escape(word) + r"\s*[\"'“”`]+([^\"'“”`]+)[\"'“”`]+", re.IGNORECASE)
        match = pattern.search(raw)
        if match:
            return match.group(1).strip()
    quoted = re.findall(r"[\"'“”`]([^\"'“”`]{2,120})[\"'“”`]", raw)
    if quoted:
        return quoted[0].strip()
    return ""


def extract_requested_write_path(text):
    raw = str(text or "")
    match = re.search(r"(?i)([a-z]:\\[^\n\r\"'`<>]+)", raw)
    if not match:
        return ""
    candidate = clean_path_candidate(match.group(1))
    if not candidate:
        return ""
    return os.path.abspath(os.path.normpath(candidate))


def extract_code_block(text):
    raw = str(text or "")
    match = re.search(r"```(?:[A-Za-z0-9_+#.-]+)?\s*\n?([\s\S]*?)```", raw)
    return match.group(1).strip() if match else ""


