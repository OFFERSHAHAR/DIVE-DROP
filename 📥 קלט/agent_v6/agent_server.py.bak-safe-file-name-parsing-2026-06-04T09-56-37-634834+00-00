def model_status_message(payload):
    lines = ["<b>מצב מודלים</b>", ""]
    for item in payload.get("models", []):
        opts = []
        if item.get("temperature") is not None:
            opts.append("temp " + str(item.get("temperature")))
        if item.get("num_ctx"):
            opts.append("ctx " + str(item.get("num_ctx")))
        if item.get("num_predict"):
            opts.append("predict " + str(item.get("num_predict")))
        suffix = " - " + ", ".join(opts) if opts else ""
        lines.append("• " + html_safe(item.get("role", item.get("node", ""))) + ": <code>" + html_safe(item.get("model", "unknown")) + "</code>" + html_safe(suffix))
    lines.extend(["", "<b>הגדרות מודל ייעודיות</b>"])
    overrides = payload.get("overrides", [])
    if overrides:
        for rule in overrides:
            match = rule.get("match") or "כל משימה"
            lines.append("• <code>" + html_safe(rule.get("agent", "")) + "</code> → <code>" + html_safe(rule.get("model", "")) + "</code> | " + html_safe(match))
    else:
        lines.append("אין הגדרות ייעודיות פעילות.")
    available = payload.get("available_models", [])
    if available:
        lines.extend(["", "<b>מודלים זמינים מקומית</b>", ", ".join("<code>" + name + "</code>" for name in available[:12])])
    lines.extend(["", "פקודות:", "<code>/model set agent_name model_name keywords</code>", "<code>/model clear agent_name</code>", "", "השינוי חל רק על הסוכן והמשימה שהוגדרו. שאר הזרימה נשארת כמו שהיא."])
    return "\n".join(lines)


def model_command_payload(chat_id, text):
    if str(chat_id or "").strip() != str(ADMIN_CHAT_ID):
        return {"ok": False, "message_html": "פקודת /model זמינה רק למנהל הבוט."}
    raw = str(text or "").strip()
    parts = raw.split()
    if not parts:
        return {"ok": False, "message_html": "חסרה פקודת model."}
    action = (parts[1].lower() if len(parts) > 1 else "status")
    status_words = {"status", "list", "show", "overrides", "מצב", "הצג", "רשימה"}
    set_words = {"set", "add", "קבע", "הוסף", "שנה"}
    clear_words = {"clear", "remove", "delete", "נקה", "מחק", "בטל"}

    if action in status_words:
        payload = model_status_payload()
        payload["message_html"] = model_status_message(payload)
        return payload

    if action in set_words:
        if len(parts) < 4:
            return {"ok": False, "message_html": "שימוש: <code>/model set agent_name model_name keywords</code>"}
        agent = clean_storage_value(parts[2], 120)
        model = clean_storage_value(parts[3], 120)
        if not re.match(r"^[A-Za-z0-9_.:/+-]{2,120}$", model):
            return {"ok": False, "message_html": "שם מודל לא תקין."}
        match = " ".join(parts[4:]).strip()
        match = re.sub(r"^(when|for|עבור|למשימות|במשימות)\s+", "", match, flags=re.IGNORECASE).strip()
        rules = load_model_overrides()
        now = utc_now()
        updated = False
        for rule in rules:
            if rule.get("agent") == agent and rule.get("match", "") == match:
                rule["model"] = model
                rule["active"] = True
                rule["updated_at"] = now
                updated = True
                break
        if not updated:
            rules.append({
                "id": uuid.uuid4().hex[:12],
                "agent": agent,
                "model": model,
                "match": match,
                "active": True,
                "created_at": now,
                "updated_at": now,
            })
        save_model_overrides(rules)
        match_label = match or "כל משימה של הסוכן"
        return {
            "ok": True,
            "message_html": "נשמרה הגדרת מודל ייעודית.\nסוכן: <code>" + html_safe(agent) + "</code>\nמודל: <code>" + html_safe(model) + "</code>\nמשימות: " + html_safe(match_label)
        }

    if action in clear_words:
        if len(parts) < 3:
            return {"ok": False, "message_html": "שימוש: <code>/model clear agent_name</code>"}
        agent = clean_storage_value(parts[2], 120)
        rules = load_model_overrides()
        removed = 0
        for rule in rules:
            if rule.get("agent") == agent:
                rule["active"] = False
                rule["updated_at"] = utc_now()
                removed += 1
        save_model_overrides(rules)
        return {"ok": True, "message_html": "נוקו הגדרות המודל לסוכן <code>" + html_safe(agent) + "</code>.\nכמות: " + str(removed)}

    payload = model_status_payload()
    payload["message_html"] = model_status_message(payload)
    return payload

