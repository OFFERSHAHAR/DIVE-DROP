"""
Self-Evolving Agent - Registry & Memory Server v6
Multi-user: personal memory per chat_id + shared global memory
Free/local stack: Flask + n8n + Ollama + Telegram.
"""

from flask import Flask, request, Response, send_file
from flask_cors import CORS
import json, os, re
from datetime import datetime

app = Flask(__name__)
CORS(app)

DATA_DIR      = os.path.join(os.path.dirname(__file__), "agent_data")
REGISTRY_FILE = os.path.join(DATA_DIR, "registry.json")
GLOBAL_MEMORY = os.path.join(DATA_DIR, "memory_global.json")
ADMIN_CHAT_ID = os.environ.get("AGENT_ADMIN_CHAT_ID", "7799410671")
GLOBAL_MEMORY_ENABLED = os.environ.get("AGENT_ENABLE_GLOBAL_MEMORY", "0") == "1"
CHAT_ID_RE = re.compile(r"^-?\d{1,32}$")

def ensure_dir():
    os.makedirs(DATA_DIR, exist_ok=True)

def valid_chat_id(chat_id):
    return bool(CHAT_ID_RE.match(str(chat_id or "")))

def user_memory_file(chat_id):
    if not valid_chat_id(chat_id):
        raise ValueError("Invalid chat_id")
    return os.path.join(DATA_DIR, f"memory_{chat_id}.json")

def require_admin():
    supplied = request.headers.get("X-Admin-Chat-Id") or request.args.get("admin_id") or ""
    return str(supplied) == str(ADMIN_CHAT_ID)

def load_json(path, default):
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return default

def save_json(path, data):
    ensure_dir()
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)

def R(data, status=200):
    return Response(json.dumps(data, ensure_ascii=False),
                    status=status, mimetype="application/json")

def utc_now():
    return datetime.utcnow().isoformat()

def enrich_agent(existing, data):
    score = data.get("score", None)
    if score is not None:
        try:
            score = float(score)
        except (TypeError, ValueError):
            score = None

    if score is not None:
        old_count = int(existing.get("score_count", 0) or 0)
        old_avg = float(existing.get("score_avg", existing.get("score", 0)) or 0)
        new_count = old_count + 1
        existing["score_avg"] = round(((old_avg * old_count) + score) / new_count, 2)
        existing["score_count"] = new_count
        existing["best_score"] = max(float(existing.get("best_score", score) or score), score)
        existing["last_score"] = score

    for key, value in data.items():
        if key not in {"score", "score_avg", "score_count", "best_score", "created_at"}:
            existing[key] = value

    existing["uses"] = int(existing.get("uses", 0) or 0) + (1 if score is not None else 0)
    existing["updated_at"] = utc_now()
    if score is not None:
        existing["last_used"] = existing["updated_at"]
    existing.setdefault("status", "active")
    return existing

# Registry

@app.route("/agents", methods=["GET"])
def get_agents():
    agents = load_json(REGISTRY_FILE, [])
    return R(sorted(agents, key=lambda a: (float(a.get("score_avg", a.get("score", 0)) or 0), int(a.get("uses", 0) or 0)), reverse=True))

@app.route("/agents", methods=["POST"])
def add_agent():
    data = request.get_json(force=True)
    if not data or "name" not in data:
        return R({"error": "Missing name"}, 400)
    agents = load_json(REGISTRY_FILE, [])
    ex = next((a for a in agents if a.get("name") == data["name"]), None)
    if ex:
        enrich_agent(ex, data)
        agent = ex
    else:
        agent = dict(data)
        agent.setdefault("score_avg", data.get("score", None))
        agent.setdefault("score_count", 1 if data.get("score", None) is not None else 0)
        agent.setdefault("uses", 0)
        agent.setdefault("status", "active")
        agent["created_at"] = utc_now()
        agents.append(agent)
    save_json(REGISTRY_FILE, agents)
    return R({"status": "ok", "agent": agent}, 201)

@app.route("/agents/<name>", methods=["DELETE"])
def delete_agent(name):
    agents = [a for a in load_json(REGISTRY_FILE, []) if a.get("name") != name]
    save_json(REGISTRY_FILE, agents)
    return R({"status": "deleted", "name": name})

# Personal Memory /memory/{chat_id}

@app.route("/memory/<chat_id>", methods=["GET"])
def get_user_memory(chat_id):
    if not valid_chat_id(chat_id):
        return R({"error": "Invalid chat_id"}, 400)
    limit = request.args.get("limit", 50, type=int)
    return R(load_json(user_memory_file(chat_id), [])[-limit:])

@app.route("/memory/<chat_id>", methods=["POST"])
def add_user_memory(chat_id):
    if not valid_chat_id(chat_id):
        return R({"error": "Invalid chat_id"}, 400)
    data = request.get_json(force=True)
    if not data or "task" not in data:
        return R({"error": "Missing task"}, 400)
    memory = load_json(user_memory_file(chat_id), [])
    entry = {
        "chat_id":    str(chat_id),
        "task":       data.get("task", ""),
        "agent":      data.get("agent", "unknown"),
        "result":     data.get("result", ""),
        "score":      data.get("score", None),
        "deductions": data.get("deductions", None),
        "timestamp":  utc_now()
    }
    memory.append(entry)
    if len(memory) > 200:
        memory = memory[-200:]
    save_json(user_memory_file(chat_id), memory)
    return R({"status": "ok", "entry": entry}, 201)

@app.route("/memory/<chat_id>", methods=["DELETE"])
def clear_user_memory(chat_id):
    if not valid_chat_id(chat_id):
        return R({"error": "Invalid chat_id"}, 400)
    save_json(user_memory_file(chat_id), [])
    return R({"status": "cleared", "chat_id": chat_id})

# Global Memory is off by default to avoid mixing private user data.

@app.route("/memory/global", methods=["GET"])
def get_global_memory():
    if not GLOBAL_MEMORY_ENABLED:
        return R({"error": "Global memory disabled", "hint": "Set AGENT_ENABLE_GLOBAL_MEMORY=1 to enable shared memory."}, 403)
    limit = request.args.get("limit", 50, type=int)
    return R(load_json(GLOBAL_MEMORY, [])[-limit:])

@app.route("/memory/global", methods=["POST"])
def add_global_memory():
    if not GLOBAL_MEMORY_ENABLED:
        return R({"error": "Global memory disabled", "hint": "Use /memory/{chat_id} for personal memory."}, 403)
    data = request.get_json(force=True)
    if not data or "task" not in data:
        return R({"error": "Missing task"}, 400)
    memory = load_json(GLOBAL_MEMORY, [])
    entry = {
        "task":      data.get("task", ""),
        "agent":     data.get("agent", "unknown"),
        "result":    data.get("result", ""),
        "score":     data.get("score", None),
        "timestamp": utc_now()
    }
    memory.append(entry)
    if len(memory) > 1000:
        memory = memory[-1000:]
    save_json(GLOBAL_MEMORY, memory)
    return R({"status": "ok", "entry": entry}, 201)

# Status, users and owner/admin exports

@app.route("/", methods=["GET"])
def status():
    ensure_dir()
    agents = load_json(REGISTRY_FILE, [])
    global_mem = load_json(GLOBAL_MEMORY, [])
    user_files = [f for f in os.listdir(DATA_DIR)
                  if f.startswith("memory_") and f != "memory_global.json"]
    return R({
        "status": "running",
        "agents": len(agents),
        "global_memory": len(global_mem),
        "global_memory_enabled": GLOBAL_MEMORY_ENABLED,
        "users": len(user_files),
        "admin_configured": bool(ADMIN_CHAT_ID)
    })

@app.route("/users", methods=["GET"])
def list_users():
    ensure_dir()
    user_files = [f for f in os.listdir(DATA_DIR)
                  if f.startswith("memory_") and f != "memory_global.json"]
    users = []
    for f in user_files:
        chat_id = f.replace("memory_", "").replace(".json", "")
        if not valid_chat_id(chat_id):
            continue
        mem = load_json(os.path.join(DATA_DIR, f), [])
        users.append({"chat_id": chat_id, "messages": len(mem)})
    return R(sorted(users, key=lambda x: -x["messages"]))

@app.route("/admin/memory/<chat_id>", methods=["GET"])
def admin_user_memory(chat_id):
    if not require_admin():
        return R({"error": "Admin only"}, 403)
    if not valid_chat_id(chat_id):
        return R({"error": "Invalid chat_id"}, 400)
    limit = request.args.get("limit", 200, type=int)
    return R(load_json(user_memory_file(chat_id), [])[-limit:])

@app.route("/admin/export/<chat_id>", methods=["GET"])
def admin_export_memory(chat_id):
    if not require_admin():
        return R({"error": "Admin only"}, 403)
    if not valid_chat_id(chat_id):
        return R({"error": "Invalid chat_id"}, 400)
    path = user_memory_file(chat_id)
    if not os.path.exists(path):
        save_json(path, [])
    return send_file(path, as_attachment=True, download_name=f"memory_{chat_id}.json", mimetype="application/json")

if __name__ == "__main__":
    ensure_dir()
    print("=" * 50)
    print("  Agent Server v6 (Multi-User, Free/Local)")
    print("  http://127.0.0.1:5000")
    print("  GET/POST /memory/{chat_id}  personal")
    print("  GET      /users             user list")
    print("  GET      /admin/memory/{chat_id}?admin_id=YOUR_ID")
    print("  GET      /admin/export/{chat_id}?admin_id=YOUR_ID")
    print("=" * 50)
    app.run(host="127.0.0.1", port=5000, debug=False)
