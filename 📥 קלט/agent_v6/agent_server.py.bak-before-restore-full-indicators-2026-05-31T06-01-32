"""
Self-Evolving Agent - Registry & Memory Server v6
Multi-user: personal memory per chat_id + shared global memory
"""

from flask import Flask, request, Response
from flask_cors import CORS
import json, os
from datetime import datetime

app = Flask(__name__)
CORS(app)

DATA_DIR      = os.path.join(os.path.dirname(__file__), "agent_data")
REGISTRY_FILE = os.path.join(DATA_DIR, "registry.json")
GLOBAL_MEMORY = os.path.join(DATA_DIR, "memory_global.json")

def ensure_dir(): os.makedirs(DATA_DIR, exist_ok=True)

def user_memory_file(chat_id):
    return os.path.join(DATA_DIR, f"memory_{chat_id}.json")

def load_json(path, default):
    try:
        with open(path, "r", encoding="utf-8") as f: return json.load(f)
    except: return default

def save_json(path, data):
    ensure_dir()
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)

def R(data, status=200):
    return Response(json.dumps(data, ensure_ascii=False),
                    status=status, mimetype="application/json")

# ── Registry ──────────────────────────────────────────────

@app.route("/agents", methods=["GET"])
def get_agents():
    return R(load_json(REGISTRY_FILE, []))

@app.route("/agents", methods=["POST"])
def add_agent():
    data = request.get_json(force=True)
    if not data or "name" not in data:
        return R({"error": "Missing name"}, 400)
    agents = load_json(REGISTRY_FILE, [])
    ex = next((a for a in agents if a["name"] == data["name"]), None)
    if ex:
        ex.update(data)
        ex["updated_at"] = datetime.utcnow().isoformat()
    else:
        data["created_at"] = datetime.utcnow().isoformat()
        agents.append(data)
    save_json(REGISTRY_FILE, agents)
    return R({"status": "ok", "agent": data}, 201)

@app.route("/agents/<name>", methods=["DELETE"])
def delete_agent(name):
    agents = [a for a in load_json(REGISTRY_FILE, []) if a["name"] != name]
    save_json(REGISTRY_FILE, agents)
    return R({"status": "deleted", "name": name})

# ── Personal Memory /memory/{chat_id} ─────────────────────

@app.route("/memory/<chat_id>", methods=["GET"])
def get_user_memory(chat_id):
    limit = request.args.get("limit", 50, type=int)
    return R(load_json(user_memory_file(chat_id), [])[-limit:])

@app.route("/memory/<chat_id>", methods=["POST"])
def add_user_memory(chat_id):
    data = request.get_json(force=True)
    if not data or "task" not in data:
        return R({"error": "Missing task"}, 400)
    memory = load_json(user_memory_file(chat_id), [])
    entry = {
        "task":       data.get("task", ""),
        "agent":      data.get("agent", "unknown"),
        "result":     data.get("result", ""),
        "score":      data.get("score", None),
        "deductions": data.get("deductions", None),
        "timestamp":  datetime.utcnow().isoformat()
    }
    memory.append(entry)
    if len(memory) > 200: memory = memory[-200:]
    save_json(user_memory_file(chat_id), memory)
    return R({"status": "ok", "entry": entry}, 201)

@app.route("/memory/<chat_id>", methods=["DELETE"])
def clear_user_memory(chat_id):
    save_json(user_memory_file(chat_id), [])
    return R({"status": "cleared", "chat_id": chat_id})

# ── Global Memory /memory/global ──────────────────────────

@app.route("/memory/global", methods=["GET"])
def get_global_memory():
    limit = request.args.get("limit", 50, type=int)
    return R(load_json(GLOBAL_MEMORY, [])[-limit:])

@app.route("/memory/global", methods=["POST"])
def add_global_memory():
    data = request.get_json(force=True)
    if not data or "task" not in data:
        return R({"error": "Missing task"}, 400)
    memory = load_json(GLOBAL_MEMORY, [])
    entry = {
        "task":      data.get("task", ""),
        "agent":     data.get("agent", "unknown"),
        "result":    data.get("result", ""),
        "score":     data.get("score", None),
        "timestamp": datetime.utcnow().isoformat()
    }
    memory.append(entry)
    if len(memory) > 1000: memory = memory[-1000:]
    save_json(GLOBAL_MEMORY, memory)
    return R({"status": "ok", "entry": entry}, 201)

# ── Status & Users ────────────────────────────────────────

@app.route("/", methods=["GET"])
def status():
    agents = load_json(REGISTRY_FILE, [])
    global_mem = load_json(GLOBAL_MEMORY, [])
    user_files = [f for f in os.listdir(DATA_DIR)
                  if f.startswith("memory_") and f != "memory_global.json"]
    return R({
        "status":        "running",
        "agents":        len(agents),
        "global_memory": len(global_mem),
        "users":         len(user_files)
    })

@app.route("/users", methods=["GET"])
def list_users():
    user_files = [f for f in os.listdir(DATA_DIR)
                  if f.startswith("memory_") and f != "memory_global.json"]
    users = []
    for f in user_files:
        chat_id = f.replace("memory_", "").replace(".json", "")
        mem = load_json(os.path.join(DATA_DIR, f), [])
        users.append({"chat_id": chat_id, "messages": len(mem)})
    return R(sorted(users, key=lambda x: -x["messages"]))

if __name__ == "__main__":
    ensure_dir()
    print("=" * 50)
    print("  עבד - Agent Server v6 (Multi-User)")
    print("  http://127.0.0.1:5000")
    print("  GET/POST /memory/{chat_id}  personal")
    print("  GET/POST /memory/global     shared")
    print("  GET      /users             all users")
    print("=" * 50)
    app.run(host="127.0.0.1", port=5000, debug=False)
