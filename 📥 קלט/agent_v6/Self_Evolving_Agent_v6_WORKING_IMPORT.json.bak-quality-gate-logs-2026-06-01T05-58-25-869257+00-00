    {
      "parameters": {
        "jsCode": "const data = $('Prepare Data').first().json;\nconst msg = String(data.userMessage || '').trim();\nfunction extractUserGoal(value) {\n  const text = String(value || '').trim();\n  const asciiMatch = text.match(/USER_REQUEST:\\s*([\\s\\S]*?)(?:\\nBUTTON_HINT:|\\nINTENT_LABEL:|\\nRULE:|$)/);\n  if (asciiMatch && asciiMatch[1] && asciiMatch[1].trim()) return asciiMatch[1].trim();\n  const hebrewMatch = text.match(/Ч‘Ч§Ч©ЧӘ Ч”ЧһЧ©ЧӘЧһЧ©:\\s*([\\s\\S]*?)(?:\\nЧ”Ч Ч—ЧҷЧҷЧӘ ЧӣЧӨЧӘЧ•ЧЁ ЧһЧ©Ч ЧҷЧӘ:|\\nЧӣЧ•Ч•Ч ЧӘ ЧһЧһЧ©Ч§:|\\nЧ—Ч•Ч§ Ч‘ЧҷЧҰЧ•Чў:|$)/);\n  if (hebrewMatch && hebrewMatch[1] && hebrewMatch[1].trim()) return hebrewMatch[1].trim();\n  const legacyMatch = text.match(/(?:Ч‘Ч§Ч©ЧӘ Ч”ЧһЧ©ЧӘЧһЧ©|ЧівҖҳЧіВ§ЧіВ©ЧіГ— ЧівҖқЧіВһЧіВ©ЧіГ—ЧіВһЧіВ©):\\s*([\\s\\S]*)$/);\n  if (legacyMatch && legacyMatch[1] && legacyMatch[1].trim()) return legacyMatch[1].trim();\n  return text;\n}\nconst userGoalRaw = extractUserGoal(msg);\nconst localContextMatch = msg.match(/READ_ONLY_LOCAL_PATH_CONTEXT[\\s\\S]*?(?:----- END LOCAL FILE -----|----- END LOCAL DIRECTORY -----)/i);\nconst localContextBlock = localContextMatch ? localContextMatch[0] : '';\nconst userGoal = localContextBlock && !userGoalRaw.includes(localContextBlock)\n  ? (userGoalRaw + '\\n\\n' + localContextBlock).trim()\n  : userGoalRaw;\nconst lower = msg.toLowerCase();\nconst userLower = userGoal.toLowerCase();\nconst agents = Array.isArray(data.agents) ? data.agents : [];\nconst hasAttachedFile = /----- BEGIN ATTACHED FILE -----|FILE_CONTEXT|READ_ONLY_LOCAL_PATH_CONTEXT|----- BEGIN LOCAL FILE -----|----- BEGIN LOCAL DIRECTORY -----|Ч§Ч•Ч‘ЧҘ ЧһЧҰЧ•ЧЁЧЈ ЧңЧ§ЧЁЧҷЧҗЧ” Ч‘ЧңЧ‘Ч“/i.test(msg);\n\nconst hasAny = (words) => words.some(w => lower.includes(w.toLowerCase()));\nconst hasAnyUser = (words) => words.some(w => userLower.includes(w.toLowerCase()));\nconst exactCasual = ['Ч”Чҷ', 'Ч”ЧҷЧҷ', 'Ч”ЧҷЧҷЧҷ', 'Ч”ЧңЧ•', 'Ч©ЧңЧ•Чқ', 'Ч‘Ч•Ч§ЧЁ ЧҳЧ•Ч‘', 'ЧўЧЁЧ‘ ЧҳЧ•Ч‘', 'ЧңЧҷЧңЧ” ЧҳЧ•Ч‘', 'ЧһЧ” Ч Ч©ЧһЧў', 'ЧһЧ” Ч§Ч•ЧЁЧ”', 'ЧһЧ” Ч”ЧһЧҰЧ‘', 'ЧӘЧ•Ч“Ч”', 'ЧЎЧ‘Ч‘Ч”', 'ЧҗЧ—ЧңЧ”'];\nconst scoreDetailWords = ['ЧӨЧҷЧЁЧ•Чҳ ЧҰЧҷЧ•Чҹ', 'ЧӨЧҷЧЁЧ•Чҳ ЧўЧң Ч”ЧҰЧҷЧ•Чҹ', 'Ч©ЧңЧ— ЧӨЧҷЧЁЧ•Чҳ ЧўЧң Ч”ЧҰЧҷЧ•Чҹ', 'ЧӨЧЁЧҳЧҷЧқ ЧўЧң Ч”ЧҰЧҷЧ•Чҹ', 'ЧңЧһЧ” Ч”ЧҰЧҷЧ•Чҹ', 'Ч”ЧЎЧ‘ЧЁ ЧўЧң Ч”ЧҰЧҷЧ•Чҹ'];\nconst chitchatWords = ['ЧһЧҷ ЧҗЧӘЧ”', 'ЧўЧ–ЧЁЧ”', 'ЧһЧ” ЧҗЧӘЧ” ЧҷЧ•Ч“Чў ЧңЧўЧ©Ч•ЧӘ', 'ЧһЧ” ЧҗЧӘЧ” ЧҷЧӣЧ•Чң ЧңЧўЧ©Ч•ЧӘ', 'ЧһЧ” Ч”Ч•Чҗ ЧҷЧ•Ч“Чў ЧңЧўЧ©Ч•ЧӘ', 'ЧһЧ” Ч”Ч‘Ч•Чҳ ЧҷЧ•Ч“Чў ЧңЧўЧ©Ч•ЧӘ'];\nconst codeWords = ['code', 'python', 'javascript', 'js', 'sql', 'json', 'html', 'css', 'react', 'n8n', 'workflow', 'bug', 'debug', 'Ч“ЧҷЧ‘ЧҗЧ’', 'Ч§Ч•Ч“', 'Ч§Ч•Ч‘ЧҘ', 'ЧӨЧ•Ч Ч§ЧҰЧҷЧ”', 'ЧЎЧ§ЧЁЧҷЧӨЧҳ', 'Ч©Ч’ЧҷЧҗЧ”', 'Ч•Ч•ЧЁЧ§ЧӨЧңЧ•ЧҗЧ•', 'Ч•Ч•ЧЁЧ§ ЧӨЧңЧ•ЧҗЧ•', 'file_context', 'attached file', 'Ч§Ч•Ч‘ЧҘ ЧһЧҰЧ•ЧЁЧЈ', 'Ч‘ЧҗЧ’', 'ЧӘЧ§Чҹ', 'ЧӘЧҷЧ§Ч•Чҹ'];\nconst n8nWords = ['n8n', 'workflow', 'workflow json', 'n8n workflow', 'Ч•Ч•ЧЁЧ§ЧӨЧңЧ•ЧҗЧ•', 'Ч•Ч•ЧЁЧ§ ЧӨЧңЧ•ЧҗЧ•', 'Ч–ЧЁЧҷЧһЧӘ n8n', 'Ч§Ч•Ч‘ЧҘ json Чң n8n', 'json Чңn8n', 'json Чң n8n'];\nconst createAgentWords = ['ЧҰЧ•ЧЁ ЧңЧҷ ЧЎЧ•ЧӣЧҹ', 'ЧӘЧҷЧҰЧ•ЧЁ ЧңЧҷ ЧЎЧ•ЧӣЧҹ', 'Ч‘Ч Ч” ЧңЧҷ ЧЎЧ•ЧӣЧҹ', 'ЧӘЧ‘Ч Ч” ЧңЧҷ ЧЎЧ•ЧӣЧҹ', 'ЧӘЧӣЧҷЧҹ ЧңЧҷ ЧЎЧ•ЧӣЧҹ', 'ЧҰЧ•ЧЁ ЧЎЧ•ЧӣЧҹ', 'ЧЎЧ•ЧӣЧҹ Ч—Ч“Ч©', 'Ч ЧҰЧҷЧ’ Ч—Ч“Ч©'];\nconst historyWords = ['Ч‘ЧҗЧҷЧ–Ч” ЧЎЧ•ЧӣЧҹ', 'ЧҗЧҷЧ–Ч” ЧЎЧ•ЧӣЧҹ Ч”Ч©ЧӘЧһЧ©', 'ЧҗЧҷЧ–Ч” Ч ЧҰЧҷЧ’ Ч”Ч©ЧӘЧһЧ©', 'ЧЎЧ•ЧӣЧҹ Ч”Ч©ЧӘЧһЧ©ЧӘ', 'Ч ЧҰЧҷЧ’ Ч”Ч©ЧӘЧһЧ©ЧӘ', 'Ч”ЧҷЧЎЧҳЧ•ЧЁЧҷЧҷЧӘ ЧЎЧ•ЧӣЧ ЧҷЧқ', 'Ч©ЧҷЧһЧ•Ч©Чҷ ЧЎЧ•ЧӣЧ ЧҷЧқ', 'Ч–ЧҷЧӣЧЁЧ•Чҹ ЧЎЧ•ЧӣЧ ЧҷЧқ', 'ЧЎЧ•ЧӣЧҹ ЧңЧҗЧҷЧ–Ч• ЧһЧ©ЧҷЧһЧ”', 'Ч ЧҰЧҷЧ’ ЧңЧҗЧҷЧ–Ч• ЧһЧ©ЧҷЧһЧ”'];\nconst routingStopWords = new Set(['Ч”Ч•Чҗ','Ч”ЧҷЧҗ','ЧҗЧ Чҷ','ЧҗЧӘЧ”','ЧҗЧӘЧқ','Ч©ЧңЧҷ','Ч©ЧңЧҡ','Ч©ЧңЧ Ч•','ЧһЧ”','ЧҗЧҷЧҡ','ЧңЧһЧ”','ЧһЧӘЧҷ','ЧҗЧҷЧӨЧ”','ЧҷЧ•Ч“Чў','ЧҷЧ•Ч“ЧўЧӘ','ЧңЧўЧ©Ч•ЧӘ','ЧҷЧӣЧ•Чң','ЧҷЧӣЧ•ЧңЧ”','ЧҰЧЁЧҷЧҡ','ЧЁЧ•ЧҰЧ”','Ч‘Ч§Ч©Ч”','Ч”Ч‘Ч§Ч©Ч”','ЧӘЧўЧ©Ч”','ЧӘЧӣЧӘЧ•Ч‘','ЧӘЧЎЧ‘ЧҷЧЁ','Ч”ЧҷЧҷЧӘ','ЧһЧһЧңЧҷЧҘ','ЧңЧ”ЧҳЧһЧҷЧў']);\n\nfunction cleanName(value) {\n  let text = String(value || '').trim();\n  const match = text.match(/(?:Ч§Ч•ЧЁЧҗЧҷЧқ ЧңЧҷ|Ч”Ч©Чқ Ч©ЧңЧҷ|ЧҗЧ Чҷ)\\s+([^,.!?\\n]+)$/i);\n  if (match) text = match[1];\n  text = text\n    .replace(/^(Ч§Ч•ЧЁЧҗЧҷЧқ ЧңЧҷ|Ч”Ч©Чқ Ч©ЧңЧҷ|ЧҗЧ Чҷ)\\s+/i, '')\n    .replace(/(?:^|\\s)(ЧӘЧҷЧҰЧ•ЧЁ|ЧҰЧ•ЧЁ|ЧӘЧўЧ©Ч”|Ч‘Ч Ч”|ЧӘЧ‘Ч Ч”|ЧӘЧӣЧҷЧҹ|Ч”ЧӣЧҹ|ЧҰЧЁЧҷЧҡ|ЧЁЧ•ЧҰЧ”|ЧЎЧ•ЧӣЧҹ|Ч ЧҰЧҷЧ’).*$/i, '')\n    .replace(/[^\\u0590-\\u05FFa-zA-Z\\s'-]/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n  if (text.split(/\\s+/).length > 3) return '';\n  return text.slice(0, 40);\n}\n\nlet action = 'chitchat';\nlet agent_name = null;\nlet direct_reply = null;\nlet userName = data.userName || '';\nlet requestMessage = userGoal;\nlet selectionReason = '';\nconst preferredN8nAgent = agents.find(a => a.name === 'n8n_agent') || agents.find(a => a.name === 'agent_create_n8n_task');\n\nif (!data.userName && !data.awaitingName) {\n  action = 'ask_name';\n  direct_reply = 'Ч‘ЧЁЧ•Чҡ Ч”Ч‘Чҗ. ЧҗЧҷЧҡ Ч§Ч•ЧЁЧҗЧҷЧқ ЧңЧҡ?\\n\\nЧҗЧ—ЧЁЧҷ Ч©ЧӘЧӣЧӘЧ•Ч‘ ЧҗЧӘ Ч”Ч©Чқ Ч©ЧңЧҡ, ЧҗЧ–ЧӣЧ•ЧЁ ЧҗЧ•ЧӘЧ• Ч•ЧҗЧӨЧ Ч” ЧҗЧңЧҷЧҡ Ч‘Ч©Чқ Ч‘Ч©ЧҷЧ—Ч•ЧӘ Ч”Ч‘ЧҗЧ•ЧӘ.';\n} else if ((!data.userName && data.awaitingName) || /^\\s*(Ч§Ч•ЧЁЧҗЧҷЧқ ЧңЧҷ|Ч”Ч©Чқ Ч©ЧңЧҷ|ЧҗЧ Чҷ)\\s+/i.test(msg)) {\n  const extractedName = cleanName(userGoal);\n  const inlineRequest = (() => {\n    const raw = userGoal.replace(/^\\s*(Ч§Ч•ЧЁЧҗЧҷЧқ ЧңЧҷ|Ч”Ч©Чқ Ч©ЧңЧҷ|ЧҗЧ Чҷ)\\s+/i, '').trim();\n    const marker = raw.search(/\\s(ЧҰЧ•ЧЁ|ЧӘЧҷЧҰЧ•ЧЁ|ЧӘЧўЧ©Ч”|Ч‘Ч Ч”|ЧӘЧ‘Ч Ч”|ЧӘЧӣЧҷЧҹ|Ч”ЧӣЧҹ|ЧҰЧЁЧҷЧҡ|ЧЁЧ•ЧҰЧ”)\\s/i);\n    if (marker > 0) return raw.slice(marker).trim();\n    return '';\n  })();\n  if (extractedName && inlineRequest && inlineRequest.split(/\\s+/).filter(Boolean).length >= 3) {\n    action = 'create_agent';\n    userName = extractedName;\n    requestMessage = inlineRequest;\n    direct_reply = null;\n  } else if (extractedName) {\n    action = 'save_name';\n    userName = extractedName;\n    direct_reply = `Ч ЧўЧҷЧқ ЧһЧҗЧ•Ч“, ${userName}.\\n\\nЧһЧўЧӣЧ©ЧҷЧ• ЧҗЧӨЧ Ч” ЧҗЧңЧҷЧҡ Ч‘Ч©Чқ Ч”Ч–Ч”. ЧҗЧқ ЧӣЧӘЧ‘ЧӘ Ч’Чқ Ч‘Ч§Ч©Ч” Ч‘ЧҗЧ•ЧӘЧ” Ч”Ч•Ч“ЧўЧ”, Ч©ЧңЧ— ЧҗЧ•ЧӘЧ” Ч©Ч•Ч‘ Ч‘Ч©Ч•ЧЁЧ” Ч—Ч