<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🐍 Python Fullstack - Complete Learning Platform</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { height: 100%; }
        body { width: 100vw; height: 100vh; overflow: hidden; font-family: 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; display: flex; flex-direction: column; }

        .header {
            flex-shrink: 0;
            height: 60px;
            background: linear-gradient(90deg, #7c3aed 0%, #ec4899 50%, #06b6d4 100%);
            display: flex;
            align-items: center;
            padding: 0 30px;
            justify-content: space-between;
            border-bottom: 2px solid #06b6d4;
        }

        .header-left { display: flex; align-items: center; gap: 20px; }
        .logo { font-size: 1.6em; font-weight: 900; color: white; }
        .mode-switch { display: flex; gap: 8px; }
        .mode-btn { padding: 6px 12px; background: rgba(255,255,255,0.2); border: none; color: white; border-radius: 4px; cursor: pointer; font-weight: 600; font-size: 0.85em; transition: all 0.2s; }
        .mode-btn.active { background: white; color: #7c3aed; }

        .container {
            flex: 1;
            display: grid;
            grid-template-columns: 220px 1fr 300px;
            gap: 0;
            overflow: hidden;
        }

        .left { background: #1e293b; border-right: 2px solid #334155; display: flex; flex-direction: column; overflow: hidden; }
        .left-header { background: linear-gradient(135deg, #7c3aed 0%, #ec4899 100%); color: white; padding: 12px; font-weight: 700; font-size: 0.9em; border-bottom: 2px solid #334155; flex-shrink: 0; }
        .lessons { flex: 1; overflow-y: auto; padding: 8px; }
        .lesson { padding: 10px; margin: 4px 0; background: #0f172a; border: 2px solid #334155; border-radius: 6px; cursor: pointer; transition: all 0.2s; font-size: 0.85em; }
        .lesson:hover { border-color: #7c3aed; }
        .lesson.active { background: linear-gradient(135deg, #7c3aed 0%, #ec4899 100%); color: white; }

        .center { background: #0f172a; border-right: 2px solid #334155; display: flex; flex-direction: column; overflow: hidden; }
        .c-header { background: #1e293b; padding: 15px; border-bottom: 2px solid #334155; flex-shrink: 0; }
        .c-header h2 { font-size: 1.4em; background: linear-gradient(135deg, #7c3aed 0%, #ec4899 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 6px; }
        .c-meta { display: flex; gap: 12px; font-size: 0.8em; color: #bfdbfe; }

        .editor-area { flex: 1; display: grid; grid-template-rows: 1fr 140px; gap: 8px; padding: 12px; overflow: hidden; }
        .code-box, .output-box { background: #020617; border: 2px solid #3b82f6; border-radius: 8px; display: flex; flex-direction: column; overflow: hidden; }
        .box-header { background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); color: white; padding: 8px 12px; font-weight: 700; font-size: 0.85em; flex-shrink: 0; }
        .output-box { border-color: #22c55e; }
        .output-box .box-header { background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); }

        #code { flex: 1; background: #020617; color: #60a5fa; border: none; padding: 12px; font-family: 'Courier New'; font-size: 13px; resize: none; outline: none; line-height: 1.5; }
        #output { flex: 1; color: #22c55e; padding: 10px 12px; font-family: 'Courier New'; font-size: 12px; overflow-y: auto; white-space: pre-wrap; word-break: break-all; }

        .buttons { display: flex; gap: 8px; padding: 12px; background: #1e293b; border-top: 2px solid #334155; flex-shrink: 0; }
        button { padding: 10px 12px; border: none; border-radius: 6px; font-weight: 700; cursor: pointer; color: white; transition: all 0.2s; flex: 1; font-size: 0.85em; }
        .btn-run { background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); }
        .btn-clear { background: #ef4444; }
        .btn-sol { background: #3b82f6; }

        .right { background: #1e293b; border-left: 2px solid #334155; display: flex; flex-direction: column; overflow: hidden; }
        .right-header { background: linear-gradient(135deg, #7c3aed 0%, #ec4899 100%); color: white; padding: 12px; font-weight: 700; font-size: 0.9em; border-bottom: 2px solid #334155; flex-shrink: 0; }
        .right-content { flex: 1; overflow-y: auto; padding: 12px; }
        .section { margin-bottom: 14px; }
        .s-title { color: #60a5fa; font-weight: 700; font-size: 0.85em; margin-bottom: 8px; }
        .task { padding: 6px 10px; background: #0f172a; border-radius: 4px; margin: 4px 0; color: #bfdbfe; font-size: 0.8em; border-right: 2px solid #3b82f6; }
        .expected { background: #020617; padding: 8px; border-radius: 4px; border-left: 2px solid #22c55e; color: #86efac; font-family: 'Courier New'; font-size: 0.8em; }
        .hint { background: rgba(6, 182, 212, 0.1); border: 2px dashed #06b6d4; padding: 8px; border-radius: 4px; color: #a5f3fc; font-size: 0.8em; }

        .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 15px; }
        .stat-box { background: linear-gradient(135deg, rgba(124, 58, 237, 0.2) 0%, rgba(236, 72, 153, 0.2) 100%); border: 2px solid #7c3aed; padding: 15px; border-radius: 8px; text-align: center; }
        .stat-num { font-size: 1.8em; font-weight: 900; color: #60a5fa; }
        .stat-label { font-size: 0.8em; color: #bfdbfe; margin-top: 6px; }

        .progress-bar { background: #0f172a; border: 2px solid #3b82f6; border-radius: 6px; height: 20px; overflow: hidden; margin: 8px 0; }
        .progress-fill { background: linear-gradient(90deg, #7c3aed 0%, #ec4899 100%); height: 100%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 0.75em; }

        .video-card { background: #0f172a; border: 2px solid #334155; padding: 10px; border-radius: 6px; margin: 8px 0; cursor: pointer; transition: all 0.2s; }
        .video-card:hover { border-color: #7c3aed; }
        .video-title { color: #60a5fa; font-weight: 600; font-size: 0.9em; }
        .video-time { font-size: 0.75em; color: #94a3b8; }

        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #0f172a; }
        ::-webkit-scrollbar-thumb { background: #7c3aed; border-radius: 2px; }

        .msg { position: fixed; bottom: 20px; right: 320px; padding: 10px 16px; border-radius: 6px; color: white; font-weight: 700; font-size: 0.9em; display: none; z-index: 999; }
        .msg.show { display: block; animation: pop 0.3s; }
        .msg.ok { background: #22c55e; }
        .msg.err { background: #ef4444; }
        @keyframes pop { from { opacity: 0; transform: scale(0.8); } to { opacity: 1; transform: scale(1); } }

        .hide { display: none !important; }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-left">
            <div class="logo">🐍 Python Fullstack</div>
            <div class="mode-switch">
                <button class="mode-btn active" onclick="setMode('learn')">🎓 Learn</button>
                <button class="mode-btn" onclick="setMode('stats')">📊 Stats</button>
                <button class="mode-btn" onclick="setMode('videos')">🎬 Videos</button>
            </div>
        </div>
        <div style="color: white; font-weight: 700; font-size: 1.1em;" id="headerInfo">📅 Day 1/30</div>
    </div>

    <div class="container">
        <!-- LEFT -->
        <div class="left">
            <div class="left-header">📚 30 Days</div>
            <div class="lessons" id="lessonsList"></div>
        </div>

        <!-- CENTER LEARN MODE -->
        <div class="center" id="learnMode">
            <div class="c-header">
                <h2 id="title">Hello Python!</h2>
                <div class="c-meta">
                    <div>⏱️ 10 min</div>
                    <div id="diff">Easy</div>
                    <div id="status">Not Started</div>
                </div>
            </div>

            <div class="editor-area">
                <div class="code-box">
                    <div class="box-header">💻 Code Editor</div>
                    <textarea id="code" placeholder="Write Python..."></textarea>
                </div>
                <div class="output-box">
                    <div class="box-header">📤 Output</div>
                    <div id="output" style="color: #64748b; font-style: italic;">[ Run your code ]</div>
                </div>
            </div>

            <div class="buttons">
                <button class="btn-run" onclick="run()">▶️ Run</button>
                <button class="btn-clear" onclick="clear()">🗑️ Clear</button>
                <button class="btn-sol" onclick="sol()">💡 Solution</button>
            </div>
        </div>

        <!-- CENTER STATS MODE -->
        <div class="center hide" id="statsMode" style="padding: 20px; overflow-y: auto;">
            <h2 style="color: #60a5fa; margin-bottom: 20px; font-size: 1.8em;">📊 Your Progress</h2>

            <div class="stats-grid">
                <div class="stat-box">
                    <div class="stat-num" id="completedCount">0</div>
                    <div class="stat-label">Completed</div>
                </div>
                <div class="stat-box">
                    <div class="stat-num" id="totalCount">30</div>
                    <div class="stat-label">Total Days</div>
                </div>
            </div>

            <div style="margin-bottom: 20px;">
                <div style="color: #60a5fa; font-weight: 700; margin-bottom: 10px;">Overall Progress</div>
                <div class="progress-bar">
                    <div class="progress-fill" id="overallProgress" style="width: 0%;">0%</div>
                </div>
            </div>

            <div style="margin-bottom: 20px;">
                <div style="color: #60a5fa; font-weight: 700; margin-bottom: 10px;">This Week</div>
                <div class="progress-bar">
                    <div class="progress-fill" id="weekProgress" style="width: 0%; background: linear-gradient(90deg, #06b6d4 0%, #3b82f6 100%);">0%</div>
                </div>
            </div>

            <div style="margin-bottom: 20px;">
                <div style="color: #60a5fa; font-weight: 700; margin-bottom: 10px;">Streak 🔥</div>
                <div style="font-size: 2em; color: #f59e0b; font-weight: 900;" id="streak">0 days</div>
            </div>

            <div>
                <div style="color: #60a5fa; font-weight: 700; margin-bottom: 10px;">Quick Stats</div>
                <div class="task" style="border-right-color: #06b6d4;">⏱️ Total Time: <span id="totalTime">0</span> mins</div>
                <div class="task" style="border-right-color: #06b6d4;">🎯 Avg Time/Day: <span id="avgTime">0</span> mins</div>
                <div class="task" style="border-right-color: #22c55e;">✅ Exercises Done: <span id="doneCount">0</span></div>
            </div>
        </div>

        <!-- CENTER VIDEOS MODE -->
        <div class="center hide" id="videosMode" style="padding: 20px; overflow-y: auto;">
            <h2 style="color: #60a5fa; margin-bottom: 20px; font-size: 1.8em;">🎬 Learning Resources</h2>

            <div style="margin-bottom: 30px;">
                <div style="color: #60a5fa; font-weight: 700; margin-bottom: 12px;">📹 Recommended Videos</div>
                <div class="video-card">
                    <div class="video-title">Python for Beginners</div>
                    <div class="video-time">⏱️ 45 min • YouTube</div>
                </div>
                <div class="video-card">
                    <div class="video-title">Python Basics: Variables & Types</div>
                    <div class="video-time">⏱️ 30 min • Codecademy</div>
                </div>
                <div class="video-card">
                    <div class="video-title">Complete Python Tutorial</div>
                    <div class="video-time">⏱️ 120 min • Real Python</div>
                </div>
                <div class="video-card">
                    <div class="video-title">Python Loops & Control Flow</div>
                    <div class="video-time">⏱️ 35 min • W3Schools</div>
                </div>
            </div>

            <div>
                <div style="color: #60a5fa; font-weight: 700; margin-bottom: 12px;">🔗 Useful Links</div>
                <div class="video-card">
                    <div class="video-title">Python Official Docs</div>
                    <div class="video-time">📖 python.org</div>
                </div>
                <div class="video-card">
                    <div class="video-title">Real Python Tutorials</div>
                    <div class="video-time">📖 realpython.com</div>
                </div>
                <div class="video-card">
                    <div class="video-title">W3Schools Python</div>
                    <div class="video-time">📖 w3schools.com</div>
                </div>
            </div>
        </div>

        <!-- RIGHT -->
        <div class="right">
            <div class="right-header" id="rightHeader">📋 Exercise</div>
            <div class="right-content" id="rightContent">
                <div class="section">
                    <div class="s-title">Tasks:</div>
                    <div id="tasks"></div>
                </div>
                <div class="section">
                    <div class="s-title">Expected:</div>
                    <div class="expected" id="expected"></div>
                </div>
                <div class="section">
                    <div class="s-title">💡 Hint:</div>
                    <div class="hint" id="hint"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="msg" id="msg"></div>

    <script>
        const lessons = [
            { day: 1, title: "Hello Python!", diff: "Easy", tasks: ['✅ Print "Hello, Python!"', '✅ Print your name', '✅ Print one more'], exp: 'Hello, Python!\nYour Name\nI love coding!', hint: 'Use print() for each line', sol: 'print("Hello, Python!")\nprint("Your Name")\nprint("I love coding!")' },
            { day: 2, title: "Variables", diff: "Easy", tasks: ['✅ name = "Alice"', '✅ age = 25', '✅ Print both'], exp: 'Alice\n25', hint: 'A variable stores a value', sol: 'name = "Alice"\nage = 25\nprint(name)\nprint(age)' },
            { day: 3, title: "String Concat", diff: "Easy", tasks: ['✅ first = "Hello"', '✅ last = "Python"', '✅ Join them'], exp: 'HelloPython', hint: 'Use +', sol: 'first = "Hello"\nlast = "Python"\nprint(first + last)' },
            { day: 4, title: "Math Ops", diff: "Easy", tasks: ['✅ Add 10 + 5', '✅ Multiply 6 * 7', '✅ Divide 20 / 4'], exp: '15\n42\n5.0', hint: 'Use +, -, *, /', sol: 'print(10 + 5)\nprint(6 * 7)\nprint(20 / 4)' },
            { day: 5, title: "User Input", diff: "Easy", tasks: ['✅ input() name', '✅ input() age', '✅ Greet'], exp: 'Hello, Alice!', hint: 'Use input()', sol: 'name = input("Name: ")\nprint("Hello, " + name + "!")' },
            ...Array.from({length: 25}, (_, i) => ({ day: i + 6, title: `Day ${i + 6}`, diff: i < 10 ? "Easy" : i < 20 ? "Medium" : "Hard", tasks: ['✅ Task here'], exp: '[output]', hint: 'Think step by step', sol: 'print("Done!")' }))
        ];

        let cur = 1;
        let completed = JSON.parse(localStorage.getItem('pythonDone') || '[]');
        let times = JSON.parse(localStorage.getItem('pythonTimes') || '{}');

        function init() {
            const list = document.getElementById('lessonsList');
            list.innerHTML = lessons.map((d, i) => `<div class="lesson ${i === 0 ? 'active' : ''} ${completed.includes(d.day) ? 'done' : ''}" onclick="load(${d.day})" title="Day ${d.day}">${d.day}</div>`).join('');
            load(1);
            updateStats();
        }

        function load(day) {
            cur = day;
            const d = lessons[day - 1];
            document.getElementById('headerInfo').textContent = `📅 Day ${day}/30`;
            document.getElementById('title').textContent = d.title;
            document.getElementById('diff').textContent = d.diff;
            document.getElementById('status').textContent = completed.includes(day) ? '✅ Done' : '⏳ In Progress';
            document.getElementById('tasks').innerHTML = d.tasks.map(t => `<div class="task">${t}</div>`).join('');
            document.getElementById('expected').textContent = d.exp;
            document.getElementById('hint').textContent = d.hint;
            document.getElementById('code').value = '';
            document.getElementById('output').textContent = '[ Run your code ]';
            document.getElementById('output').style.color = '#64748b';
            document.querySelectorAll('.lesson').forEach((e, i) => e.classList.toggle('active', i === day - 1));
        }

        function run() {
            const code = document.getElementById('code').value;
            if (!code.trim()) { msg('❌ Empty!', 'err'); return; }
            let out = '';
            window.print = (...a) => out += a.join(' ') + '\n';
            try {
                eval(code.replace(/print\(/g, 'window.print('));
                document.getElementById('output').textContent = out.trim() || '(no output)';
                document.getElementById('output').style.color = '#22c55e';
                if (!completed.includes(cur)) {
                    completed.push(cur);
                    localStorage.setItem('pythonDone', JSON.stringify(completed));
                    times[cur] = 10;
                    localStorage.setItem('pythonTimes', JSON.stringify(times));
                    document.querySelectorAll('.lesson')[cur - 1].classList.add('done');
                    updateStats();
                    msg('✅ Completed!', 'ok');
                } else {
                    msg('✅ Success!', 'ok');
                }
            } catch (e) {
                document.getElementById('output').textContent = '❌ ' + e.message;
                document.getElementById('output').style.color = '#ef4444';
                msg('❌ Error!', 'err');
            }
        }

        function clear() {
            document.getElementById('code').value = '';
            document.getElementById('output').textContent = '[ Run your code ]';
            document.getElementById('output').style.color = '#64748b';
        }

        function sol() {
            document.getElementById('code').value = lessons[cur - 1].sol;
            msg('💡 Loaded!', 'ok');
        }

        function msg(text, type) {
            const m = document.getElementById('msg');
            m.textContent = text;
            m.className = 'msg show ' + type;
            setTimeout(() => m.classList.remove('show'), 2500);
        }

        function setMode(m) {
            document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('learnMode').classList.toggle('hide', m !== 'learn');
            document.getElementById('statsMode').classList.toggle('hide', m !== 'stats');
            document.getElementById('videosMode').classList.toggle('hide', m !== 'videos');
            if (m === 'stats') updateStats();
        }

        function updateStats() {
            const pct = Math.round((completed.length / 30) * 100);
            document.getElementById('completedCount').textContent = completed.length;
            document.getElementById('overallProgress').textContent = pct + '%';
            document.getElementById('overallProgress').style.width = pct + '%';
            document.getElementById('weekProgress').style.width = Math.min(completed.length * 3, 100) + '%';
            document.getElementById('streak').textContent = completed.length + ' days';
            document.getElementById('totalTime').textContent = completed.length * 10;
            document.getElementById('avgTime').textContent = completed.length > 0 ? Math.round((completed.length * 10) / completed.length) : 0;
            document.getElementById('doneCount').textContent = completed.length;
        }

        window.addEventListener('keydown', e => { if (e.ctrlKey && e.key === 'Enter') run(); });
        init();
    </script>
</body>
</html>