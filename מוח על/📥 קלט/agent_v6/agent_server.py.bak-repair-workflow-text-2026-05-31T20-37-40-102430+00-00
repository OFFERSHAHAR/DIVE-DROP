@app.route("/users", methods=["GET"])
def list_users():
    ensure_dir()
    user_files = [f for f in os.listdir(DATA_DIR)
                  if f.startswith("memory_") and f != "memory_global.json"]
    users = []
    for f in user_files:
        chat_id = f.replace("memory_", "").replace(".json", "")
        if not valid_chat_id(chat_id):
            continue
        mem = load_json(os.path.join(DATA_DIR, f), [])
        profile = get_profile_data(chat_id)
        users.append({"chat_id": chat_id, "display_name": profile.get("display_name", ""), "messages": len(mem)})
    return R(sorted(users, key=lambda x: -x["messages"]))

