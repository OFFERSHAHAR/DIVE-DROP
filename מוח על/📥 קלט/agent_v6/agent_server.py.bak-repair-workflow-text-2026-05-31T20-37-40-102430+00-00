@app.route("/admin/export/<chat_id>", methods=["GET"])
def admin_export_memory(chat_id):
    if not require_admin():
        return R({"error": "Admin only"}, 403)
    if not valid_chat_id(chat_id):
        return R({"error": "Invalid chat_id"}, 400)
    path = user_memory_file(chat_id)
    if not os.path.exists(path):
        save_json(path, [])
    return send_file(path, as_attachment=True, download_name=f"memory_{chat_id}.json", mimetype="application/json")

