@app.route("/memory/<chat_id>", methods=["POST"])
def add_user_memory(chat_id):
    if not valid_chat_id(chat_id):
        return R({"error": "Invalid chat_id"}, 400)
    data = request.get_json(force=True)
    if not data or "task" not in data:
        return R({"error": "Missing task"}, 400)
    memory = load_json(user_memory_file(chat_id), [])
    profile = get_profile_data(chat_id)
    user_name = data.get("user_name") or profile.get("display_name", "")
    entry = {
        "chat_id":    str(chat_id),
        "user_name":  clean_storage_value(user_name, 80),
        "task":       clean_storage_value(data.get("task", ""), 1000),
        "agent":      clean_storage_value(data.get("agent", "unknown"), 120) or "unknown",
        "result":     clean_storage_value(data.get("result", ""), 4000, keep_newlines=True),
        "score":      data.get("score", None),
        "deductions": data.get("deductions", None),
        "decision_reason": clean_storage_value(data.get("decision_reason", ""), 1000),
        "timestamp":  utc_now()
    }
    memory.append(entry)
    if len(memory) > 200:
        memory = memory[-200:]
    save_json(user_memory_file(chat_id), memory)
    try:
        if mini_session_active(chat_id):
            append_mini_inbox(chat_id, entry, "answer")
    except Exception:
        pass
    return R({"status": "ok", "entry": entry}, 201)

