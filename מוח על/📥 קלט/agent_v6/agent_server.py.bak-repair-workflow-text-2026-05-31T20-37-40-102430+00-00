def ensure_dir():
    os.makedirs(DATA_DIR, exist_ok=True)

def valid_chat_id(chat_id):
    return bool(CHAT_ID_RE.match(str(chat_id or "")))

def user_memory_file(chat_id):
    if not valid_chat_id(chat_id):
        raise ValueError("Invalid chat_id")
    return os.path.join(DATA_DIR, f"memory_{chat_id}.json")

def mini_inbox_file(chat_id):
    if not valid_chat_id(chat_id):
        raise ValueError("Invalid chat_id")
    return os.path.join(DATA_DIR, f"mini_inbox_{chat_id}.json")

def flow_log_file(chat_id):
    if not valid_chat_id(chat_id):
        raise ValueError("Invalid chat_id")
    return os.path.join(DATA_DIR, f"flow_{chat_id}.json")

def clean_display_name(name):
    value = str(name or "").replace("\\n", " ").replace("\\r", " ").strip()
    value = re.sub(r"\\s+", " ", value)
    return value[:60]

def load_profiles():
    profiles = load_json(USER_PROFILES_FILE, {})
    return profiles if isinstance(profiles, dict) else {}

def save_profiles(profiles):
    save_json(USER_PROFILES_FILE, profiles)

def get_profile_data(chat_id):
    profiles = load_profiles()
    profile = profiles.get(str(chat_id), {})
    profile.setdefault("chat_id", str(chat_id))
    profile.setdefault("display_name", "")
    profile.setdefault("awaiting_name", False)
    profile["exists"] = str(chat_id) in profiles
    return profile

def update_profile_data(chat_id, data):
    profiles = load_profiles()
    now = utc_now()
    profile = profiles.get(str(chat_id), {"chat_id": str(chat_id), "created_at": now})
    if "display_name" in data:
        profile["display_name"] = clean_display_name(data.get("display_name"))
    if "awaiting_name" in data:
        profile["awaiting_name"] = bool(data.get("awaiting_name"))
    for key in ["telegram_username", "telegram_first_name", "telegram_last_name"]:
        if key in data and data.get(key) is not None:
            profile[key] = clean_display_name(data.get(key))
    profile["updated_at"] = now
    profiles[str(chat_id)] = profile
    save_profiles(profiles)
    profile["exists"] = True
    return profile

def require_admin():
    supplied = request.headers.get("X-Admin-Chat-Id") or request.args.get("admin_id") or ""
    return str(supplied) == str(ADMIN_CHAT_ID)

def load_json(path, default):
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return default

def save_json(path, data):
    ensure_dir()
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)

def R(data, status=200):
    return Response(json.dumps(data, ensure_ascii=False),
                    status=status, mimetype="application/json")

def utc_now():
    return datetime.utcnow().isoformat()

def unix_now():
    return int(time.time())

def event_id(entry):
    raw = "|".join([
        str(entry.get("timestamp", "")),
        str(entry.get("agent", "")),
        str(entry.get("task", ""))[:120],
        str(entry.get("event", "answer"))
    ])
    return hashlib.sha1(raw.encode("utf-8", errors="ignore")).hexdigest()[:16]

def touch_mini_session(chat_id):
    sessions = load_json(MINI_APP_SESSIONS_FILE, {})
    now = unix_now()
    session = sessions.get(str(chat_id), {})
    session.update({
        "chat_id": str(chat_id),
        "opened_at": session.get("opened_at") or utc_now(),
        "last_seen_at": utc_now(),
        "active_until": now + 900,
        "channel": "mini_app"
    })
    sessions[str(chat_id)] = session
    save_json(MINI_APP_SESSIONS_FILE, sessions)
    return session

def mini_session_active(chat_id):
    sessions = load_json(MINI_APP_SESSIONS_FILE, {})
    session = sessions.get(str(chat_id), {})
    return int(session.get("active_until", 0) or 0) >= unix_now()

def append_mini_inbox(chat_id, entry, event_type="answer"):
    if not valid_chat_id(chat_id):
        return None
    clean = clean_memory_entry(entry)
    clean["event"] = event_type
    clean["channel"] = "mini_app"
    clean["delivered_at"] = utc_now()
    clean["id"] = event_id(clean)
    inbox = load_json(mini_inbox_file(chat_id), [])
    if not isinstance(inbox, list):
        inbox = []
    known = {str(item.get("id", "")) for item in inbox if isinstance(item, dict)}
    if clean["id"] not in known:
        inbox.append(clean)
    inbox = inbox[-120:]
    save_json(mini_inbox_file(chat_id), inbox)
    return clean

def mini_inbox_items(chat_id, limit=20):
    inbox = load_json(mini_inbox_file(chat_id), [])
    memory = load_json(user_memory_file(chat_id), [])
    items = []
    seen = set()
    for source in list(inbox) + [
        dict(clean_memory_entry(entry), event="answer", channel="memory", id=event_id(dict(entry, event="answer")))
        for entry in memory[-limit:]
        if isinstance(entry, dict)
    ]:
        if not isinstance(source, dict):
            continue
        key = str(source.get("id", ""))
        if key in seen:
            continue
        seen.add(key)
        items.append(source)
    items.sort(key=lambda item: item.get("timestamp", item.get("delivered_at", "")), reverse=True)
    return items[:limit]

def clean_flow_entry(entry):
    entry = entry if isinstance(entry, dict) else {}
    manager = entry.get("manager") if isinstance(entry.get("manager"), dict) else {}
    action = clean_storage_value(entry.get("action") or manager.get("action") or "unknown", 80)
    return {
        "chat_id": clean_storage_value(entry.get("chat_id", ""), 40),
        "user_name": clean_storage_value(entry.get("user_name", ""), 80),
        "task": clean_storage_value(entry.get("task", ""), 1000),
        "stage": clean_storage_value(entry.get("stage") or "conversation_manager", 80),
        "title": clean_storage_value(entry.get("title") or "מנהל שיחה", 120),
        "message": clean_storage_value(entry.get("message") or manager.get("summary") or "", 240),
        "action": action,
        "agent": clean_storage_value(entry.get("agent") or manager.get("agent") or "", 120),
        "reason": clean_storage_value(entry.get("reason") or entry.get("decision_reason") or manager.get("reason") or "", 1000),
        "mode": clean_storage_value(manager.get("mode") or action, 80),
        "answer_style": clean_storage_value(manager.get("answer_style", ""), 120),
        "memory_policy": clean_storage_value(manager.get("memory_policy", ""), 180),
        "progress_policy": clean_storage_value(manager.get("progress_policy", ""), 180),
        "show_progress": bool(manager.get("show_progress", False)),
        "confidence": manager.get("confidence", None),
        "source": clean_storage_value(entry.get("source") or "n8n", 80),
        "timestamp": entry.get("timestamp") or utc_now()
    }

