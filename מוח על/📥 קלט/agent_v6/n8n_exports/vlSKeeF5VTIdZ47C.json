        "id": "9030f788-5499-4d95-9167-187a303210ae",
        "name": "Read Memory",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          -992,
          256
        ],
        "alwaysOutputData": true
