      {
        "parameters": {
          "jsCode": "const userMessage = $('Telegram Trigger').item.json.message.text;\nconst chatId = $('Telegram Trigger').item.json.message.chat.id;\n\nlet registry = [];\ntry {\n  const items = $('Read Registry').all();\n  if (items && items.length > 0) {\n    const first = items[0].json;\n    if (Array.isArray(first)) registry = first;\n    else if (Array.isArray(first.agents)) registry = first.agents;\n    else registry = items.map(i => i.json);\n  }\n} catch(e) {}\n\nlet memory = [];\ntry {\n  const items = $('Read Memory').all();\n  if (items && items.length > 0) {\n    const first = items[0].json;\n    if (Array.isArray(first)) memory = first;\n    else if (Array.isArray(first.memory)) memory = first.memory;\n    else memory = items.map(i => i.json);\n  }\n} catch(e) {}\n\nconst activeAgents = registry.filter(a => (a.status || 'active') === 'active');\nconst sortedAgents = activeAgents.sort((a, b) => {\n  const scoreA = Number(a.score_avg ?? a.score ?? 0);\n  const scoreB = Number(b.score_avg ?? b.score ?? 0);\n  const usesA = Number(a.uses ?? 0);\n  const usesB = Number(b.uses ?? 0);\n  return (scoreB - scoreA) || (usesB - usesA);\n});\n\nconst agentList = sortedAgents.length > 0\n  ? sortedAgents.map(a => `- ${a.name}: ${a.description} (good for: ${a.good_for || ''}; avg score: ${a.score_avg ?? a.score ?? 'new'}; uses: ${a.uses ?? 0})`).join('\\n')\n  : 'No agents yet';\n\nconst recentMemory = memory.slice(-6)\n  .map(m => `[${m.agent}] ${m.task} -> ${(m.result || '').substring(0, 80)}`)\n  .join('\\n') || 'None';\n\nconst conversationHistory = memory.slice(-10)\n  .map(m => {\n    const assistant = m.agent === 'chitchat' ? 'Assistant' : `Assistant [${m.agent}]`;\n    return `User: ${m.task}\\n${assistant}: ${(m.result || '').substring(0, 300)}`;\n  })\n  .join('\\n\\n') || '';\n\nreturn [{ json: { userMessage, chatId, agentList, recentMemory, conversationHistory } }];"
        },
