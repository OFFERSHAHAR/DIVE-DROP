        "jsCode": "const rawUserMessage = $('Telegram Trigger').item.json.message.text || '';\nlet localPathContext = {};\ntry {\n  const items = $('Read Local Path Context').all();\n  if (items && items.length > 0) localPathContext = items[0].json || {};\n} catch(e) {}\nconst localContextText = localPathContext && localPathContext.ok && localPathContext.context ? String(localPathContext.context) : '';\nconst userMessage = (rawUserMessage + (localContextText ? '\\n\\n' + localContextText : '')).trim();\nconst chatId = $('Telegram Trigger').item.json.message.chat.id;\n\nlet registry = [];\ntry {\n  const items = $('Read Registry').all();\n  if (items && items.length > 0) {\n    const first = items[0].json;\n    if (Array.isArray(first)) registry = first;\n    else if (Array.isArray(first.agents)) registry = first.agents;\n    else registry = items.map(i => i.json);\n  }\n} catch(e) {}\n\nlet memory = [];\ntry {\n  const items = $('Read Memory').all();\n  if (items && items.length > 0) {\n    const first = items[0].json;\n    if (Array.isArray(first)) memory = first;\n    else if (Array.isArray(first.memory)) memory = first.memory;\n    else memory = items.map(i => i.json);\n  }\n} catch(e) {}\n\nlet profile = {};\ntry {\n  const items = $('Read Profile').all();\n  if (items && items.length > 0) profile = items[0].json || {};\n} catch(e) {}\n\nconst pendingCreatedAgent = (() => {\n  const reversedPending = [...memory].map((entry, index) => ({ entry, index })).reverse();\n  const found = reversedPending.find(item => String(item.entry && item.entry.agent || '') === 'pending_created_agent');\n  if (!found) return null;\n\n  let pending = null;\n  try {\n    pending = JSON.parse(String(found.entry.result || '{}'));\n  } catch (e) {\n    return null;\n  }\n  if (!pending || !pending.agentName || !pending.task) return null;\n\n  const createdMs = Date.parse(pending.created_at || found.entry.timestamp || found.entry.time || '');\n  const isFresh = !Number.isFinite(createdMs) || (Date.now() - createdMs) < 60 * 60 * 1000;\n  if (!isFresh) return null;\n\n  const laterEntries = memory.slice(found.index + 1);\n  const alreadyRan = laterEntries.some(m =>\n    String(m.agent || '') === String(pending.agentName || '') &&\n    String(m.task || '').trim() === String(pending.task || '').trim()\n  );\n  const canceled = laterEntries.some(m => /ביטלתי את ההרצה|ביטול|בוטל/.test(String(m.result || '')));\n  if (alreadyRan || canceled) return null;\n\n  return pending;\n})();\nmemory = memory.filter(m => String(m.agent || '') !== 'pending_created_agent');\n\nconst userName = String(profile.display_name || '').trim();\nconst awaitingName = Boolean(profile.awaiting_name);\nconst profileExists = Boolean(profile.exists);\n\nfunction cleanTextForPrompt(value) {\n  const allowed = new Set(['AI','API','JSON','HTML','CSS','JS','SQL','DB','UI','UX','HTTP','URL','N8N','OLLAMA','TELEGRAM','PYTHON','JAVASCRIPT','REACT','NODE','WEBHOOK','FRONTEND','BACKEND','MYSQL','PHP','PDF','WORKFLOW','AGENT','BOT','MINI','APP','FLASK','GATEWAY','NGROK','PROMPT','MODEL','ROUTER','MEMORY','CHAT','CRM']);\n  return String(value || '')\n    .replace(/[\\u0600-\\u06FF\\u0750-\\u077F\\u08A0-\\u08FF\\uFB50-\\uFDFF\\uFE70-\\uFEFF\\u0400-\\u04FF\\u0370-\\u03FF\\u0E00-\\u0E7F\\u3040-\\u30FF\\uAC00-\\uD7AF\\u4E00-\\u9FFF\\u3400-\\u4DBF\\u3000-\\u303F\\uFF00-\\uFFEF\\u00C0-\\u024F]/g, '')\n    .replace(/[┏┗┣┃━]+/g, ' ')\n    .replace(/\\[out\\]/gi, '')\n    .replace(/[\\\\*\\`#_]/g, '')\n    .replace(/&\\s*(lt|gt|amp)\\s*;/gi, ' ')\n      .replace(/[<>]/g, ' ')\n    .replace(/[A-Za-z][A-Za-z0-9_+#./-]*/g, (token) => {\n      const key = token.replace(/[.]+$/g, '').toUpperCase();\n      return allowed.has(key) ? token : '';\n    })\n    .replace(/(זין|כוס|שרמוט|זונה|מזדיין|בן זונה|fuck|sex|porn)/gi, '')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nconst bannedAgentNames = new Set(['agent', 'snakecaseagent', 'snake_case_agent', 'snake_case_name', 'custom_task_agent', 'new_agent', 'helper', 'assistant', 'hebrew_task_agent', 'generic_task_agent', 'custom_hebrew_agent']);\n\nconst activeAgents = registry\n  .filter(a => (a.status || 'active') === 'active' && !bannedAgentNames.has(String(a.name || '').toLowerCase()))\n  .sort((a, b) => {\n    const scoreA = Number(a.score_avg ?? a.score ?? 0);\n    const scoreB = Number(b.score_avg ?? b.score ?? 0);\n    const usesA = Number(a.uses ?? 0);\n    const usesB = Number(b.uses ?? 0);\n    return (scoreB - scoreA) || (usesB - usesA);\n  });\n\nconst agentList = activeAgents.slice(0, 8).length > 0\n  ? activeAgents.slice(0, 8).map(a => `- ${a.name}: ${cleanTextForPrompt(a.description)} (מתאים ל: ${cleanTextForPrompt(a.good_for || '')}; ציון: ${a.score_avg ?? a.score ?? 'חדש'}; שימושים: ${a.uses ?? 0})`).join('\\n')\n  : 'אין עדיין סוכנים';\n\nfunction memoryEntryIsUseful(m) {\n  const task = cleanTextForPrompt(m.task || '');\n  const result = cleanTextForPrompt(m.result || '');\n  const raw = `${m.task || ''}\\n${m.result || ''}`;\n  if (m.quarantined || m.ignore_for_prompt) return false;\n  const skipTasks = new Set(['הי', 'היי', 'שלום', 'מה נשמע', 'מה קורה', 'מאשר', 'כן', 'לא', 'בטל']);\n  if (!task || skipTasks.has(task)) return false;\n  if (/^כוונת ממשק:/.test(task)) return false;\n  const badN8nWorkflowJson = /(SELF-CHECK PROTOCOL|ckecklist|n8n_nodes_base_|n8n-nodes-base\\.parseJSON|n8n-nodes-base\\.log|saveToDatabase|filterData|analyzeData|\\\"connections\\\"\\s*:\\s*\\[\\s*\\[|\\\"type\\\"\\s*:\\s*\\\"ckecklist\\\")/i.test(raw);\n  if (badN8nWorkflowJson) return false;\n  if (/יש סוכן חדש שמוכן להרצה|ביטלתי את ההרצה|לא התקבלה תשובה מלאה/.test(result)) return false;\n  const currentName = String(userName || '').trim();\n  const escapedCurrentName = currentName.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n  const assistantClaimsUserName = escapedCurrentName && new RegExp('אני\\\\s+' + escapedCurrentName + '\\\\b').test(raw);\n  if (assistantClaimsUserName || /אני\\s+עופר\\b|עופר\\s+יודע\\s+להטמיע|מודולים\\s+פתרונות\\s+AI\\s+לאת?רגונים|מבנה\\s+של\\s+פתרונות\\s+AI\\s+עבור\\s+N8N/i.test(raw)) return false;\n  return true;\n}\n\nconst usefulMemory = memory.filter(memoryEntryIsUseful);\n\nconst recentMemory = usefulMemory.slice(-5)\n  .map(m => `[${m.agent}] ${cleanTextForPrompt(m.task).substring(0, 120)}`)\n  .join('\\n') || 'None';\n\nconst conversationHistory = usefulMemory.slice(-4)\n  .map(m => {\n    const assistant = m.agent === 'chitchat' ? 'עוזר' : `עוזר [${m.agent}]`;\n    return `משתמש: ${cleanTextForPrompt(m.task).substring(0, 180)}\\n${assistant}: ${cleanTextForPrompt(m.result).substring(0, 260)}`;\n  })\n  .join('\\n\\n') || '';\n\n\nconst skipHistoryTasks = new Set(['הי', 'היי', 'שלום', 'מה נשמע', 'מה קורה']);\nconst historyTaskWords = ['באיזה סוכן', 'איזה סוכן השתמש', 'איזה נציג השתמש', 'היסטוריית סוכנים', 'שימושי סוכנים', 'זיכרון סוכנים'];\nconst agentHistoryRows = [...memory].reverse()\n  .filter(m => {\n    const task = cleanTextForPrompt(m.task || '');\n    const isHistoryTask = historyTaskWords.some(word => task.includes(word));\n    return task && m.agent && !skipHistoryTasks.has(task) && !isHistoryTask;\n  })\n  .slice(0, 12)\n  .map((m, index) => {\n    const task = cleanTextForPrompt(m.task || '').substring(0, 180) || 'לא נשמרה משימה';\n    const agent = String(m.agent || 'לא ידוע').replace(/[^A-Za-z0-9_א-ת-]/g, '').trim() || 'לא ידוע';\n    const score = (m.score === null || m.score === undefined || m.score === '') ? 'אין' : String(m.score) + '/10';\n    const time = String(m.timestamp || '').replace('T', ' ').substring(0, 16) || 'לא נשמר';\n    const reason = cleanTextForPrompt(m.decision_reason || m.deductions || '').substring(0, 180) || 'לא נשמרה סיבה';\n    return `${index + 1}. משימה:\n${task}\nסוכן:\n${agent}\nציון:\n${score}\nסיבה:\n${reason}\nזמן:\n${time}`;\n  });\n\nconst agentHistory = agentHistoryRows.length\n  ? `שימושי סוכנים מהזיכרון\nמשתמש: ${userName || 'משתמש'}\n\n${agentHistoryRows.join('\\n\\n')}`\n  : `${userName || 'משתמש'}, אין עדיין שימושי סוכנים שמורים בזיכרון האישי שלך.`;\n\nconst lastScored = [...memory].reverse().find(m => m.score !== null && m.score !== undefined);\nconst lastEvaluation = lastScored ? {\n  task: lastScored.task || '',\n  agent: lastScored.agent || '',\n  score: lastScored.score,\n  deductions: lastScored.deductions || 'לא נשמר פירוט ניכויים',\n  result: cleanTextForPrompt(lastScored.result).substring(0, 500),\n  timestamp: lastScored.timestamp || ''\n} : null;\n\nreturn [{ json: { userMessage, chatId, agents: activeAgents, agentList, recentMemory, conversationHistory, lastEvaluation, agentHistory, pendingCreatedAgent, profile, userName, awaitingName, profileExists } }];"
