        "jsCode": "const data = $('Prepare Data').first().json;\nconst msg = String(data.userMessage || '').trim();\nfunction extractUserGoal(value) {\n  const text = String(value || '').trim();\n  const asciiMatch = text.match(/USER_REQUEST:\\s*([\\s\\S]*?)(?:\\nBUTTON_HINT:|\\nINTENT_LABEL:|\\nRULE:|$)/);\n  if (asciiMatch && asciiMatch[1] && asciiMatch[1].trim()) return asciiMatch[1].trim();\n  const hebrewMatch = text.match(/בקשת המשתמש:\\s*([\\s\\S]*?)(?:\\nהנחיית כפתור משנית:|\\nכוונת ממשק:|\\nחוק ביצוע:|$)/);\n  if (hebrewMatch && hebrewMatch[1] && hebrewMatch[1].trim()) return hebrewMatch[1].trim();\n  const legacyMatch = text.match(/(?:בקשת המשתמש|׳‘׳§׳©׳× ׳”׳׳©׳×׳׳©):\\s*([\\s\\S]*)$/);\n  if (legacyMatch && legacyMatch[1] && legacyMatch[1].trim()) return legacyMatch[1].trim();\n  return text;\n}\nconst userGoalRaw = extractUserGoal(msg);\nconst localContextMatch = msg.match(/READ_ONLY_LOCAL_PATH_CONTEXT[\\s\\S]*?(?:----- END LOCAL FILE -----|----- END LOCAL DIRECTORY -----)/i);\nconst localContextBlock = localContextMatch ? localContextMatch[0] : '';\nconst userGoal = localContextBlock && !userGoalRaw.includes(localContextBlock)\n  ? (userGoalRaw + '\\n\\n' + localContextBlock).trim()\n  : userGoalRaw;\nconst lower = msg.toLowerCase();\nconst userLower = userGoal.toLowerCase();\nconst agents = Array.isArray(data.agents) ? data.agents : [];\nconst hasAttachedFile = /----- BEGIN ATTACHED FILE -----|FILE_CONTEXT|READ_ONLY_LOCAL_PATH_CONTEXT|----- BEGIN LOCAL FILE -----|----- BEGIN LOCAL DIRECTORY -----|קובץ מצורף לקריאה בלבד/i.test(msg);\n\nconst hasAny = (words) => words.some(w => lower.includes(w.toLowerCase()));\nconst hasAnyUser = (words) => words.some(w => userLower.includes(w.toLowerCase()));\nconst exactCasual = ['הי', 'היי', 'הייי', 'הלו', 'שלום', 'בוקר טוב', 'ערב טוב', 'לילה טוב', 'מה נשמע', 'מה קורה', 'מה המצב', 'תודה', 'סבבה', 'אחלה'];\nconst scoreDetailWords = ['פירוט ציון', 'פירוט על הציון', 'שלח פירוט על הציון', 'פרטים על הציון', 'למה הציון',