      "parameters": {
        "jsCode": "const userMessage = $('Telegram Trigger').item.json.message.text || '';\nconst chatId = $('Telegram Trigger').item.json.message.chat.id;\n\nlet registry = [];\ntry {\n  const items = $('Read Registry').all();\n  if (items && items.length > 0) {\n    const first = items[0].json;\n    if (Array.isArray(first)) registry = first;\n    else if (Array.isArray(first.agents)) registry = first.agents;\n    else registry = items.map(i => i.json);\n  }\n} catch(e) {}\n\nlet memory = [];\ntry {\n  const items = $('Read Memory').all();\n  if (items && items.length > 0) {\n    const first = items[0].json;\n    if (Array.isArray(first)) memory = first;\n    else if (Array.isArray(first.memory)) memory = first.memory;\n    else memory = items.map(i => i.json);\n  }\n} catch(e) {}\n\nlet profile = {};\ntry {\n  const items = $('Read Profile').all();\n  if (items && items.length > 0) profile = items[0].json || {};\n} catch(e) {}\n\nconst userName = String(profile.display_name || '').trim();\nconst awaitingName = Boolean(profile.awaiting_name);\nconst profileExists = Boolean(profile.exists);\n\nfunction cleanTextForPrompt(value) {\n  return String(value || '')\n    .replace(/[\\u4E00-\\u9FFF\\u3400-\\u4DBF\\u3000-\\u303F\\uFF00-\\uFFEF\\u00C0-\\u024F]/g, '')\n    .replace(/\\[out\\]/gi, '').replace(/[\\\\*`#]/g, '')\n    .replace(/(Ч–ЧҷЧҹ|ЧӣЧ•ЧЎ|Ч©ЧЁЧһЧ•Чҳ|Ч–Ч•Ч Ч”|ЧһЧ–Ч“ЧҷЧҷЧҹ|Ч‘Чҹ Ч–Ч•Ч Ч”|fuck|sex|porn)/gi, '')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nconst bannedAgentNames = new Set(['agent', 'snakecaseagent', 'snake_case_agent', 'snake_case_name', 'custom_task_agent', 'new_agent', 'helper', 'assistant']);\n\nconst activeAgents = registry\n  .filter(a => (a.status || 'active') === 'active' && !bannedAgentNames.has(String(a.name || '').toLowerCase()))\n  .sort((a, b) => {\n    const scoreA = Number(a.score_avg ?? a.score ?? 0);\n    const scoreB = Number(b.score_avg ?? b.score ?? 0);\n    const usesA = Number(a.uses ?? 0);\n    const usesB = Number(b.uses ?? 0);\n    return (scoreB - scoreA) || (usesB - usesA);\n  });\n\nconst agentList = activeAgents.slice(0, 8).length > 0\n  ? activeAgents.slice(0, 8).map(a => `- ${a.name}: ${cleanTextForPrompt(a.description)} (ЧһЧӘЧҗЧҷЧқ Чң: ${cleanTextForPrompt(a.good_for || '')}; ЧҰЧҷЧ•Чҹ: ${a.score_avg ?? a.score ?? 'Ч—Ч“Ч©'}; Ч©ЧҷЧһЧ•Ч©ЧҷЧқ: ${a.uses ?? 0})`).join('\\n')\n  : 'ЧҗЧҷЧҹ ЧўЧ“ЧҷЧҷЧҹ ЧЎЧ•ЧӣЧ ЧҷЧқ';\n\nconst recentMemory = memory.slice(-3)\n  .map(m => `[${m.agent}] ${cleanTextForPrompt(m.task).substring(0, 120)}`)\n  .join('\\n') || 'None';\n\nconst conversationHistory = memory.slice(-3)\n  .map(m => {\n    const assistant = m.agent === 'chitchat' ? 'ЧўЧ•Ч–ЧЁ' : `ЧўЧ•Ч–ЧЁ [${m.agent}]`;\n    return `ЧһЧ©ЧӘЧһЧ©: ${cleanTextForPrompt(m.task).substring(0, 180)}\\n${assistant}: ${cleanTextForPrompt(m.result).substring(0, 220)}`;\n  })\n  .join('\\n\\n') || '';\n\n\nconst skipHistoryTasks = new Set(['Ч”Чҷ', 'Ч”ЧҷЧҷ', 'Ч©ЧңЧ•Чқ', 'ЧһЧ” Ч Ч©ЧһЧў', 'ЧһЧ” Ч§Ч•ЧЁЧ”']);\nconst agentHistoryRows = [...memory].reverse()\n  .filter(m => {\n    const task = cleanTextForPrompt(m.task || '');\n    return task && m.agent && !skipHistoryTasks.has(task);\n  })\n  .slice(0, 12)\n  .map((m, index) => {\n    const task = cleanTextForPrompt(m.task || '').substring(0, 180) || 'ЧңЧҗ Ч Ч©ЧһЧЁЧ” ЧһЧ©ЧҷЧһЧ”';\n    const agent = String(m.agent || 'ЧңЧҗ ЧҷЧ“Ч•Чў').trim() || 'ЧңЧҗ ЧҷЧ“Ч•Чў';\n    const score = (m.score === null || m.score === undefined || m.score === '') ? 'ЧҗЧҷЧҹ' : String(m.score) + '/10';\n    const time = String(m.timestamp || '').replace('T', ' ').substring(0, 16) || 'ЧңЧҗ Ч Ч©ЧһЧЁ';\n    return `${index + 1}. ЧһЧ©ЧҷЧһЧ”:\n${task}\nЧЎЧ•ЧӣЧҹ:\n${agent}\nЧҰЧҷЧ•Чҹ:\n${score}\nЧ–ЧһЧҹ:\n${time}`;\n  });\n\nconst agentHistory = agentHistoryRows.length\n  ? `в”Ҹв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nв”ғ Ч©ЧҷЧһЧ•Ч©Чҷ ЧЎЧ•ЧӣЧ ЧҷЧқ ЧһЧ”Ч–ЧҷЧӣЧЁЧ•Чҹ\nв”Јв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nв”ғ ЧһЧ©ЧӘЧһЧ©:\nв”ғ ${userName || 'ЧһЧ©ЧӘЧһЧ©'}\nв”ғ\n${agentHistoryRows.join('\\n\\n')}\nв”—в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ`\n  : `${userName || 'ЧһЧ©ЧӘЧһЧ©'}, ЧҗЧҷЧҹ ЧўЧ“ЧҷЧҷЧҹ Ч©ЧҷЧһЧ•Ч©Чҷ ЧЎЧ•ЧӣЧ ЧҷЧқ Ч©ЧһЧ•ЧЁЧҷЧқ Ч‘Ч–ЧҷЧӣЧЁЧ•Чҹ Ч”ЧҗЧҷЧ©Чҷ Ч©ЧңЧҡ.`;\n\nconst lastScored = [...memory].reverse().find(m => m.score !== null && m.score !== undefined);\nconst lastEvaluation = lastScored ? {\n  task: lastScored.task || '',\n  agent: lastScored.agent || '',\n  score: lastScored.score,\n  deductions: lastScored.deductions || 'ЧңЧҗ Ч Ч©ЧһЧЁ ЧӨЧҷЧЁЧ•Чҳ Ч ЧҷЧӣЧ•ЧҷЧҷЧқ',\n  result: cleanTextForPrompt(lastScored.result).substring(0, 500),\n  timestamp: lastScored.timestamp || ''\n} : null;\n\nreturn [{ json: { userMessage, chatId, agents: activeAgents, agentList, recentMemory, conversationHistory, lastEvaluation, agentHistory, profile, userName, awaitingName, profileExists } }];"
      },
