    {
      "parameters": {
        "jsCode": "const data = $('Prepare Data').first().json;\nconst msg = String(data.userMessage || '').trim();\nconst lower = msg.toLowerCase();\nconst agents = Array.isArray(data.agents) ? data.agents : [];\n\nconst hasAny = (words) => words.some(w => lower.includes(w.toLowerCase()));\nconst exactCasual = ['Ч”Чҷ', 'Ч”ЧҷЧҷ', 'Ч”ЧҷЧҷЧҷ', 'Ч”ЧңЧ•', 'Ч©ЧңЧ•Чқ', 'Ч‘Ч•Ч§ЧЁ ЧҳЧ•Ч‘', 'ЧўЧЁЧ‘ ЧҳЧ•Ч‘', 'ЧңЧҷЧңЧ” ЧҳЧ•Ч‘', 'ЧһЧ” Ч Ч©ЧһЧў', 'ЧһЧ” Ч§Ч•ЧЁЧ”', 'ЧһЧ” Ч”ЧһЧҰЧ‘', 'ЧӘЧ•Ч“Ч”', 'ЧЎЧ‘Ч‘Ч”', 'ЧҗЧ—ЧңЧ”'];\nconst detailWords = ['ЧӨЧҷЧЁЧ•Чҳ', 'ЧӘЧҹ ЧӨЧҷЧЁЧ•Чҳ', 'ЧӨЧЁЧҳ', 'Ч©ЧңЧ— ЧӨЧҷЧЁЧ•Чҳ', 'ЧӨЧЁЧҳЧҷЧқ ЧўЧң Ч”ЧҰЧҷЧ•Чҹ', 'ЧңЧһЧ” Ч”ЧҰЧҷЧ•Чҹ'];\nconst chitchatWords = ['ЧһЧҷ ЧҗЧӘЧ”', 'ЧўЧ–ЧЁЧ”', 'ЧһЧ” ЧҗЧӘЧ” ЧҷЧ•Ч“Чў ЧңЧўЧ©Ч•ЧӘ'];\nconst codeWords = ['code', 'python', 'javascript', 'js', 'sql', 'html', 'css', 'react', 'bug', 'debug', 'Ч“ЧҷЧ‘ЧҗЧ’', 'Ч§Ч•Ч“', 'ЧӨЧ•Ч Ч§ЧҰЧҷЧ”', 'ЧЎЧ§ЧЁЧҷЧӨЧҳ', 'Ч©Ч’ЧҷЧҗЧ”'];\nconst createAgentWords = ['ЧҰЧ•ЧЁ ЧңЧҷ ЧЎЧ•ЧӣЧҹ', 'ЧӘЧҷЧҰЧ•ЧЁ ЧңЧҷ ЧЎЧ•ЧӣЧҹ', 'Ч‘Ч Ч” ЧңЧҷ ЧЎЧ•ЧӣЧҹ', 'ЧӘЧ‘Ч Ч” ЧңЧҷ ЧЎЧ•ЧӣЧҹ', 'ЧӘЧӣЧҷЧҹ ЧңЧҷ ЧЎЧ•ЧӣЧҹ', 'ЧҰЧ•ЧЁ ЧЎЧ•ЧӣЧҹ', 'ЧЎЧ•ЧӣЧҹ Ч—Ч“Ч©', 'Ч ЧҰЧҷЧ’ Ч—Ч“Ч©'];\nconst historyWords = ['Ч‘ЧҗЧҷЧ–Ч” ЧЎЧ•ЧӣЧҹ', 'ЧҗЧҷЧ–Ч” ЧЎЧ•ЧӣЧҹ Ч”Ч©ЧӘЧһЧ©', 'ЧҗЧҷЧ–Ч” Ч ЧҰЧҷЧ’ Ч”Ч©ЧӘЧһЧ©', 'ЧЎЧ•ЧӣЧҹ Ч”Ч©ЧӘЧһЧ©ЧӘ', 'Ч ЧҰЧҷЧ’ Ч”Ч©ЧӘЧһЧ©ЧӘ', 'Ч”ЧҷЧЎЧҳЧ•ЧЁЧҷЧҷЧӘ ЧЎЧ•ЧӣЧ ЧҷЧқ', 'Ч©ЧҷЧһЧ•Ч©Чҷ ЧЎЧ•ЧӣЧ ЧҷЧқ', 'Ч–ЧҷЧӣЧЁЧ•Чҹ ЧЎЧ•ЧӣЧ ЧҷЧқ', 'ЧЎЧ•ЧӣЧҹ ЧңЧҗЧҷЧ–Ч• ЧһЧ©ЧҷЧһЧ”', 'Ч ЧҰЧҷЧ’ ЧңЧҗЧҷЧ–Ч• ЧһЧ©ЧҷЧһЧ”'];\n\nfunction cleanName(value) {\n  let text = String(value || '').trim();\n  const match = text.match(/(?:Ч§Ч•ЧЁЧҗЧҷЧқ ЧңЧҷ|Ч”Ч©Чқ Ч©ЧңЧҷ|ЧҗЧ Чҷ)\\s+([^,.!?\\n]+)$/i);\n  if (match) text = match[1];\n  text = text\n    .replace(/^(Ч§Ч•ЧЁЧҗЧҷЧқ ЧңЧҷ|Ч”Ч©Чқ Ч©ЧңЧҷ|ЧҗЧ Чҷ)\\s+/i, '')\n    .replace(/(?:^|\\s)(ЧӘЧҷЧҰЧ•ЧЁ|ЧҰЧ•ЧЁ|ЧӘЧўЧ©Ч”|Ч‘Ч Ч”|ЧӘЧ‘Ч Ч”|ЧӘЧӣЧҷЧҹ|Ч”ЧӣЧҹ|ЧҰЧЁЧҷЧҡ|ЧЁЧ•ЧҰЧ”|ЧЎЧ•ЧӣЧҹ|Ч ЧҰЧҷЧ’).*$/i, '')\n    .replace(/[^\\u0590-\\u05FFa-zA-Z\\s'-]/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n  if (text.split(/\\s+/).length > 3) return '';\n  return text.slice(0, 40);\n}\n\nlet action = 'create_agent';\nlet agent_name = null;\nlet direct_reply = null;\nlet userName = data.userName || '';\nlet requestMessage = msg;\n\nif (!data.userName && !data.awaitingName) {\n  action = 'ask_name';\n  direct_reply = 'Ч‘ЧЁЧ•Чҡ Ч”Ч‘Чҗ. ЧҗЧҷЧҡ Ч§Ч•ЧЁЧҗЧҷЧқ ЧңЧҡ?\\n\\nЧҗЧ—ЧЁЧҷ Ч©ЧӘЧӣЧӘЧ•Ч‘ ЧҗЧӘ Ч”Ч©Чқ Ч©ЧңЧҡ, ЧҗЧ–ЧӣЧ•ЧЁ ЧҗЧ•ЧӘЧ• Ч•ЧҗЧӨЧ Ч” ЧҗЧңЧҷЧҡ Ч‘Ч©Чқ Ч‘Ч©ЧҷЧ—Ч•ЧӘ Ч”Ч‘ЧҗЧ•ЧӘ.';\n} else if ((!data.userName && data.awaitingName) || /^\\s*(Ч§Ч•ЧЁЧҗЧҷЧқ ЧңЧҷ|Ч”Ч©Чқ Ч©ЧңЧҷ|ЧҗЧ Чҷ)\\s+/i.test(msg)) {\n  const extractedName = cleanName(msg);\n  const inlineRequest = (() => {\n    const raw = msg.replace(/^\\s*(Ч§Ч•ЧЁЧҗЧҷЧқ ЧңЧҷ|Ч”Ч©Чқ Ч©ЧңЧҷ|ЧҗЧ Чҷ)\\s+/i, '').trim();\n    const marker = raw.search(/\\s(ЧҰЧ•ЧЁ|ЧӘЧҷЧҰЧ•ЧЁ|ЧӘЧўЧ©Ч”|Ч‘Ч Ч”|ЧӘЧ‘Ч Ч”|ЧӘЧӣЧҷЧҹ|Ч”ЧӣЧҹ|ЧҰЧЁЧҷЧҡ|ЧЁЧ•ЧҰЧ”)\\s/i);\n    if (marker > 0) return raw.slice(marker).trim();\n    return '';\n  })();\n  if (extractedName && inlineRequest && inlineRequest.split(/\\s+/).filter(Boolean).length >= 3) {\n    action = 'create_agent';\n    userName = extractedName;\n    requestMessage = inlineRequest;\n    direct_reply = null;\n  } else if (extractedName) {\n    action = 'save_name';\n    userName = extractedName;\n    direct_reply = `Ч ЧўЧҷЧқ ЧһЧҗЧ•Ч“, ${userName}.\\n\\nЧһЧўЧӣЧ©ЧҷЧ• ЧҗЧӨЧ Ч” ЧҗЧңЧҷЧҡ Ч‘Ч©Чқ Ч”Ч–Ч”. ЧҗЧқ ЧӣЧӘЧ‘ЧӘ Ч’Чқ Ч‘Ч§Ч©Ч” Ч‘ЧҗЧ•ЧӘЧ” Ч”Ч•Ч“ЧўЧ”, Ч©ЧңЧ— ЧҗЧ•ЧӘЧ” Ч©Ч•Ч‘ Ч‘Ч©Ч•ЧЁЧ” Ч—Ч“Ч©Ч” Ч•ЧҗЧҳЧӨЧң Ч‘Ч” ЧһЧҷЧ“.`;\n  } else {\n    action = 'ask_name';\n    direct_reply = 'ЧңЧҗ Ч”ЧҰЧңЧ—ЧӘЧҷ ЧңЧ”Ч‘ЧҷЧҹ ЧһЧ” Ч”Ч©Чқ Ч‘ЧңЧ‘Ч“. ЧӣЧӘЧ•Ч‘ ЧЁЧ§ ЧҗЧӘ Ч”Ч©Чқ Ч©ЧңЧҡ, ЧңЧһЧ©Чң: ЧўЧ•ЧӨЧЁ';\n  }\n} else {\n  const wordCount = msg.split(/\\s+/).filter(Boolean).length;\n  const isShortCasual = wordCount <= 3 && (exactCasual.includes(lower) || hasAny(exactCasual));\n  const asksForScoreDetails = hasAny(detailWords);\n  const asksForAgentHistory = hasAny(historyWords);\n\n  if (asksForAgentHistory) {\n    action = 'chitchat';\n    direct_reply = data.agentHistory || `${data.userName || 'ЧһЧ©ЧӘЧһЧ©'}, ЧҗЧҷЧҹ ЧўЧ“ЧҷЧҷЧҹ Ч©ЧҷЧһЧ•Ч©Чҷ ЧЎЧ•ЧӣЧ ЧҷЧқ Ч©ЧһЧ•ЧЁЧҷЧқ Ч‘Ч–ЧҷЧӣЧЁЧ•Чҹ Ч”ЧҗЧҷЧ©Чҷ Ч©ЧңЧҡ.`;\n  } else if (hasAny(createAgentWords)) {\n    action = 'create_agent';\n  } else if (asksForScoreDetails) {\n    action = 'chitchat';\n    const ev = data.lastEvaluation;\n    if (ev) {\n      direct_reply = `в”Ҹв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nв”ғ ЧӨЧҷЧЁЧ•Чҳ ЧҰЧҷЧ•Чҹ ЧҗЧ—ЧЁЧ•Чҹ\nв”Јв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\nв”ғ ЧһЧ©ЧӘЧһЧ©:\nв”ғ ${data.userName}\nв”ғ\nв”ғ ЧЎЧ•ЧӣЧҹ:\nв”ғ ${ev.agent}\nв”ғ\nв”ғ ЧҰЧҷЧ•Чҹ:\nв”ғ ${ev.score}/10\nв”ғ\nв”ғ ЧЎЧҷЧ‘Ч”:\nв”ғ ${ev.deductions}\nв”ғ\nв”ғ ЧһЧ©ЧҷЧһЧ”:\nв”ғ ${ev.task}\nв”—в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ`;\n    } else {\n      direct_reply = `${data.userName}, ЧҗЧҷЧҹ ЧўЧ“ЧҷЧҷЧҹ ЧҰЧҷЧ•Чҹ Ч©ЧһЧ•ЧЁ Ч‘Ч–ЧҷЧӣЧЁЧ•Чҹ Ч”ЧҗЧҷЧ©Чҷ Ч©ЧңЧҡ.`;\n    }\n  } else if (!msg || isShortCasual || hasAny(chitchatWords)) {\n    action = 'chitchat';\n    if (isShortCasual) {\n      direct_reply = `${data.userName || 'Ч©ЧңЧ•Чқ'}, Ч©ЧңЧ•Чқ. ЧҗЧҷЧҡ ЧҗЧӨЧ©ЧЁ ЧңЧўЧ–Ч•ЧЁ ЧңЧҡ ЧўЧӣЧ©ЧҷЧ•?`;\n    }\n  } else if (hasAny(codeWords) && agents.some(a => a.name === 'code_helper')) {\n    action = 'use_agent';\n    agent_name = 'code_helper';\n  } else {\n    const tokens = lower\n      .replace(/[^a-z0-9Чҗ-ЧӘ_\\s]/gi, ' ')\n      .split(/\\s+/)\n      .filter(t => t.length >= 3);\n\n    let best = null;\n    let bestScore = 0;\n    for (const agent of agents) {\n      const haystack = [agent.name, agent.description, agent.good_for].join(' ').toLowerCase();\n      let score = 0;\n      for (const token of tokens) {\n        if (haystack.includes(token)) score += 1;\n      }\n      score += Math.min(Number(agent.score_avg ?? agent.score ?? 0) || 0, 10) / 20;\n      score += Math.min(Number(agent.uses ?? 0) || 0, 20) / 100;\n      if (score > bestScore) {\n        bestScore = score;\n        best = agent;\n      }\n    }\n\n    if (best && bestScore >= 1.3) {\n      ac