      "parameters": {
        "jsCode": "const userMessage = $('Telegram Trigger').item.json.message.text || '';\nconst chatId = $('Telegram Trigger').item.json.message.chat.id;\n\nlet registry = [];\ntry {\n  const items = $('Read Registry').all();\n  if (items && items.length > 0) {\n    const first = items[0].json;\n    if (Array.isArray(first)) registry = first;\n    else if (Array.isArray(first.agents)) registry = first.agents;\n    else registry = items.map(i => i.json);\n  }\n} catch(e) {}\n\nlet memory = [];\ntry {\n  const items = $('Read Memory').all();\n  if (items && items.length > 0) {\n    const first = items[0].json;\n    if (Array.isArray(first)) memory = first;\n    else if (Array.isArray(first.memory)) memory = first.memory;\n    else memory = items.map(i => i.json);\n  }\n} catch(e) {}\n\nlet profile = {};\ntry {\n  const items = $('Read Profile').all();\n  if (items && items.length > 0) profile = items[0].json || {};\n} catch(e) {}\n\nconst latestMemoryEntry = [...memory].reverse().find(m => m && (m.task || m.result || m.agent)) || null;\nconst pendingCreatedAgent = (() => {\n  if (!latestMemoryEntry || String(latestMemoryEntry.agent || '') !== 'pending_created_agent') return null;\n  try {\n    const pending = JSON.parse(String(latestMemoryEntry.result || '{}'));\n    if (!pending || !pending.agentName || !pending.task) return null;\n    const createdMs = Date.parse(pending.created_at || latestMemoryEntry.timestamp || '');\n    const isFresh = !Number.isFinite(createdMs) || (Date.now() - createdMs) < 60 * 60 * 1000;\n    return isFresh ? pending : null;\n  } catch (e) {\n    return null;\n  }\n})();\nmemory = memory.filter(m => String(m.agent || '') !== 'pending_created_agent');\n\nconst userName = String(profile.display_name || '').trim();\nconst awaitingName = Boolean(profile.awaiting_name);\nconst profileExists = Boolean(profile.exists);\n\nfunction cleanTextForPrompt(value) {\n  const allowed = new Set(['AI','API','JSON','HTML','CSS','JS','SQL','DB','UI','UX','HTTP','URL','N8N','OLLAMA','TELEGRAM','PYTHON','JAVASCRIPT','REACT','NODE','WEBHOOK','FRONTEND','BACKEND','MYSQL','PHP','PDF']);\n  return String(value || '')\n    .replace(/[\\u0600-\\u06FF\\u0750-\\u077F\\u08A0-\\u08FF\\uFB50-\\uFDFF\\uFE70-\\uFEFF\\u0400-\\u04FF\\u0370-\\u03FF\\u0E00-\\u0E7F\\u3040-\\u30FF\\uAC00-\\uD7AF\\u4E00-\\u9FFF\\u3400-\\u4DBF\\u3000-\\u303F\\uFF00-\\uFFEF\\u00C0-\\u024F]/g, '')\n    .replace(/[鈹忊敆鈹ｂ攦鈹乚+/g, ' ')\n    .replace(/\\[out\\]/gi, '')\n    .replace(/[\\\\*\\`#_]/g, '')\n    .replace(/&\\s*(lt|gt|amp)\\s*;/gi, ' ')\n      .replace(/[<>]/g, ' ')\n    .replace(/[A-Za-z][A-Za-z0-9_+#./-]*/g, (token) => {\n      const key = token.replace(/[.]+$/g, '').toUpperCase();\n      return allowed.has(key) ? token : '';\n    })\n    .replace(/(讝讬谉|讻讜住|砖专诪讜讟|讝讜谞讛|诪讝讚讬讬谉|讘谉 讝讜谞讛|fuck|sex|porn)/gi, '')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nconst bannedAgentNames = new Set(['agent', 'snakecaseagent', 'snake_case_agent', 'snake_case_name', 'custom_task_agent', 'new_agent', 'helper', 'assistant', 'hebrew_task_agent', 'generic_task_agent', 'custom_hebrew_agent']);\n\nconst activeAgents = registry\n  .filter(a => (a.status || 'active') === 'active' && !bannedAgentNames.has(String(a.name || '').toLowerCase()))\n  .sort((a, b) => {\n    const scoreA = Number(a.score_avg ?? a.score ?? 0);\n    const scoreB = Number(b.score_avg ?? b.score ?? 0);\n    const usesA = Number(a.uses ?? 0);\n    const usesB = Number(b.uses ?? 0);\n    return (scoreB - scoreA) || (usesB - usesA);\n  });\n\nconst agentList = activeAgents.slice(0, 8).length > 0\n  ? activeAgents.slice(0, 8).map(a => `- ${a.name}: ${cleanTextForPrompt(a.description)} (诪转讗讬诐 诇: ${cleanTextForPrompt(a.good_for || '')}; 爪讬讜谉: ${a.score_avg ?? a.score ?? '讞讚砖'}; 砖讬诪讜砖讬诐: ${a.uses ?? 0})`).join('\\n')\n  : '讗讬谉 注讚讬讬谉 住讜讻谞讬诐';\n\nconst recentMemory = memory.slice(-3)\n  .map(m => `[${m.agent}] ${cleanTextForPrompt(m.task).substring(0, 120)}`)\n  .join('\\n') || 'None';\n\nconst conversationHistory = memory.slice(-3)\n  .map(m => {\n    const assistant = m.agent === 'chitchat' ? '注讜讝专' : `注讜讝专 [${m.agent}]`;\n    return `诪砖转诪砖: ${cleanTextForPrompt(m.task).substring(0, 180)}\\n${assistant}: ${cleanTextForPrompt(m.result).substring(0, 220)}`;\n  })\n  .join('\\n\\n') || '';\n\n\nconst skipHistoryTasks = new Set(['讛讬', '讛讬讬', '砖诇讜诐', '诪讛 谞砖诪注', '诪讛 拽讜专讛']);\nconst historyTaskWords = ['讘讗讬讝讛 住讜讻谉', '讗讬讝讛 住讜讻谉 讛砖转诪砖', '讗讬讝讛 谞爪讬讙 讛砖转诪砖', '讛讬住讟讜专讬讬转 住讜讻谞讬诐', '砖讬诪讜砖讬 住讜讻谞讬诐', '讝讬讻专讜谉 住讜讻谞讬诐'];\nconst agentHistoryRows = [...memory].reverse()\n  .filter(m => {\n    const task = cleanTextForPrompt(m.task || '');\n    const isHistoryTask = historyTaskWords.some(word => task.includes(word));\n    return task && m.agent && !skipHistoryTasks.has(task) && !isHistoryTask;\n  })\n  .slice(0, 12)\n  .map((m, index) => {\n    const task = cleanTextForPrompt(m.task || '').substring(0, 180) || '诇讗 谞砖诪专讛 诪砖讬诪讛';\n    const agent = String(m.agent || '诇讗 讬讚讜注').replace(/[^A-Za-z0-9_讗-转-]/g, '').trim() || '诇讗 讬讚讜注';\n    const score = (m.score === null || m.score === undefined || m.score === '') ? '讗讬谉' : String(m.score) + '/10';\n    const time = String(m.timestamp || '').replace('T', ' ').substring(0, 16) || '诇讗 谞砖诪专';\n    const reason = cleanTextForPrompt(m.decision_reason || m.deductions || '').substring(0, 180) || '诇讗 谞砖诪专讛 住讬讘讛';\n    return `${index + 1}. 诪砖讬诪讛:\n${task}\n住讜讻谉:\n${agent}\n爪讬讜谉:\n${score}\n住讬讘讛:\n${reason}\n讝诪谉:\n${time}`;\n  });\n\nconst agentHistory = agentHistoryRows.length\n  ? `砖讬诪讜砖讬 住讜讻谞讬诐 诪讛讝讬讻专讜谉\n诪砖转诪砖: ${userName || '诪砖转诪砖'}\n\n${agentHistoryRows.join('\\n\\n')}`\n  : `${userName || '诪砖转诪砖'}, 讗讬谉 注讚讬讬谉 砖讬诪讜砖讬 住讜讻谞讬诐 砖诪讜专讬诐 讘讝讬讻专讜谉 讛讗讬砖讬 砖诇讱.`;\n\nconst lastScored = [...memory].reverse().find(m => m.score !== null && m.score !== undefined);\nconst lastEvaluation = lastScored ? {\n  task: lastScored.task || '',\n  agent: lastScored.agent || '',\n  score: lastScored.score,\n  deductions: lastScored.deductions || '诇讗 谞砖诪专 驻讬专讜讟 谞讬讻讜讬讬诐',\n  result: cleanTextForPrompt(lastScored.result).substring(0, 500),\n  timestamp: lastScored.timestamp || ''\n} : null;\n\nreturn [{ json: { userMessage, chatId, agents: activeAgents, agentList, recentMemory, conversationHistory, lastEvaluation, agentHistory, pendingCreatedAgent, profile, userName, awaitingName, profileExists } }];"
      },
