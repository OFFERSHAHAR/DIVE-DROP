      "parameters": {
        "jsCode": "const data = $('Prepare Data').first().json;\nconst msg = String(data.userMessage || '').trim();\nconst lower = msg.toLowerCase();\nconst agents = Array.isArray(data.agents) ? data.agents : [];\n\nconst hasAny = (words) => words.some(w => lower.includes(w.toLowerCase()));\nconst exactCasual = ['讛讬', '讛讬讬', '讛讬讬讬', '讛诇讜', '砖诇讜诐', '讘讜拽专 讟讜讘', '注专讘 讟讜讘', '诇讬诇讛 讟讜讘', '诪讛 谞砖诪注', '诪讛 拽讜专讛', '诪讛 讛诪爪讘', '转讜讚讛', '住讘讘讛', '讗讞诇讛'];\nconst scoreDetailWords = ['驻讬专讜讟 爪讬讜谉', '驻讬专讜讟 注诇 讛爪讬讜谉', '砖诇讞 驻讬专讜讟 注诇 讛爪讬讜谉', '驻专讟讬诐 注诇 讛爪讬讜谉', '诇诪讛 讛爪讬讜谉', '讛住讘专 注诇 讛爪讬讜谉'];\nconst chitchatWords = ['诪讬 讗转讛', '注讝专讛', '诪讛 讗转讛 讬讜讚注 诇注砖讜转'];\nconst codeWords = ['code', 'python', 'javascript', 'js', 'sql', 'html', 'css', 'react', 'bug', 'debug', '讚讬讘讗讙', '拽讜讚', '驻讜谞拽爪讬讛', '住拽专讬驻讟', '砖讙讬讗讛'];\nconst createAgentWords = ['爪讜专 诇讬 住讜讻谉', '转讬爪讜专 诇讬 住讜讻谉', '讘谞讛 诇讬 住讜讻谉', '转讘谞讛 诇讬 住讜讻谉', '转讻讬谉 诇讬 住讜讻谉', '爪讜专 住讜讻谉', '住讜讻谉 讞讚砖', '谞爪讬讙 讞讚砖'];\nconst historyWords = ['讘讗讬讝讛 住讜讻谉', '讗讬讝讛 住讜讻谉 讛砖转诪砖', '讗讬讝讛 谞爪讬讙 讛砖转诪砖', '住讜讻谉 讛砖转诪砖转', '谞爪讬讙 讛砖转诪砖转', '讛讬住讟讜专讬讬转 住讜讻谞讬诐', '砖讬诪讜砖讬 住讜讻谞讬诐', '讝讬讻专讜谉 住讜讻谞讬诐', '住讜讻谉 诇讗讬讝讜 诪砖讬诪讛', '谞爪讬讙 诇讗讬讝讜 诪砖讬诪讛'];\n\nfunction cleanName(value) {\n  let text = String(value || '').trim();\n  const match = text.match(/(?:拽讜专讗讬诐 诇讬|讛砖诐 砖诇讬|讗谞讬)\\s+([^,.!?\\n]+)$/i);\n  if (match) text = match[1];\n  text = text\n    .replace(/^(拽讜专讗讬诐 诇讬|讛砖诐 砖诇讬|讗谞讬)\\s+/i, '')\n    .replace(/(?:^|\\s)(转讬爪讜专|爪讜专|转注砖讛|讘谞讛|转讘谞讛|转讻讬谉|讛讻谉|爪专讬讱|专讜爪讛|住讜讻谉|谞爪讬讙).*$/i, '')\n    .replace(/[^\\u0590-\\u05FFa-zA-Z\\s'-]/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n  if (text.split(/\\s+/).length > 3) return '';\n  return text.slice(0, 40);\n}\n\nlet action = 'chitchat';\nlet agent_name = null;\nlet direct_reply = null;\nlet userName = data.userName || '';\nlet requestMessage = msg;\nlet selectionReason = '';\n\nif (!data.userName && !data.awaitingName) {\n  action = 'ask_name';\n  direct_reply = '讘专讜讱 讛讘讗. 讗讬讱 拽讜专讗讬诐 诇讱?\\n\\n讗讞专讬 砖转讻转讜讘 讗转 讛砖诐 砖诇讱, 讗讝讻讜专 讗讜转讜 讜讗驻谞讛 讗诇讬讱 讘砖诐 讘砖讬讞讜转 讛讘讗讜转.';\n} else if ((!data.userName && data.awaitingName) || /^\\s*(拽讜专讗讬诐 诇讬|讛砖诐 砖诇讬|讗谞讬)\\s+/i.test(msg)) {\n  const extractedName = cleanName(msg);\n  const inlineRequest = (() => {\n    const raw = msg.replace(/^\\s*(拽讜专讗讬诐 诇讬|讛砖诐 砖诇讬|讗谞讬)\\s+/i, '').trim();\n    const marker = raw.search(/\\s(爪讜专|转讬爪讜专|转注砖讛|讘谞讛|转讘谞讛|转讻讬谉|讛讻谉|爪专讬讱|专讜爪讛)\\s/i);\n    if (marker > 0) return raw.slice(marker).trim();\n    return '';\n  })();\n  if (extractedName && inlineRequest && inlineRequest.split(/\\s+/).filter(Boolean).length >= 3) {\n    action = 'create_agent';\n    userName = extractedName;\n    requestMessage = inlineRequest;\n    direct_reply = null;\n  } else if (extractedName) {\n    action = 'save_name';\n    userName = extractedName;\n    direct_reply = `谞注讬诐 诪讗讜讚, ${userName}.\\n\\n诪注讻砖讬讜 讗驻谞讛 讗诇讬讱 讘砖诐 讛讝讛. 讗诐 讻转讘转 讙诐 讘拽砖讛 讘讗讜转讛 讛讜讚注讛, 砖诇讞 讗讜转讛 砖讜讘 讘砖讜专讛 讞讚砖讛 讜讗讟驻诇 讘讛 诪讬讚.`;\n  } else {\n    action = 'ask_name';\n    direct_reply = '诇讗 讛爪诇讞转讬 诇讛讘讬谉 诪讛 讛砖诐 讘诇讘讚. 讻转讜讘 专拽 讗转 讛砖诐 砖诇讱, 诇诪砖诇: 注讜驻专';\n  }\n} else {\n  const wordCount = msg.split(/\\s+/).filter(Boolean).length;\n  const isShortCasual = wordCount <= 3 && (exactCasual.includes(lower) || hasAny(exactCasual));\n  const asksForScoreDetails = hasAny(scoreDetailWords) || (/^\\s*(驻讬专讜讟|驻专讟|砖诇讞 驻讬专讜讟|转谉 驻讬专讜讟)\\s*$/i.test(msg) && Boolean(data.lastEvaluation));\n  const asksForAgentHistory = hasAny(historyWords);\n  const pending = data.pendingCreatedAgent || null;\n  const confirmsPending = /^(讻谉|讻谉 转诪砖讬讱|诪讗砖专|诪讗砖专转|讗砖专|转讗砖专|转诪砖讬讱|讘爪注|转专讬抓|拽讚讬诪讛|讬讗诇诇讛|ok|yes)$/i.test(msg.trim());\n  const cancelsPending = /^(诇讗|讘讟诇|讘讬讟讜诇|注爪讜专|讗诇 转专讬抓|诇讗 注讻砖讬讜|cancel|no)$/i.test(msg.trim());\n\n  if (pending && confirmsPending) {\n    action = 'use_agent';\n    agent_name = pending.agentName;\n    requestMessage = pending.task;\n    direct_reply = null;\n    selectionReason = '讛诪砖转诪砖 讗讬砖专 诇讛专讬抓 讗转 讛住讜讻谉 讛讞讚砖 砖谞讜爪专 注诇 讛砖讗诇讛 讛诪拽讜专讬转.';\n  } else if (pending && cancelsPending) {\n    action = 'chitchat';\n    direct_reply = '讘讬讟诇转讬 讗转 讛讛专爪讛. 讛住讜讻谉 谞砖讗专 砖诪讜专 讜讗驻砖专 诇讛砖转诪砖 讘讜 讘讛诪砖讱.';\n  } else if (pending) {\n    action = 'chitchat';\n    direct_reply = '讬砖 住讜讻谉 讞讚砖 砖诪讜讻谉 诇讛专爪讛 注诇 讛砖讗诇讛 讛诪拽讜专讬转. 讻转讜讘 讻谉 讗讜 诪讗砖专 讻讚讬 诇讛专讬抓 讗讜转讜, 讗讜 讘讟诇 讻讚讬 诇注爪讜专.';\n  } else if (asksForAgentHistory) {\n    action = 'chitchat';\n    direct_reply = data.agentHistory || `${data.userName || '诪砖转诪砖'}, 讗讬谉 注讚讬讬谉 砖讬诪讜砖讬 住讜讻谞讬诐 砖诪讜专讬诐 讘讝讬讻专讜谉 讛讗讬砖讬 砖诇讱.`;\n  } else if (hasAny(createAgentWords)) {\n    action = 'create_agent';\n  } else if (asksForScoreDetails) {\n    action = 'chitchat';\n    const ev = data.lastEvaluation;\n    if (ev) {\n      direct_reply = `驻讬专讜讟 爪讬讜谉 讗讞专讜谉\\n诪砖转诪砖: ${data.userName}\\n住讜讻谉: ${ev.agent}\\n爪讬讜谉: ${ev.score}/10\\n住讬讘讛: ${ev.deductions}\\n诪砖讬诪讛: ${ev.task}`;\n    } else {\n      direct_reply = `${data.userName}, 讗讬谉 注讚讬讬谉 爪讬讜谉 砖诪讜专 讘讝讬讻专讜谉 讛讗讬砖讬 砖诇讱.`;\n    }\n  } else if (!msg || isShortCasual || hasAny(chitchatWords)) {\n    action = 'chitchat';\n    if (isShortCasual) {\n      direct_reply = `${data.userName || '砖诇讜诐'}, 砖诇讜诐. 讗讬讱 讗驻砖专 诇注讝讜专 诇讱 注讻砖讬讜?`;\n    }\n  } else if (hasAny(codeWords) && agents.some(a => a.name === 'code_helper')) {\n    action = 'use_agent';\n    agent_name = 'code_helper';\n  } else {\n    const tokens = lower\n      .replace(/[^a-z0-9讗-转_\\s]/gi, ' ')\n      .split(/\\s+/)\n      .filter(t => t.length >= 3);\n\n    const agentTimes = agents\n      .map(a => Date.parse(a.updated_at || a.last_used || a.created_at || ''))\n      .filter(Number.isFinite);\n    const newestTime = agentTimes.length ? Math.max(...agentTimes) : Date.now();\n    const oldestTime = agentTimes.length ? Math.min(...agentTimes) : newestTime;\n    const timeSpan = Math.max(1, newestTime - oldestTime);\n\n    const candidates = [];\n    for (const agent of agents) {\n      const haystack = [agent.name, agent.description, agent.good_for].join(' ').toLowerCase();\n      let matchScore = 0;\n      const matchedTokens = [];\n      for (const token of tokens) {\n        if (haystack.includes(token)) {\n          matchScore += 1;\n          matchedTokens.push(token);\n        }\n      }\n      if (matchScore <= 0) continue;\n\n      const agentScore = Number(agent.score_avg ?? agent.score ?? 0) || 0;\n      const quality = Math.min(agentScore, 10) / 10;\n      const uses = Number(agent.uses ?? 0) || 0;\n      const updatedMs = Date.parse(agent.updated_at || agent.last_used || agent.created_at || '') || oldestTime;\n      const recency = Math.max(0, Math.min(1, (updatedMs - oldestTime) / timeSpan));\n      const freshImprovedBonus = recency >= 0.65 && agentScore >= 8 ? 0.55 : (recency >= 0.65 && agentScore >= 7 ? 0.25 : 0);\n      const genericPenalty = /(砖讬诪讜砖 专讗砖讜谉|砖讬诪讜砖 砖谞讬|砖讬诪讜砖 砖诇讬砖讬|诪砖驻讟 讗讞讚 讘专讜专 注诇 讛转驻拽讬讚)/.test(haystack) ? 0.45 : 0;\n      const finalScore = (matchScore * 1.35) + (quality * 0.95) + (recency * 0.55) + (Math.min(uses, 12) / 120) + freshImprovedBonus - genericPenalty;\n\n      candidates.push({\n        agent,\n        matchScore,\n        matchedTokens: [...new Set(matchedTokens)].slice(0, 5),\n        agentScore,\n        uses,\n        updatedMs,\n        recency,\n        finalScore\n      });\n    }\n\n    candidates.sort((a, b) =>\n      (b.finalScore - a.finalScore) ||\n      (b.agentScore - a.agentScore) ||\n      (b.updatedMs - a.updatedMs)\n    );\n\n    let best = candidates[0] || null;\n    if (best) {\n      for (const candidate of candidates.slice(1)) {\n        const closeMatch = candidate.matchScore >= best.matchScore - 0.5;\n        const fresherAndNoWorse = candidate.updatedMs > best.updatedMs && candidate.agentScore >= best.agentScore - 0.25;\n        const closeEnough = candidate.finalScore >= best.finalScore - 0.35;\n        if (closeMatch && fresherAndNoWorse && closeEnough) {\n          best = candidate;\n        }\n      }\n    }\n\n    if (best && best.finalScore >= 1.85 && best.matchScore >= 1) {\n      action = 'use_agent';\n      agent_name = best.agent.name;\n      const updated = best.agent.updated_at || best.agent.last_u