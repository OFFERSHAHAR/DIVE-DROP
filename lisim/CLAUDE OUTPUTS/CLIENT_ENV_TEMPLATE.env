# ============================================================================
# WhatsApp MCP Server - Environment Configuration Template
# ============================================================================
# Copy this file to .env in your client-specific folder and fill in values
# from your Meta App Dashboard
# ============================================================================

# 1. WhatsApp Cloud API Credentials (REQUIRED)
# ============================================================================
# Where to find:
# Meta App Dashboard > Your App > WhatsApp > API Setup > Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=

# Meta App Dashboard > Your App > WhatsApp > API Setup > Permanent Access Token
# IMPORTANT: Use a PERMANENT token, not a temporary one (expires after 2 hours)
WHATSAPP_ACCESS_TOKEN=

# Meta App Dashboard > Your App > WhatsApp > Business Account Settings
WHATSAPP_BUSINESS_ACCOUNT_ID=

# 2. Webhook Configuration (OPTIONAL - only if receiving messages)
# ============================================================================
# Random secret string - you'll enter the SAME value in Meta Dashboard
# Generate with: openssl rand -hex 32
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Port for incoming webhook server (e.g., 3000, 8080)
# Leave empty to run in send-only mode (no incoming message receiving)
WEBHOOK_PORT=3000

# HTTP path for webhooks (default: /webhook)
WEBHOOK_PATH=/webhook

# 3. Security (RECOMMENDED for production)
# ============================================================================
# Meta App Dashboard > Settings > Basic > App Secret
# Used to verify X-Hub-Signature-256 header on incoming webhooks
# If not set, webhooks will still work but without signature verification
WHATSAPP_APP_SECRET=

# 4. API Configuration (OPTIONAL)
# ============================================================================
# WhatsApp Cloud API version (default: v21.0)
WHATSAPP_API_VERSION=v21.0

# 5. Logging (OPTIONAL)
# ============================================================================
# Logging verbosity: info or debug
LOG_LEVEL=info

# 6. n8n Integration (OPTIONAL)
# ============================================================================
# For connecting to n8n MCP Server
# Set these if you're integrating with n8n workflows
N8N_MCP_URL=https://opiko666.app.n8n.cloud/mcp-server/http
N8N_MCP_TOKEN=

# ============================================================================
# QUICK START CHECKLIST
# ============================================================================
# 1. [ ] Go to https://developers.facebook.com/apps
# 2. [ ] Select your app and go to WhatsApp > API Setup
# 3. [ ] Copy Phone Number ID → WHATSAPP_PHONE_NUMBER_ID
# 4. [ ] Copy Permanent Access Token → WHATSAPP_ACCESS_TOKEN
# 5. [ ] Find Business Account ID → WHATSAPP_BUSINESS_ACCOUNT_ID
# 6. [ ] (Optional) Copy App Secret → WHATSAPP_APP_SECRET
# 7. [ ] (For webhooks) Generate random token → WHATSAPP_WEBHOOK_VERIFY_TOKEN
# 8. [ ] Save this file as .env in your client folder
# 9. [ ] Run: node dist/index.js
